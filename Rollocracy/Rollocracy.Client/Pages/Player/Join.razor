@page "/player/join"
@inject HttpClient Http
@inject NavigationManager Navigation
@using System.Net.Http.Json
@using Rollocracy.Domain.Entities

@rendermode InteractiveAuto

<h3>Rejoindre une session</h3>

<input @bind="SessionCode" placeholder="Code de session" />
<input @bind="PlayerName" placeholder="Votre pseudo" />

<button @onclick="JoinSession">Rejoindre</button>

@if (!string.IsNullOrEmpty(Message))
{
    <p>@Message</p>
}

@code {
    private string SessionCode = string.Empty;
    private string PlayerName = string.Empty;
    private string Message = string.Empty;

    private async Task JoinSession()
    {
        try
        {
            var request = new
            {
                SessionCode = SessionCode,
                PlayerName = PlayerName
            };

            var response = await Http.PostAsJsonAsync("api/session/join", request);

            if (response.IsSuccessStatusCode)
            {
                var player = await response.Content.ReadFromJsonAsync<PlayerSession>();

                Navigation.NavigateTo($"/player/room/{player.Id}");
            }
            else
            {
                Message = "Impossible de rejoindre la session";
            }
        }
        catch (Exception ex)
        {
            Message = $"Erreur : {ex.Message}";
        }
    }
}