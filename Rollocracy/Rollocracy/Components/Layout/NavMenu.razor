@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Extensions.Localization
@using Rollocracy.Localization
@inject IStringLocalizer<SharedTexts> L

<div class="rc-nav @(IsCollapsed ? "collapsed" : string.Empty)">
    <div class="rc-nav__header">
        <div class="rc-nav__header-actions">
            <button type="button"
                    class="icon-button"
                    title="@L["Layout_CycleTheme"]"
                    @onclick="async () => await OnCycleTheme.InvokeAsync()">
                @ThemeGlyph
            </button>

            <button type="button"
                    class="icon-button"
                    title="@L["Layout_SupportSoon"]"
                    disabled>
                ❤
            </button>

            <button type="button"
                    class="icon-button"
                    title="@L["Layout_ToggleSidebar"]"
                    @onclick="async () => await OnToggleSidebar.InvokeAsync()">
                @(IsCollapsed ? "»" : "«")
            </button>
        </div>

        <div class="rc-nav__welcome">
            <div class="rc-nav__welcome-label">@L["Layout_Welcome"]</div>
            <div class="rc-nav__welcome-name">
                @(string.IsNullOrWhiteSpace(CurrentUserDisplayName)
                    ? L["Layout_Guest"]
                    : CurrentUserDisplayName)
            </div>
        </div>
    </div>

    <nav class="rc-nav__sections">
        <div class="rc-nav__section">
            <div class="rc-nav__section-title">@L["Layout_UserSection"]</div>

            <AuthorizeView>
                <Authorizing>
                    <span class="rc-nav__loading">@L["Common_Loading"]</span>
                </Authorizing>

                <NotAuthorized>
                    <NavLink class="rc-nav__link" href="/login" title="@L["Home_Login"]">
                        <span class="rc-nav__icon">⇥</span>
                        <span class="rc-nav__label">@L["Home_Login"]</span>
                    </NavLink>

                    <NavLink class="rc-nav__link" href="/register" title="@L["Home_Register"]">
                        <span class="rc-nav__icon">＋</span>
                        <span class="rc-nav__label">@L["Home_Register"]</span>
                    </NavLink>
                </NotAuthorized>

                <Authorized>
                    <a class="rc-nav__link" href="/auth/logout" title="@L["Home_Logout"]">
                        <span class="rc-nav__icon">⇤</span>
                        <span class="rc-nav__label">@L["Home_Logout"]</span>
                    </a>

                    <button type="button" class="rc-nav__link rc-nav__link--disabled" disabled title="@L["Layout_AccountSettings"]">
                        <span class="rc-nav__icon">⚙</span>
                        <span class="rc-nav__label">@L["Layout_AccountSettings"]</span>
                    </button>
                </Authorized>
            </AuthorizeView>
        </div>

        @if (CanShowMjMenus)
        {
            <div class="rc-nav__section">
                <div class="rc-nav__section-title">@L["Layout_OutsideSessionSection"]</div>

                <NavLink class="rc-nav__link" href="/mj/gamesystems" title="@L["Layout_GameSystems"]">
                    <span class="rc-nav__icon">◫</span>
                    <span class="rc-nav__label">@L["Layout_GameSystems"]</span>
                </NavLink>

                <NavLink class="rc-nav__link" href="/mj/sessions" title="@L["Layout_GameSessions"]">
                    <span class="rc-nav__icon">◎</span>
                    <span class="rc-nav__label">@L["Layout_GameSessions"]</span>
                </NavLink>
            </div>
        }

        @if (CanShowMjMenus && CurrentSessionId.HasValue)
        {
            <div class="rc-nav__section">
                <div class="rc-nav__section-title">@L["Layout_CurrentSessionSection"]</div>

                <NavLink class="rc-nav__link" href="@($"/mj/session/{CurrentSessionId.Value}")" Match="NavLinkMatch.All" title="@L["Layout_ViewCharacters"]">
                    <span class="rc-nav__icon">▣</span>
                    <span class="rc-nav__label">@L["Layout_ViewCharacters"]</span>
                </NavLink>

                <NavLink class="rc-nav__link" href="@($"/mj/session/{CurrentSessionId.Value}/test")" title="@L["Layout_Test"]">
                    <span class="rc-nav__icon">⚄</span>
                    <span class="rc-nav__label">@L["Layout_Test"]</span>
                </NavLink>

                <a class="rc-nav__link" href="@($"/mj/session/{CurrentSessionId.Value}/poll")" title="@L["Layout_Poll"]">
                    <span class="rc-nav__icon">☰</span>
                    <span class="rc-nav__label">@L["Layout_Poll"]</span>
                </a>

                <NavLink class="rc-nav__link" href="@($"/mj/session/{CurrentSessionId.Value}/mass-distribution")" title="@L["MassDistribution_Title"]">
                    <span class="rc-nav__icon">✦</span>
                    <span class="rc-nav__label">@L["MassDistribution_Title"]</span>
                </NavLink>

                <NavLink class="rc-nav__link" href="@($"/mj/session/{CurrentSessionId.Value}/random-draw")" title="@L["RandomDraw_Title"]">
                    <span class="rc-nav__icon">⟡</span>
                    <span class="rc-nav__label">@L["RandomDraw_Title"]</span>
                </NavLink>

                <NavLink class="rc-nav__link" href="@($"/mj/session/{CurrentSessionId.Value}/settings")" title="@L["Layout_SessionSettings"]">
                    <span class="rc-nav__icon">⚙</span>
                    <span class="rc-nav__label">@L["Layout_SessionSettings"]</span>
                </NavLink>
            </div>
        }
    </nav>
</div>

@code {
    [Parameter] public bool IsCollapsed { get; set; }
    [Parameter] public string CurrentUserDisplayName { get; set; } = string.Empty;
    [Parameter] public bool CanShowMjMenus { get; set; }
    [Parameter] public Guid? CurrentSessionId { get; set; }
    [Parameter] public string CurrentTheme { get; set; } = "light";
    [Parameter] public EventCallback OnToggleSidebar { get; set; }
    [Parameter] public EventCallback OnCycleTheme { get; set; }

    private string ThemeGlyph => CurrentTheme == "dark" ? "☾" : "☀";
}
