@page "/join"
@rendermode InteractiveServer
@using Microsoft.Extensions.Localization
@using Rollocracy.Localization
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedTexts> L

<h3>@L["Join_Title"]</h3>

<p>@L["Join_Description"]</p>

<div>
    <label>@L["Join_GameMasterUsername"]</label><br />
    <input @bind="GameMasterUsername" />
</div>

<div>
    <label>@L["Join_SessionSlug"]</label><br />
    <input @bind="SessionSlug" />
</div>

<button @onclick="GoToSession">@L["Join_Submit"]</button>

@if (!string.IsNullOrWhiteSpace(Message))
{
    <p>@Message</p>
}

@code {
    private string GameMasterUsername = string.Empty;
    private string SessionSlug = string.Empty;
    private string Message = string.Empty;

    private void GoToSession()
    {
        if (string.IsNullOrWhiteSpace(GameMasterUsername))
        {
            Message = L["Join_GameMasterRequired"];
            return;
        }

        if (string.IsNullOrWhiteSpace(SessionSlug))
        {
            Message = L["Join_SessionSlugRequired"];
            return;
        }

        Navigation.NavigateTo($"/{GameMasterUsername.Trim()}/{SessionSlug.Trim()}");
    }
}