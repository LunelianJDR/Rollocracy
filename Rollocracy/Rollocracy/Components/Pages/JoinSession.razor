@page "/{mjUsername}/{sessionSlug}"
@rendermode InteractiveServer
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.SignalR
@using Microsoft.Extensions.Localization
@using Rollocracy.Domain.Entities
@using Rollocracy.Hubs
@using Rollocracy.Localization
@inject Rollocracy.Domain.Interfaces.ISessionService SessionService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation
@inject IHubContext<SessionHub> SessionHubContext
@inject IStringLocalizer<SharedTexts> L

<h3>@L["JoinSession_Title"]</h3>

<p>@L["JoinSession_GameMasterLabel"] : @mjUsername</p>
<p>@L["JoinSession_SessionLabel"] : @sessionSlug</p>

@if (!IsLoaded)
{
    <p>@L["Common_Loading"]</p>
}
else if (!IsAuthenticated)
{
    <p>@L["JoinSession_MustBeLoggedIn"]</p>
}
else if (Session is null)
{
    <p>@L["JoinSession_NotFound"]</p>
}
else if (!Session.IsActive)
{
    <p>@L["JoinSession_Inactive"]</p>
}
else
{
    @if (RequiresPassword)
    {
        <div>
            <label>@L["JoinSession_PasswordLabel"]</label><br />
            <input @bind="SessionPassword" />
        </div>
    }
    else
    {
        <p>@L["JoinSession_NoPasswordRequired"]</p>
    }

    <button @onclick="HandleJoinSession">@L["JoinSession_Submit"]</button>

    @if (!string.IsNullOrWhiteSpace(Message))
    {
        <p>@Message</p>
    }
}

@code {
    [Parameter] public string mjUsername { get; set; } = string.Empty;
    [Parameter] public string sessionSlug { get; set; } = string.Empty;

    private Session? Session;
    private bool IsLoaded;
    private bool IsAuthenticated;
    private bool RequiresPassword;

    private Guid CurrentUserId;
    private string CurrentUsername = string.Empty;
    private bool CurrentUserIsGameMaster;

    private string SessionPassword = string.Empty;
    private string Message = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        IsAuthenticated = user.Identity?.IsAuthenticated == true;

        if (IsAuthenticated)
        {
            var userIdValue = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            var isGameMasterValue = user.FindFirst("IsGameMaster")?.Value;

            if (!string.IsNullOrWhiteSpace(userIdValue))
            {
                CurrentUserId = Guid.Parse(userIdValue);
            }

            CurrentUsername = user.Identity?.Name ?? string.Empty;

            if (!string.IsNullOrWhiteSpace(isGameMasterValue))
            {
                CurrentUserIsGameMaster = bool.Parse(isGameMasterValue);
            }

            Session = await SessionService.GetSessionByOwnerAndSlugAsync(mjUsername, sessionSlug);

            if (Session is not null)
            {
                RequiresPassword = !string.IsNullOrWhiteSpace(Session.SessionPassword);
            }
        }

        IsLoaded = true;
    }

    private async Task HandleJoinSession()
    {
        try
        {
            if (Session is null)
            {
                Message = L["JoinSession_NotFound"];
                return;
            }

            if (!Session.IsActive)
            {
                Message = L["JoinSession_Inactive"];
                return;
            }

            var playerSession = await SessionService.JoinSessionAsync(
                mjUsername,
                sessionSlug,
                SessionPassword,
                CurrentUserId,
                CurrentUsername,
                CurrentUserIsGameMaster);

            await SessionHubContext.Clients
                .Group(playerSession.SessionId.ToString())
                .SendAsync("PlayerJoined", playerSession);

            Navigation.NavigateTo($"/player/room/{playerSession.Id}");
        }
        catch (Exception ex)
        {
            Message = $"{L["Common_Error"]} : {ex.Message}";
        }
    }
}