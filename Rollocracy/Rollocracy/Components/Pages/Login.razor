@page "/login"
@using Microsoft.Extensions.Localization
@using Rollocracy.Localization
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedTexts> L

<h3>@L["Login_Title"]</h3>

@if (HasError)
{
    <p>@L["Login_InvalidCredentials"]</p>
}

<form method="post" action="/auth/login">
    <div>
        <label for="username">@L["Login_Username"]</label><br />
        <input id="username" name="Username" />
    </div>

    <div>
        <label for="password">@L["Login_Password"]</label><br />
        <input id="password" name="Password" type="password" />
    </div>

    <button type="submit">@L["Login_Submit"]</button>
</form>

@code {
    private bool HasError;

    protected override void OnInitialized()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);

        if (!string.IsNullOrWhiteSpace(uri.Query) && uri.Query.Contains("error=1"))
        {
            HasError = true;
        }
    }
}