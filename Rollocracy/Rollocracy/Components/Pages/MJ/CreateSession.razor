@page "/mj/create-session"
@rendermode InteractiveServer

@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Extensions.Localization
@using Rollocracy.Localization

@inject Rollocracy.Domain.Interfaces.ISessionService SessionService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedTexts> L

<h3>@L["CreateSession_Title"]</h3>

@if (!IsLoaded)
{
    <p>@L["Common_Loading"]</p>
}
else if (RedirectToHome)
{
    <p>@L["Common_Loading"]</p>
}
else
{
    <div>
        <label>@L["CreateSession_Name"]</label><br />
        <input @bind="SessionName" />
    </div>

    <div>
        <label>@L["CreateSession_PasswordOptional"]</label><br />
        <input @bind="SessionPassword" />
    </div>

    <button @onclick="HandleCreateSession">@L["CreateSession_Submit"]</button>

    @if (!string.IsNullOrWhiteSpace(Message))
    {
        <p>@Message</p>
    }

    @if (!string.IsNullOrWhiteSpace(CreatedJoinUrl))
    {
        <p>@L["CreateSession_UrlLabel"] : <code>@CreatedJoinUrl</code></p>

        @if (string.IsNullOrWhiteSpace(CreatedSessionPassword))
        {
            <p>@L["CreateSession_PasswordLabel"] : @L["Common_None"]</p>
        }
        else
        {
            <p>@L["CreateSession_PasswordLabel"] : <code>@CreatedSessionPassword</code></p>
        }
    }
}

@code {
    private string SessionName = string.Empty;
    private string SessionPassword = string.Empty;
    private string Message = string.Empty;
    private string CreatedJoinUrl = string.Empty;
    private string CreatedSessionPassword = string.Empty;
    private bool IsLoaded;
    private bool RedirectToHome;
    private Guid CurrentUserId;
    private string CurrentUsername = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var isAuthenticated = user.Identity?.IsAuthenticated == true;

        if (!isAuthenticated)
        {
            RedirectToHome = true;
            IsLoaded = true;
            return;
        }

        var userIdValue = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (string.IsNullOrWhiteSpace(userIdValue))
        {
            RedirectToHome = true;
            IsLoaded = true;
            return;
        }

        CurrentUserId = Guid.Parse(userIdValue);
        CurrentUsername = user.Identity?.Name ?? string.Empty;

        var canCreateSessions = await SessionService.CanUserCreateSessionsAsync(CurrentUserId);

        if (!canCreateSessions)
        {
            RedirectToHome = true;
            IsLoaded = true;
            return;
        }

        IsLoaded = true;
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && RedirectToHome)
        {
            Navigation.NavigateTo("/", forceLoad: true);
        }

        return Task.CompletedTask;
    }

    private async Task HandleCreateSession()
    {
        try
        {
            Message = string.Empty;
            CreatedJoinUrl = string.Empty;
            CreatedSessionPassword = string.Empty;

            if (string.IsNullOrWhiteSpace(SessionName))
            {
                Message = L["CreateSession_NameRequired"];
                return;
            }

            var gameSystemId = Guid.NewGuid();

            var session = await SessionService.CreateSessionAsync(
                CurrentUserId,
                gameSystemId,
                SessionName,
                SessionPassword);

            CreatedJoinUrl = $"{Navigation.BaseUri}{CurrentUsername}/{session.SessionSlug}";
            CreatedSessionPassword = SessionPassword;
            Message = L["CreateSession_Success"];

            Navigation.NavigateTo($"/mj/session/{session.Id}");
        }
        catch (Exception ex)
        {
            Message = $"{L["Common_Error"]} : {ex.Message}";
        }
    }
}