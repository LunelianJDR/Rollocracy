@page "/mj/gamesystems/{GameSystemId:guid}"
@rendermode InteractiveServer

@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Extensions.Localization
@using Rollocracy.Domain.GameRules
@using Rollocracy.Localization

@inject Rollocracy.Domain.Interfaces.IGameSystemService GameSystemService
@inject Rollocracy.Domain.Interfaces.ISessionService SessionService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedTexts> L

<h3>@L["EditGameSystem_Title"]</h3>

@if (!IsLoaded)
{
    <p>@L["Common_Loading"]</p>
}
else if (RedirectToHome)
{
    <p>@L["Common_Loading"]</p>
}
else if (CurrentSystem is null)
{
    <p>@L["EditGameSystem_NotFound"]</p>
}
else
{
    <div class="alert alert-info">
        <p>@L["EditGameSystem_FoundationDeliveryNotice"]</p>
        <p>@L["EditGameSystem_DiceDefaultHelp"]</p>
    </div>

    <h4>@L["EditGameSystem_GeneralSection"]</h4>

    <div>
        <label>@L["EditGameSystem_Name"]</label><br />
        <input @bind="CurrentSystem.Name" />
    </div>

    <div>
        <label>@L["EditGameSystem_Description"]</label><br />
        <textarea @bind="CurrentSystem.Description"></textarea>
    </div>

    <div>
        <label>@L["EditGameSystem_ResolutionMode"]</label><br />
        <select @bind="CurrentSystem.TestResolutionMode">
            <option value="@TestResolutionMode.SuccessThreshold">@L["Resolution_SuccessThreshold"]</option>
            <option value="@TestResolutionMode.RollUnderAttribute">@L["Resolution_RollUnderAttribute"]</option>
        </select>
    </div>

    @if (!CurrentSystem.IsLockedToSessionCopy && CurrentSystem.ImpactedSessions.Count > 0)
    {
        <div class="alert alert-warning" style="margin-top:12px;">
            <p><strong>@L["EditGameSystem_SharedWarningTitle"]</strong></p>
            <p>@L["EditGameSystem_SharedWarningText"]</p>
            <ul>
                @foreach (var session in CurrentSystem.ImpactedSessions)
                {
                    <li>@session.SessionName</li>
                }
            </ul>
        </div>
    }

    <div class="alert alert-secondary" style="margin-top:12px;">
        <p>@L["EditGameSystem_ApplyOnlyWhenConfirmed"]</p>
        <p>@L["EditGameSystem_DeletionResponsibilityWarning"]</p>
    </div>

    <hr />

    <h4>@L["EditGameSystem_AttributesSection"]</h4>

    <button @onclick="AddAttributeRow">@L["EditGameSystem_AddAttributeRow"]</button>

    @foreach (var attributeItem in CurrentSystem.Attributes)
    {
        <div style="margin-top:12px; padding:8px; border:1px solid #ccc;">
            @if (attributeItem.IsDeleted)
            {
                <p><strong>@attributeItem.Name</strong> - @L["EditGameSystem_PendingDeletion"]</p>
                <button @onclick="() => attributeItem.IsDeleted = false">@L["EditGameSystem_Restore"]</button>
            }
            else
            {
                <div>
                    <label>@L["Common_Name"]</label><br />
                    <input @bind="attributeItem.Name" />
                </div>
                <div>
                    <label>@L["Common_Min"]</label><br />
                    <input type="number" @bind="attributeItem.MinValue" />
                </div>
                <div>
                    <label>@L["Common_Max"]</label><br />
                    <input type="number" @bind="attributeItem.MaxValue" />
                </div>
                <div>
                    <label>@L["EditGameSystem_DefaultMode"]</label><br />
                    <select @bind="attributeItem.DefaultValueMode">
                        <option value="@BaseValueGenerationMode.Fixed">@L["EditGameSystem_DefaultModeFixed"]</option>
                        <option value="@BaseValueGenerationMode.DiceExpression">@L["EditGameSystem_DefaultModeDice"]</option>
                    </select>
                </div>

                @if (attributeItem.DefaultValueMode == BaseValueGenerationMode.Fixed)
                {
                    <div>
                        <label>@L["EditGameSystem_DefaultFixedValue"]</label><br />
                        <input type="number" @bind="attributeItem.DefaultValue" />
                    </div>
                }
                else
                {
                    <div>
                        <label>@L["EditGameSystem_DefaultFlatBonus"]</label><br />
                        <input type="number" @bind="attributeItem.DefaultValueFlatBonus" />
                    </div>
                    <div>
                        <label>@L["EditGameSystem_DefaultDiceCount"]</label><br />
                        <input type="number" @bind="attributeItem.DefaultValueDiceCount" />
                    </div>
                    <div>
                        <label>@L["EditGameSystem_DefaultDiceSides"]</label><br />
                        <input type="number" @bind="attributeItem.DefaultValueDiceSides" />
                    </div>
                }

                @if (attributeItem.AttributeDefinitionId.HasValue)
                {
                    <button @onclick="() => attributeItem.IsDeleted = true">@L["EditGameSystem_Delete"]</button>
                }
                else
                {
                    <button @onclick="() => CurrentSystem.Attributes.Remove(attributeItem)">@L["EditGameSystem_Delete"]</button>
                }
            }
        </div>
    }

    <hr />

    <h4>@L["EditGameSystem_DerivedStatsSection"]</h4>
    <p>@L["EditGameSystem_DerivedStatsHelp"]</p>

    <button @onclick="AddDerivedStatRow">@L["EditGameSystem_AddDerivedStatRow"]</button>

    @foreach (var derivedStat in CurrentSystem.DerivedStats)
    {
        <div style="margin-top:12px; padding:8px; border:1px solid #ccc;">
            @if (derivedStat.IsDeleted)
            {
                <p><strong>@derivedStat.Name</strong> - @L["EditGameSystem_PendingDeletion"]</p>
                <button @onclick="() => derivedStat.IsDeleted = false">@L["EditGameSystem_Restore"]</button>
            }
            else
            {
                <div>
                    <label>@L["Common_Name"]</label><br />
                    <input @bind="derivedStat.Name" />
                </div>
                <div>
                    <label>@L["Common_Min"]</label><br />
                    <input type="number" @bind="derivedStat.MinValue" />
                </div>
                <div>
                    <label>@L["Common_Max"]</label><br />
                    <input type="number" @bind="derivedStat.MaxValue" />
                </div>
                <div>
                    <label>@L["EditGameSystem_RoundMode"]</label><br />
                    <select @bind="derivedStat.RoundMode">
                        <option value="@ComputedValueRoundMode.Ceiling">@L["EditGameSystem_RoundModeCeiling"]</option>
                        <option value="@ComputedValueRoundMode.Floor">@L["EditGameSystem_RoundModeFloor"]</option>
                        <option value="@ComputedValueRoundMode.Nearest">@L["EditGameSystem_RoundModeNearest"]</option>
                        <option value="@ComputedValueRoundMode.None">@L["EditGameSystem_RoundModeNone"]</option>
                    </select>
                </div>
                <div>
                    <label>@L["EditGameSystem_DisplayOrder"]</label><br />
                    <input type="number" @bind="derivedStat.DisplayOrder" />
                </div>

                <div style="margin-top:8px;">
                    <button @onclick="() => AddDerivedComponentRow(derivedStat)">@L["EditGameSystem_AddDerivedComponentRow"]</button>
                </div>

                <div style="margin-left:20px; margin-top:8px;">
                    @foreach (var component in derivedStat.Components)
                    {
                        <div style="margin-top:8px; border:1px dashed #aaa; padding:8px;">
                            @if (component.IsDeleted)
                            {
                                <span><strong>@GetBaseAttributeName(component.AttributeDefinitionId)</strong> - @L["EditGameSystem_PendingDeletion"]</span>
                                <button @onclick="() => component.IsDeleted = false">@L["EditGameSystem_Restore"]</button>
                            }
                            else
                            {
                                <div>
                                    <label>@L["EditGameSystem_ComponentAttribute"]</label><br />
                                    <select @bind="component.AttributeDefinitionId">
                                        @foreach (var attributeRef in CurrentSystem.AvailableBaseAttributes)
                                        {
                                            <option value="@attributeRef.AttributeDefinitionId">@attributeRef.Name</option>
                                        }
                                    </select>
                                </div>
                                <div>
                                    <label>@L["EditGameSystem_ComponentWeight"]</label><br />
                                    <input type="number" @bind="component.Weight" />
                                </div>
                                <p>@L["EditGameSystem_ComponentWeightHelp"]</p>

                                @if (component.DerivedStatComponentId.HasValue)
                                {
                                    <button @onclick="() => component.IsDeleted = true">@L["EditGameSystem_Delete"]</button>
                                }
                                else
                                {
                                    <button @onclick="() => derivedStat.Components.Remove(component)">@L["EditGameSystem_Delete"]</button>
                                }
                            }
                        </div>
                    }
                </div>

                @if (derivedStat.DerivedStatDefinitionId.HasValue)
                {
                    <button @onclick="() => derivedStat.IsDeleted = true">@L["EditGameSystem_Delete"]</button>
                }
                else
                {
                    <button @onclick="() => CurrentSystem.DerivedStats.Remove(derivedStat)">@L["EditGameSystem_Delete"]</button>
                }
            }
        </div>
    }

    <hr />

    <h4>@L["EditGameSystem_TraitsSection"]</h4>

    <button @onclick="AddTraitRow">@L["EditGameSystem_AddTraitTypeRow"]</button>

    @foreach (var trait in CurrentSystem.Traits)
    {
        <div style="margin-top:12px; padding:8px; border:1px solid #ccc;">
            @if (trait.IsDeleted)
            {
                <p><strong>@trait.Name</strong> - @L["EditGameSystem_PendingDeletion"]</p>
                <button @onclick="() => trait.IsDeleted = false">@L["EditGameSystem_Restore"]</button>
            }
            else
            {
                <div>
                    <label>@L["EditGameSystem_TraitTypeName"]</label><br />
                    <input @bind="trait.Name" />
                </div>

                <button @onclick="() => AddTraitOptionRow(trait)">@L["EditGameSystem_AddOptionRow"]</button>

                <div style="margin-left:20px; margin-top:8px;">
                    @foreach (var option in trait.Options)
                    {
                        <div style="margin-top:8px;">
                            @if (option.IsDeleted)
                            {
                                <span><strong>@option.Name</strong> - @L["EditGameSystem_PendingDeletion"]</span>
                                <button @onclick="() => option.IsDeleted = false">@L["EditGameSystem_Restore"]</button>
                            }
                            else
                            {
                                <input @bind="option.Name" />

                                @if (option.TraitOptionId.HasValue)
                                {
                                    <button @onclick="() => option.IsDeleted = true">@L["EditGameSystem_Delete"]</button>
                                }
                                else
                                {
                                    <button @onclick="() => trait.Options.Remove(option)">@L["EditGameSystem_Delete"]</button>
                                }
                            }
                        </div>
                    }
                </div>

                @if (trait.TraitDefinitionId.HasValue)
                {
                    <button @onclick="() => trait.IsDeleted = true">@L["EditGameSystem_Delete"]</button>
                }
                else
                {
                    <button @onclick="() => CurrentSystem.Traits.Remove(trait)">@L["EditGameSystem_Delete"]</button>
                }
            }
        </div>
    }

    <hr />

    <h4>@L["EditGameSystem_GaugesSection"]</h4>

    <button @onclick="AddGaugeRow">@L["EditGameSystem_AddGaugeRow"]</button>

    @foreach (var gauge in CurrentSystem.Gauges)
    {
        <div style="margin-top:12px; padding:8px; border:1px solid #ccc;">
            @if (gauge.IsDeleted)
            {
                <p><strong>@gauge.Name</strong> - @L["EditGameSystem_PendingDeletion"]</p>
                <button @onclick="() => gauge.IsDeleted = false">@L["EditGameSystem_Restore"]</button>
            }
            else
            {
                <div>
                    <label>@L["Common_Name"]</label><br />
                    <input @bind="gauge.Name" />
                </div>
                <div>
                    <label>@L["Common_Min"]</label><br />
                    <input type="number" @bind="gauge.MinValue" />
                </div>
                <div>
                    <label>@L["Common_Max"]</label><br />
                    <input type="number" @bind="gauge.MaxValue" />
                </div>
                <div>
                    <label>@L["Common_DefaultValue"]</label><br />
                    <input type="number" @bind="gauge.DefaultValue" />
                </div>
                <div>
                    <label>@L["EditGameSystem_IsHealthGauge"]</label>
                    <input type="checkbox" @bind="gauge.IsHealthGauge" />
                </div>

                @if (gauge.GaugeDefinitionId.HasValue)
                {
                    <button @onclick="() => gauge.IsDeleted = true">@L["EditGameSystem_Delete"]</button>
                }
                else
                {
                    <button @onclick="() => CurrentSystem.Gauges.Remove(gauge)">@L["EditGameSystem_Delete"]</button>
                }
            }
        </div>
    }

    <hr />

    <button @onclick="ApplyChanges">@L["EditGameSystem_ApplyChanges"]</button>

    @if (CurrentSystem.CanUndoLastChange)
    {
        <button @onclick="UndoLastChange">@L["EditGameSystem_UndoLastChange"]</button>
    }

    @if (ShowSharedConfirm)
    {
        <div class="alert alert-warning" style="margin-top:12px;">
            <p>@L["EditGameSystem_SharedWarningContinueQuestion"]</p>
            <button @onclick="ConfirmApplyChanges">@L["Common_Yes"]</button>
            <button @onclick="CancelApplyChanges">@L["Common_No"]</button>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Message))
    {
        <p>@Message</p>
    }
}

@code {
    [Parameter] public Guid GameSystemId { get; set; }

    private bool IsLoaded;
    private bool RedirectToHome;
    private Guid CurrentUserId;
    private string Message = string.Empty;
    private bool ShowSharedConfirm;
    private GameSystemEditorDto? CurrentSystem;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        var isAuthenticated = user.Identity?.IsAuthenticated == true;
        var userIdValue = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (!isAuthenticated || string.IsNullOrWhiteSpace(userIdValue))
        {
            RedirectToHome = true;
            IsLoaded = true;
            return;
        }

        CurrentUserId = Guid.Parse(userIdValue);

        var canCreateSessions = await SessionService.CanUserCreateSessionsAsync(CurrentUserId);

        if (!canCreateSessions)
        {
            RedirectToHome = true;
            IsLoaded = true;
            return;
        }

        await LoadEditor();
        IsLoaded = true;
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && RedirectToHome)
        {
            Navigation.NavigateTo("/", forceLoad: true);
        }

        return Task.CompletedTask;
    }

    private async Task LoadEditor()
    {
        Message = string.Empty;
        ShowSharedConfirm = false;
        CurrentSystem = await GameSystemService.GetGameSystemEditorAsync(GameSystemId, CurrentUserId);
    }

    private void AddAttributeRow()
    {
        CurrentSystem?.Attributes.Add(new EditableAttributeDefinitionDto
        {
            Name = string.Empty,
            MinValue = 0,
            MaxValue = 20,
            DefaultValue = 10
        });
    }

    private void AddDerivedStatRow()
    {
        CurrentSystem?.DerivedStats.Add(new EditableDerivedStatDefinitionDto
        {
            Name = string.Empty,
            MinValue = 0,
            MaxValue = 100,
            RoundMode = ComputedValueRoundMode.Ceiling,
            DisplayOrder = CurrentSystem.DerivedStats.Count
        });
    }

    private void AddDerivedComponentRow(EditableDerivedStatDefinitionDto derivedStat)
    {
        if (CurrentSystem is null || CurrentSystem.AvailableBaseAttributes.Count == 0)
            return;

        var attribute = CurrentSystem.AvailableBaseAttributes.First();

        derivedStat.Components.Add(new EditableDerivedStatComponentDto
        {
            AttributeDefinitionId = attribute.AttributeDefinitionId,
            AttributeName = attribute.Name,
            Weight = 100
        });
    }

    private string GetBaseAttributeName(Guid attributeDefinitionId)
    {
        if (CurrentSystem is null)
            return string.Empty;

        return CurrentSystem.AvailableBaseAttributes
            .FirstOrDefault(a => a.AttributeDefinitionId == attributeDefinitionId)?.Name ?? string.Empty;
    }

    private void AddTraitRow()
    {
        CurrentSystem?.Traits.Add(new EditableTraitDefinitionDto { Name = string.Empty });
    }

    private void AddTraitOptionRow(EditableTraitDefinitionDto trait)
    {
        trait.Options.Add(new EditableTraitOptionDto { Name = string.Empty });
    }

    private void AddGaugeRow()
    {
        CurrentSystem?.Gauges.Add(new EditableGaugeDefinitionDto
        {
            Name = string.Empty,
            MinValue = 0,
            MaxValue = 10,
            DefaultValue = 10,
            IsHealthGauge = false
        });
    }

    private async Task ApplyChanges()
    {
        if (CurrentSystem is null)
            return;

        try
        {
            Message = string.Empty;

            if (!CurrentSystem.IsLockedToSessionCopy && CurrentSystem.ImpactedSessions.Count > 0)
            {
                ShowSharedConfirm = true;
                return;
            }

            await ApplyChangesInternal(false);
        }
        catch (Exception ex)
        {
            Message = $"{L["Common_Error"]} : {ex.Message}";
        }
    }

    private async Task ConfirmApplyChanges()
    {
        try
        {
            await ApplyChangesInternal(true);
        }
        catch (Exception ex)
        {
            Message = $"{L["Common_Error"]} : {ex.Message}";
        }
    }

    private Task CancelApplyChanges()
    {
        ShowSharedConfirm = false;
        return Task.CompletedTask;
    }

    private async Task ApplyChangesInternal(bool confirmShared)
    {
        if (CurrentSystem is null)
            return;

        ShowSharedConfirm = false;

        var request = new GameSystemApplyChangesRequestDto
        {
            Name = CurrentSystem.Name,
            Description = CurrentSystem.Description,
            TestResolutionMode = CurrentSystem.TestResolutionMode,
            ConfirmSharedSystemChanges = confirmShared,
            Attributes = CurrentSystem.Attributes,
            DerivedStats = CurrentSystem.DerivedStats,
            Traits = CurrentSystem.Traits,
            Gauges = CurrentSystem.Gauges
        };

        await GameSystemService.ApplyGameSystemChangesAsync(GameSystemId, CurrentUserId, request);
        await LoadEditor();

        Message = L["EditGameSystem_ChangesApplied"];
    }

    private async Task UndoLastChange()
    {
        try
        {
            Message = string.Empty;

            await GameSystemService.UndoLastGameSystemChangeAsync(GameSystemId, CurrentUserId);
            await LoadEditor();

            Message = L["EditGameSystem_LastChangeUndone"];
        }
        catch (Exception ex)
        {
            Message = $"{L["Common_Error"]} : {ex.Message}";
        }
    }
}
