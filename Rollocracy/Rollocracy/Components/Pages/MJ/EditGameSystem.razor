@page "/mj/gamesystems/{GameSystemId:guid}"
@rendermode InteractiveServer

@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Extensions.Localization
@using Rollocracy.Domain.GameRules
@using Rollocracy.Localization

@inject Rollocracy.Domain.Interfaces.IGameSystemService GameSystemService
@inject Rollocracy.Domain.Interfaces.ISessionService SessionService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedTexts> L

<h3>@L["EditGameSystem_Title"]</h3>

@if (!IsLoaded)
{
    <p>@L["Common_Loading"]</p>
}
else if (RedirectToHome)
{
    <p>@L["Common_Loading"]</p>
}
else if (CurrentSystem is null)
{
    <p>@L["EditGameSystem_NotFound"]</p>
}
else
{
    <div class="alert alert-info">
        <p>@L["EditGameSystem_FoundationDeliveryNotice"]</p>
        <p>@L["EditGameSystem_DiceDefaultHelp"]</p>
    </div>

    <h4>@L["EditGameSystem_GeneralSection"]</h4>

    <div>
        <label>@L["EditGameSystem_Name"]</label><br />
        <input @bind="CurrentSystem.Name" />
    </div>

    <div>
        <label>@L["EditGameSystem_Description"]</label><br />
        <textarea @bind="CurrentSystem.Description"></textarea>
    </div>

    <div>
        <label>@L["EditGameSystem_ResolutionMode"]</label><br />
        <select @bind="CurrentSystem.TestResolutionMode">
            <option value="@TestResolutionMode.SuccessThreshold">@L["Resolution_SuccessThreshold"]</option>
            <option value="@TestResolutionMode.RollUnderAttribute">@L["Resolution_RollUnderAttribute"]</option>
        </select>
    </div>

    <div>
        <label>@L["EditGameSystem_DefaultTestDiceCount"]</label><br />
        <input type="number" @bind="CurrentSystem.DefaultTestDiceCount" />
    </div>

    <div>
        <label>@L["EditGameSystem_DefaultTestDiceSides"]</label><br />
        <input type="number" @bind="CurrentSystem.DefaultTestDiceSides" />
    </div>

    <div>
        <label>@L["EditGameSystem_CriticalSuccessValue"]</label><br />
        <input type="number" @bind="CurrentSystem.CriticalSuccessValue" />
        <div><small>@L["EditGameSystem_CriticalHelp"]</small></div>
    </div>

    <div>
        <label>@L["EditGameSystem_CriticalFailureValue"]</label><br />
        <input type="number" @bind="CurrentSystem.CriticalFailureValue" />
        <div><small>@L["EditGameSystem_CriticalHelp"]</small></div>
    </div>

    @if (!CurrentSystem.IsLockedToSessionCopy && CurrentSystem.ImpactedSessions.Count > 0)
    {
        <div class="alert alert-warning" style="margin-top:12px;">
            <p><strong>@L["EditGameSystem_SharedWarningTitle"]</strong></p>
            <p>@L["EditGameSystem_SharedWarningText"]</p>
            <ul>
                @foreach (var session in CurrentSystem.ImpactedSessions)
                {
                    <li>@session.SessionName</li>
                }
            </ul>
        </div>
    }

    <div class="alert alert-secondary" style="margin-top:12px;">
        <p>@L["EditGameSystem_ApplyOnlyWhenConfirmed"]</p>
        <p>@L["EditGameSystem_DeletionResponsibilityWarning"]</p>
    </div>

    <hr />

    <h4>@L["EditGameSystem_AttributesSection"]</h4>

    <button @onclick="AddAttributeRow">@L["EditGameSystem_AddAttributeRow"]</button>

    @foreach (var attributeItem in CurrentSystem.Attributes)
    {
        <div style="margin-top:12px; padding:8px; border:1px solid #ccc;">
            @if (attributeItem.IsDeleted)
            {
                <p><strong>@attributeItem.Name</strong> - @L["EditGameSystem_PendingDeletion"]</p>
                <button @onclick="() => attributeItem.IsDeleted = false">@L["EditGameSystem_Restore"]</button>
            }
            else
            {
                <div>
                    <label>@L["Common_Name"]</label><br />
                    <input @bind="attributeItem.Name" />
                </div>
                <div>
                    <label>@L["Common_Min"]</label><br />
                    <input type="number" @bind="attributeItem.MinValue" />
                </div>
                <div>
                    <label>@L["Common_Max"]</label><br />
                    <input type="number" @bind="attributeItem.MaxValue" />
                </div>
                <div>
                    <label>@L["EditGameSystem_DefaultMode"]</label><br />
                    <select @bind="attributeItem.DefaultValueMode">
                        <option value="@BaseValueGenerationMode.Fixed">@L["EditGameSystem_DefaultModeFixed"]</option>
                        <option value="@BaseValueGenerationMode.DiceExpression">@L["EditGameSystem_DefaultModeDice"]</option>
                    </select>
                </div>

                @if (attributeItem.DefaultValueMode == BaseValueGenerationMode.Fixed)
                {
                    <div>
                        <label>@L["EditGameSystem_DefaultFixedValue"]</label><br />
                        <input type="number" @bind="attributeItem.DefaultValue" />
                    </div>
                }
                else
                {
                    <div>
                        <label>@L["EditGameSystem_DefaultFlatBonus"]</label><br />
                        <input type="number" @bind="attributeItem.DefaultValueFlatBonus" />
                    </div>
                    <div>
                        <label>@L["EditGameSystem_DefaultDiceCount"]</label><br />
                        <input type="number" @bind="attributeItem.DefaultValueDiceCount" />
                    </div>
                    <div>
                        <label>@L["EditGameSystem_DefaultDiceSides"]</label><br />
                        <input type="number" @bind="attributeItem.DefaultValueDiceSides" />
                    </div>
                }

                @if (attributeItem.AttributeDefinitionId.HasValue)
                {
                    <button @onclick="() => attributeItem.IsDeleted = true">@L["EditGameSystem_Delete"]</button>
                }
                else
                {
                    <button @onclick="() => CurrentSystem.Attributes.Remove(attributeItem)">@L["EditGameSystem_Delete"]</button>
                }
            }
        </div>
    }

    <hr />

    <h4>@L["EditGameSystem_DerivedStatsSection"]</h4>
    <p>@L["EditGameSystem_DerivedStatsHelp"]</p>

    <button @onclick="AddDerivedStatRow">@L["EditGameSystem_AddDerivedStatRow"]</button>

    @foreach (var derivedStat in CurrentSystem.DerivedStats)
    {
        <div style="margin-top:12px; padding:8px; border:1px solid #ccc;">
            @if (derivedStat.IsDeleted)
            {
                <p><strong>@derivedStat.Name</strong> - @L["EditGameSystem_PendingDeletion"]</p>
                <button @onclick="() => derivedStat.IsDeleted = false">@L["EditGameSystem_Restore"]</button>
            }
            else
            {
                <div>
                    <label>@L["Common_Name"]</label><br />
                    <input @bind="derivedStat.Name" />
                </div>
                <div>
                    <label>@L["Common_Min"]</label><br />
                    <input type="number" @bind="derivedStat.MinValue" />
                </div>
                <div>
                    <label>@L["Common_Max"]</label><br />
                    <input type="number" @bind="derivedStat.MaxValue" />
                </div>
                <div>
                    <label>@L["EditGameSystem_RoundMode"]</label><br />
                    <select @bind="derivedStat.RoundMode">
                        <option value="@ComputedValueRoundMode.Ceiling">@L["EditGameSystem_RoundModeCeiling"]</option>
                        <option value="@ComputedValueRoundMode.Floor">@L["EditGameSystem_RoundModeFloor"]</option>
                        <option value="@ComputedValueRoundMode.Nearest">@L["EditGameSystem_RoundModeNearest"]</option>
                        <option value="@ComputedValueRoundMode.None">@L["EditGameSystem_RoundModeNone"]</option>
                    </select>
                </div>
                <div>
                    <label>@L["EditGameSystem_DisplayOrder"]</label><br />
                    <input type="number" @bind="derivedStat.DisplayOrder" />
                </div>

                <div style="margin-top:8px;">
                    <button @onclick="() => AddDerivedComponentRow(derivedStat)">@L["EditGameSystem_AddDerivedComponentRow"]</button>
                </div>

                <div style="margin-left:20px; margin-top:8px;">
                    @foreach (var component in derivedStat.Components)
                    {
                        <div style="margin-top:8px; border:1px dashed #aaa; padding:8px;">
                            @if (component.IsDeleted)
                            {
                                <span><strong>@GetBaseAttributeName(component.AttributeDefinitionId)</strong> - @L["EditGameSystem_PendingDeletion"]</span>
                                <button @onclick="() => component.IsDeleted = false">@L["EditGameSystem_Restore"]</button>
                            }
                            else
                            {
                                <div>
                                    <label>@L["EditGameSystem_ComponentAttribute"]</label><br />
                                    <select @bind="component.AttributeDefinitionId">
                                        @foreach (var attributeRef in CurrentSystem.AvailableBaseAttributes)
                                        {
                                            <option value="@attributeRef.AttributeDefinitionId">@attributeRef.Name</option>
                                        }
                                    </select>
                                </div>
                                <div>
                                    <label>@L["EditGameSystem_ComponentWeight"]</label><br />
                                    <input type="number" @bind="component.Weight" />
                                </div>
                                <p>@L["EditGameSystem_ComponentWeightHelp"]</p>

                                @if (component.DerivedStatComponentId.HasValue)
                                {
                                    <button @onclick="() => component.IsDeleted = true">@L["EditGameSystem_Delete"]</button>
                                }
                                else
                                {
                                    <button @onclick="() => derivedStat.Components.Remove(component)">@L["EditGameSystem_Delete"]</button>
                                }
                            }
                        </div>
                    }
                </div>

                @if (derivedStat.DerivedStatDefinitionId.HasValue)
                {
                    <button @onclick="() => derivedStat.IsDeleted = true">@L["EditGameSystem_Delete"]</button>
                }
                else
                {
                    <button @onclick="() => CurrentSystem.DerivedStats.Remove(derivedStat)">@L["EditGameSystem_Delete"]</button>
                }
            }
        </div>
    }

    <hr />

    <h4>@L["EditGameSystem_MetricsSection"]</h4>
    <p>@L["EditGameSystem_MetricsHelp"]</p>

    <button @onclick="AddMetricRow">@L["EditGameSystem_AddMetricRow"]</button>

    @foreach (var metric in CurrentSystem.Metrics)
    {
        <div style="margin-top:12px; padding:8px; border:1px solid #ccc;">
            @if (metric.IsDeleted)
            {
                <p><strong>@metric.Name</strong> - @L["EditGameSystem_PendingDeletion"]</p>
                <button @onclick="() => metric.IsDeleted = false">@L["EditGameSystem_Restore"]</button>
            }
            else
            {
                <div>
                    <label>@L["Common_Name"]</label><br />
                    <input @bind="metric.Name" />
                </div>
                <div>
                    <label>@L["EditGameSystem_MetricBaseValue"]</label><br />
                    <input type="number" @bind="metric.BaseValue" />
                </div>
                <div>
                    <label>@L["Common_Min"]</label><br />
                    <input type="number" @bind="metric.MinValue" />
                </div>
                <div>
                    <label>@L["Common_Max"]</label><br />
                    <input type="number" @bind="metric.MaxValue" />
                </div>
                <div>
                    <label>@L["EditGameSystem_RoundMode"]</label><br />
                    <select @bind="metric.RoundMode">
                        <option value="@ComputedValueRoundMode.Ceiling">@L["EditGameSystem_RoundModeCeiling"]</option>
                        <option value="@ComputedValueRoundMode.Floor">@L["EditGameSystem_RoundModeFloor"]</option>
                        <option value="@ComputedValueRoundMode.Nearest">@L["EditGameSystem_RoundModeNearest"]</option>
                        <option value="@ComputedValueRoundMode.None">@L["EditGameSystem_RoundModeNone"]</option>
                    </select>
                </div>
                <div>
                    <label>@L["EditGameSystem_DisplayOrder"]</label><br />
                    <input type="number" @bind="metric.DisplayOrder" />
                </div>

                <div style="margin-top:12px;">
                    <strong>@L["EditGameSystem_MetricFormulaSteps"]</strong>
                    <p>@L["EditGameSystem_MetricFormulaHelp"]</p>

                    @if (metric.Components.Any(x => !x.IsDeleted) && !metric.FormulaSteps.Any(x => !x.IsDeleted))
                    {
                        <p><em>@L["EditGameSystem_MetricLegacyComponentsNotice"]</em></p>
                    }

                    <button @onclick="() => AddMetricFormulaStepRow(metric)">@L["EditGameSystem_AddMetricFormulaStep"]</button>
                </div>

                <div style="margin-left:20px; margin-top:8px;">
                    @foreach (var step in metric.FormulaSteps.OrderBy(x => x.Order).ThenBy(x => x.MetricFormulaStepId))
                    {
                        <div style="margin-top:8px; border:1px dashed #aaa; padding:8px;">
                            @if (step.IsDeleted)
                            {
                                <span><strong>@GetMetricFormulaStepSummary(step)</strong> - @L["EditGameSystem_PendingDeletion"]</span>
                                <button @onclick="() => step.IsDeleted = false">@L["EditGameSystem_Restore"]</button>
                            }
                            else
                            {
                                <div>
                                    <label>@L["EditGameSystem_MetricFormulaOrder"]</label><br />
                                    <input type="number" @bind="step.Order" />
                                </div>
                                <div>
                                    <label>@L["EditGameSystem_MetricFormulaOperation"]</label><br />
                                    <select @bind="step.OperationType">
                                        <option value="@MetricFormulaOperationType.Add">@L["EditGameSystem_MetricFormulaOperation_Add"]</option>
                                        <option value="@MetricFormulaOperationType.Subtract">@L["EditGameSystem_MetricFormulaOperation_Subtract"]</option>
                                        <option value="@MetricFormulaOperationType.Multiply">@L["EditGameSystem_MetricFormulaOperation_Multiply"]</option>
                                        <option value="@MetricFormulaOperationType.Divide">@L["EditGameSystem_MetricFormulaOperation_Divide"]</option>
                                    </select>
                                </div>
                                <div>
                                    <label>@L["EditGameSystem_MetricFormulaSourceType"]</label><br />
                                    <select value="@step.SourceType" @onchange="e => OnMetricFormulaSourceTypeChanged(metric, step, e.Value?.ToString())">
                                        <option value="@MetricFormulaSourceType.BaseAttribute">@L["EditGameSystem_MetricFormulaSourceType_BaseAttribute"]</option>
                                        <option value="@MetricFormulaSourceType.Gauge">@L["EditGameSystem_MetricFormulaSourceType_Gauge"]</option>
                                        <option value="@MetricFormulaSourceType.DerivedStat">@L["EditGameSystem_MetricFormulaSourceType_DerivedStat"]</option>
                                        <option value="@MetricFormulaSourceType.Metric">@L["EditGameSystem_MetricFormulaSourceType_Metric"]</option>
                                        <option value="@MetricFormulaSourceType.Constant">@L["EditGameSystem_MetricFormulaSourceType_Constant"]</option>
                                    </select>
                                </div>

                                @if (step.SourceType == MetricFormulaSourceType.Constant)
                                {
                                    <div>
                                        <label>@L["EditGameSystem_MetricFormulaConstant"]</label><br />
                                        <input type="number" step="0.01" @bind="step.ConstantValue" />
                                    </div>
                                }
                                else
                                {
                                    <div>
                                        <label>@L["EditGameSystem_MetricFormulaSource"]</label><br />
                                        <select @bind="step.SourceId">
                                            @foreach (var option in GetMetricFormulaSourceOptions(metric, step.SourceType))
                                            {
                                                <option value="@option.Id">@option.Name</option>
                                            }
                                        </select>
                                    </div>
                                }

                                @if (step.MetricFormulaStepId.HasValue)
                                {
                                    <button @onclick="() => step.IsDeleted = true">@L["EditGameSystem_Delete"]</button>
                                }
                                else
                                {
                                    <button @onclick="() => metric.FormulaSteps.Remove(step)">@L["EditGameSystem_Delete"]</button>
                                }
                            }
                        </div>
                    }
                </div>

                @if (metric.MetricDefinitionId.HasValue)
                {
                    <button @onclick="() => metric.IsDeleted = true">@L["EditGameSystem_Delete"]</button>
                }
                else
                {
                    <button @onclick="() => CurrentSystem.Metrics.Remove(metric)">@L["EditGameSystem_Delete"]</button>
                }
            }
        </div>
    }

    <hr />

    <h4>@L["EditGameSystem_TraitsSection"]</h4>

    <button @onclick="AddTraitRow">@L["EditGameSystem_AddTraitTypeRow"]</button>

    @foreach (var trait in CurrentSystem.Traits)
    {
        <div style="margin-top:12px; padding:8px; border:1px solid #ccc;">
            @if (trait.IsDeleted)
            {
                <p><strong>@trait.Name</strong> - @L["EditGameSystem_PendingDeletion"]</p>
                <button @onclick="() => trait.IsDeleted = false">@L["EditGameSystem_Restore"]</button>
            }
            else
            {
                <div>
                    <label>@L["EditGameSystem_TraitTypeName"]</label><br />
                    <input @bind="trait.Name" />
                </div>

                <button @onclick="() => AddTraitOptionRow(trait)">@L["EditGameSystem_AddOptionRow"]</button>

                <div style="margin-left:20px; margin-top:8px;">
                    @foreach (var option in trait.Options)
                    {
                        <div style="margin-top:8px; margin-left:20px; padding:8px; border:1px solid #ddd;">
                            @if (option.IsDeleted)
                            {
                                <span><strong>@option.Name</strong> - @L["EditGameSystem_PendingDeletion"]</span>
                                <button @onclick="() => option.IsDeleted = false">@L["EditGameSystem_Restore"]</button>
                            }
                            else
                            {
                                <div>
                                    <input @bind="option.Name" />
                                    @if (option.TraitOptionId.HasValue)
                                    {
                                        <button @onclick="() => option.IsDeleted = true">@L["EditGameSystem_Delete"]</button>
                                    }
                                    else
                                    {
                                        <button @onclick="() => trait.Options.Remove(option)">@L["EditGameSystem_Delete"]</button>
                                    }
                                </div>

                                <div style="margin-top:8px;">
                                    <h5>@L["EditGameSystem_ModifiersSection"]</h5>

                                    @foreach (var mod in option.Modifiers)
                                    {
                                        <div style="margin-left:20px; margin-top:8px;">
                                            <select @bind="mod.OperationType">
                                                <option value="@ModifierOperationType.AddValue">@L["EditGameSystem_ModifierOperation_AddValue"]</option>
                                                <option value="@ModifierOperationType.Grant">@L["EditGameSystem_ModifierOperation_Grant"]</option>
                                                <option value="@ModifierOperationType.Revoke">@L["EditGameSystem_ModifierOperation_Revoke"]</option>
                                            </select>

                                            @if (mod.OperationType == ModifierOperationType.AddValue)
                                            {
                                                <select @bind="mod.TargetType">
                                                    <option value="@ModifierTargetType.BaseAttribute">@L["EditGameSystem_ModifierTarget_Attribute"]</option>
                                                    <option value="@ModifierTargetType.DerivedStat">@L["EditGameSystem_ModifierTarget_DerivedStat"]</option>
                                                    <option value="@ModifierTargetType.Metric">@L["EditGameSystem_ModifierTarget_Metric"]</option>
                                                </select>

                                                @if (mod.TargetType == ModifierTargetType.BaseAttribute)
                                                {
                                                    <select @bind="mod.TargetId">
                                                        @foreach (var target in CurrentSystem.AvailableBaseAttributes)
                                                        {
                                                            <option value="@target.AttributeDefinitionId">@target.Name</option>
                                                        }
                                                    </select>
                                                }
                                                else if (mod.TargetType == ModifierTargetType.DerivedStat)
                                                {
                                                    <select @bind="mod.TargetId">
                                                        @foreach (var target in CurrentSystem.AvailableDerivedStats)
                                                        {
                                                            <option value="@target.DerivedStatDefinitionId">@target.Name</option>
                                                        }
                                                    </select>
                                                }
                                                else if (mod.TargetType == ModifierTargetType.Metric)
                                                {
                                                    <select @bind="mod.TargetId">
                                                        @foreach (var target in CurrentSystem.AvailableMetrics)
                                                        {
                                                            <option value="@target.MetricDefinitionId">@target.Name</option>
                                                        }
                                                    </select>
                                                }

                                                <select @bind="mod.ValueMode">
                                                    <option value="@ModifierValueMode.Fixed">@L["EditGameSystem_ModifierValueMode_Fixed"]</option>
                                                    <option value="@ModifierValueMode.Metric">@L["EditGameSystem_ModifierValueMode_Metric"]</option>
                                                </select>

                                                @if (mod.ValueMode == ModifierValueMode.Metric)
                                                {
                                                    <select @bind="mod.SourceMetricId">
                                                        @foreach (var sourceMetric in CurrentSystem.AvailableMetrics)
                                                        {
                                                            <option value="@sourceMetric.MetricDefinitionId">@sourceMetric.Name</option>
                                                        }
                                                    </select>
                                                }
                                                else
                                                {
                                                    <input type="number" @bind="mod.Value" />
                                                }
                                            }
                                            else
                                            {
                                                <select @bind="mod.TargetType">
                                                    <option value="@ModifierTargetType.Talent">@L["EditGameSystem_ModifierTarget_Talent"]</option>
                                                    <option value="@ModifierTargetType.Item">@L["EditGameSystem_ModifierTarget_Item"]</option>
                                                </select>

                                                @if (mod.TargetType == ModifierTargetType.Talent)
                                                {
                                                    <select @bind="mod.TargetId">
                                                        @foreach (var target in CurrentSystem.Talents.Where(x => !x.IsDeleted && x.TalentDefinitionId.HasValue))
                                                        {
                                                            var targetId = target.TalentDefinitionId.GetValueOrDefault();
                                                            <option value="@targetId">@target.Name</option>
                                                        }
                                                    </select>
                                                }
                                                else
                                                {
                                                    <select @bind="mod.TargetId">
                                                        @foreach (var target in CurrentSystem.Items.Where(x => !x.IsDeleted && x.ItemDefinitionId.HasValue))
                                                        {
                                                            var targetId = target.ItemDefinitionId.GetValueOrDefault();
                                                            <option value="@targetId">@target.Name</option>
                                                        }
                                                    </select>
                                                }
                                            }

                                            <button @onclick="() => option.Modifiers.Remove(mod)">@L["EditGameSystem_Delete"]</button>
                                        </div>
                                    }
                                    <button @onclick="() => AddTraitOptionModifierRow(option)">
                                        @L["EditGameSystem_AddModifierRow"]
                                    </button>
                                </div>
                            }
                        </div>
                    }
                </div>

                @if (trait.TraitDefinitionId.HasValue)
                {
                    <button @onclick="() => trait.IsDeleted = true">@L["EditGameSystem_Delete"]</button>
                }
                else
                {
                    <button @onclick="() => CurrentSystem.Traits.Remove(trait)">@L["EditGameSystem_Delete"]</button>
                }
            }
        </div>
    }

    <hr />

    <h4>@L["EditGameSystem_GaugesSection"]</h4>

    <button @onclick="AddGaugeRow">@L["EditGameSystem_AddGaugeRow"]</button>

    @foreach (var gauge in CurrentSystem.Gauges)
    {
        <div style="margin-top:12px; padding:8px; border:1px solid #ccc;">
            @if (gauge.IsDeleted)
            {
                <p><strong>@gauge.Name</strong> - @L["EditGameSystem_PendingDeletion"]</p>
                <button @onclick="() => gauge.IsDeleted = false">@L["EditGameSystem_Restore"]</button>
            }
            else
            {
                <div>
                    <label>@L["Common_Name"]</label><br />
                    <input @bind="gauge.Name" />
                </div>
                <div>
                    <label>@L["Common_Min"]</label><br />
                    <input type="number" @bind="gauge.MinValue" />
                </div>
                <div>
                    <label>@L["Common_Max"]</label><br />
                    <input type="number" @bind="gauge.MaxValue" />
                </div>
                <div>
                    <label>@L["Common_DefaultValue"]</label><br />
                    <input type="number" @bind="gauge.DefaultValue" />
                </div>
                <div>
                    <label>@L["EditGameSystem_IsHealthGauge"]</label>
                    <input type="checkbox" @bind="gauge.IsHealthGauge" />
                </div>

                @if (gauge.GaugeDefinitionId.HasValue)
                {
                    <button @onclick="() => gauge.IsDeleted = true">@L["EditGameSystem_Delete"]</button>
                }
                else
                {
                    <button @onclick="() => CurrentSystem.Gauges.Remove(gauge)">@L["EditGameSystem_Delete"]</button>
                }
            }
        </div>
    }

    //   SECTION TALENTS

    <h4>@L["EditGameSystem_TalentsSection"]</h4>
    <button @onclick="AddTalentRow">@L["EditGameSystem_AddTalentRow"]</button>

    @foreach (var talent in CurrentSystem.Talents)
    {
        <div style="margin-top:12px; padding:8px; border:1px solid #ccc;">
            @if (talent.IsDeleted)
            {
                <p><strong>@talent.Name</strong> - @L["EditGameSystem_PendingDeletion"]</p>
                <button @onclick="() => talent.IsDeleted = false">@L["EditGameSystem_Restore"]</button>
            }
            else
            {
                <div>
                    <label>@L["Common_Name"]</label><br />
                    <input @bind="talent.Name" />
                </div>
                <div>
                    <label>@L["EditGameSystem_Description"]</label><br />
                    <textarea @bind="talent.Description"></textarea>
                </div>
                <h5>@L["EditGameSystem_ModifiersSection"]</h5>

                @foreach (var mod in talent.Modifiers)
                {
                    <div style="margin-left:20px; margin-top:8px;">
                        <select @bind="mod.TargetType">
                            <option value="@ModifierTargetType.BaseAttribute">@L["EditGameSystem_ModifierTarget_Attribute"]</option>
                            <option value="@ModifierTargetType.DerivedStat">@L["EditGameSystem_ModifierTarget_DerivedStat"]</option>
                            <option value="@ModifierTargetType.Metric">@L["EditGameSystem_ModifierTarget_Metric"]</option>
                        </select>

                        @if (mod.TargetType == ModifierTargetType.BaseAttribute)
                        {
                            <select @bind="mod.TargetId">
                                @foreach (var target in CurrentSystem.AvailableBaseAttributes)
                                {
                                    <option value="@target.AttributeDefinitionId">@target.Name</option>
                                }
                            </select>
                        }
                        else if (mod.TargetType == ModifierTargetType.DerivedStat)
                        {
                            <select @bind="mod.TargetId">
                                @foreach (var target in CurrentSystem.AvailableDerivedStats)
                                {
                                    <option value="@target.DerivedStatDefinitionId">@target.Name</option>
                                }
                            </select>
                        }
                        else if (mod.TargetType == ModifierTargetType.Metric)
                        {
                            <select @bind="mod.TargetId">
                                @foreach (var target in CurrentSystem.AvailableMetrics)
                                {
                                    <option value="@target.MetricDefinitionId">@target.Name</option>
                                }
                            </select>
                        }

                        <select @bind="mod.ValueMode">
                            <option value="@ModifierValueMode.Fixed">@L["EditGameSystem_ModifierValueMode_Fixed"]</option>
                            <option value="@ModifierValueMode.Metric">@L["EditGameSystem_ModifierValueMode_Metric"]</option>
                        </select>

                        @if (mod.ValueMode == ModifierValueMode.Metric)
                        {
                            <select @bind="mod.SourceMetricId">
                                @foreach (var sourceMetric in CurrentSystem.AvailableMetrics)
                                {
                                    <option value="@sourceMetric.MetricDefinitionId">@sourceMetric.Name</option>
                                }
                            </select>
                        }
                        else
                        {
                            <input type="number" @bind="mod.Value" />
                        }

                        <button @onclick="() => talent.Modifiers.Remove(mod)">@L["EditGameSystem_Delete"]</button>
                    </div>
                }

                <button @onclick="() => AddTalentModifierRow(talent)">
                    @L["EditGameSystem_AddModifierRow"]
                </button>
                <div>
                    <label>@L["EditGameSystem_DisplayOrder"]</label><br />
                    <input type="number" @bind="talent.DisplayOrder" />
                </div>

                @if (talent.TalentDefinitionId.HasValue)
                {
                    <button @onclick="() => talent.IsDeleted = true">@L["EditGameSystem_Delete"]</button>
                }
                else
                {
                    <button @onclick="() => CurrentSystem.Talents.Remove(talent)">@L["EditGameSystem_Delete"]</button>
                }
            }
        </div>
    }

    <h4>@L["EditGameSystem_ItemsSection"]</h4>
    <button @onclick="AddItemRow">@L["EditGameSystem_AddItemRow"]</button>

    @foreach (var item in CurrentSystem.Items)
    {
        <div style="margin-top:12px; padding:8px; border:1px solid #ccc;">
            @if (item.IsDeleted)
            {
                <p><strong>@item.Name</strong> - @L["EditGameSystem_PendingDeletion"]</p>
                <button @onclick="() => item.IsDeleted = false">@L["EditGameSystem_Restore"]</button>
            }
            else
            {
                <div>
                    <label>@L["Common_Name"]</label><br />
                    <input @bind="item.Name" />
                </div>
                <div>
                    <label>@L["EditGameSystem_Description"]</label><br />
                    <textarea @bind="item.Description"></textarea>
                </div>
                <h5>@L["EditGameSystem_ModifiersSection"]</h5>

                @foreach (var mod in item.Modifiers)
                {
                    <div style="margin-left:20px; margin-top:8px;">
                        <select @bind="mod.TargetType">
                            <option value="@ModifierTargetType.BaseAttribute">@L["EditGameSystem_ModifierTarget_Attribute"]</option>
                            <option value="@ModifierTargetType.DerivedStat">@L["EditGameSystem_ModifierTarget_DerivedStat"]</option>
                            <option value="@ModifierTargetType.Metric">@L["EditGameSystem_ModifierTarget_Metric"]</option>
                        </select>

                        @if (mod.TargetType == ModifierTargetType.BaseAttribute)
                        {
                            <select @bind="mod.TargetId">
                                @foreach (var target in CurrentSystem.AvailableBaseAttributes)
                                {
                                    <option value="@target.AttributeDefinitionId">@target.Name</option>
                                }
                            </select>
                        }
                        else if (mod.TargetType == ModifierTargetType.DerivedStat)
                        {
                            <select @bind="mod.TargetId">
                                @foreach (var target in CurrentSystem.AvailableDerivedStats)
                                {
                                    <option value="@target.DerivedStatDefinitionId">@target.Name</option>
                                }
                            </select>
                        }
                        else if (mod.TargetType == ModifierTargetType.Metric)
                        {
                            <select @bind="mod.TargetId">
                                @foreach (var target in CurrentSystem.AvailableMetrics)
                                {
                                    <option value="@target.MetricDefinitionId">@target.Name</option>
                                }
                            </select>
                        }

                        <select @bind="mod.ValueMode">
                            <option value="@ModifierValueMode.Fixed">@L["EditGameSystem_ModifierValueMode_Fixed"]</option>
                            <option value="@ModifierValueMode.Metric">@L["EditGameSystem_ModifierValueMode_Metric"]</option>
                        </select>

                        @if (mod.ValueMode == ModifierValueMode.Metric)
                        {
                            <select @bind="mod.SourceMetricId">
                                @foreach (var sourceMetric in CurrentSystem.AvailableMetrics)
                                {
                                    <option value="@sourceMetric.MetricDefinitionId">@sourceMetric.Name</option>
                                }
                            </select>
                        }
                        else
                        {
                            <input type="number" @bind="mod.Value" />
                        }

                        <button @onclick="() => item.Modifiers.Remove(mod)">@L["EditGameSystem_Delete"]</button>
                    </div>
                }

                <button @onclick="() => AddItemModifierRow(item)">
                    @L["EditGameSystem_AddModifierRow"]
                </button>
                <div>
                    <label>@L["EditGameSystem_DisplayOrder"]</label><br />
                    <input type="number" @bind="item.DisplayOrder" />
                </div>

                @if (item.ItemDefinitionId.HasValue)
                {
                    <button @onclick="() => item.IsDeleted = true">@L["EditGameSystem_Delete"]</button>
                }
                else
                {
                    <button @onclick="() => CurrentSystem.Items.Remove(item)">@L["EditGameSystem_Delete"]</button>
                }
            }
        </div>
    }

    <hr />

    <button @onclick="ApplyChanges">@L["EditGameSystem_ApplyChanges"]</button>

    @if (CurrentSystem.CanUndoLastChange)
    {
        <button @onclick="UndoLastChange">@L["EditGameSystem_UndoLastChange"]</button>
    }

    @if (ShowSharedConfirm)
    {
        <div class="alert alert-warning" style="margin-top:12px;">
            <p>@L["EditGameSystem_SharedWarningContinueQuestion"]</p>
            <button @onclick="ConfirmApplyChanges">@L["Common_Yes"]</button>
            <button @onclick="CancelApplyChanges">@L["Common_No"]</button>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Message))
    {
        <p>@Message</p>
    }
}

@code {
    [Parameter] public Guid GameSystemId { get; set; }

    private bool IsLoaded;
    private bool RedirectToHome;
    private Guid CurrentUserId;
    private string Message = string.Empty;
    private bool ShowSharedConfirm;
    private GameSystemEditorDto? CurrentSystem;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        var isAuthenticated = user.Identity?.IsAuthenticated == true;
        var userIdValue = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (!isAuthenticated || string.IsNullOrWhiteSpace(userIdValue))
        {
            RedirectToHome = true;
            IsLoaded = true;
            return;
        }

        CurrentUserId = Guid.Parse(userIdValue);

        var canCreateSessions = await SessionService.CanUserCreateSessionsAsync(CurrentUserId);

        if (!canCreateSessions)
        {
            RedirectToHome = true;
            IsLoaded = true;
            return;
        }

        await LoadEditor();
        IsLoaded = true;
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && RedirectToHome)
        {
            Navigation.NavigateTo("/", forceLoad: true);
        }

        return Task.CompletedTask;
    }

    private async Task LoadEditor()
    {
        Message = string.Empty;
        ShowSharedConfirm = false;
        CurrentSystem = await GameSystemService.GetGameSystemEditorAsync(GameSystemId, CurrentUserId);
    }

    private void AddAttributeRow()
    {
        CurrentSystem?.Attributes.Add(new EditableAttributeDefinitionDto
        {
            Name = string.Empty,
            MinValue = 0,
            MaxValue = 20,
            DefaultValue = 10
        });
    }

    private void AddDerivedStatRow()
    {
        CurrentSystem?.DerivedStats.Add(new EditableDerivedStatDefinitionDto
        {
            Name = string.Empty,
            MinValue = 0,
            MaxValue = 100,
            RoundMode = ComputedValueRoundMode.Ceiling,
            DisplayOrder = CurrentSystem.DerivedStats.Count
        });
    }

    private void AddDerivedComponentRow(EditableDerivedStatDefinitionDto derivedStat)
    {
        if (CurrentSystem is null || CurrentSystem.AvailableBaseAttributes.Count == 0)
            return;

        var attribute = CurrentSystem.AvailableBaseAttributes.First();

        derivedStat.Components.Add(new EditableDerivedStatComponentDto
        {
            AttributeDefinitionId = attribute.AttributeDefinitionId,
            AttributeName = attribute.Name,
            Weight = 100
        });
    }

    private string GetBaseAttributeName(Guid attributeDefinitionId)
    {
        if (CurrentSystem is null)
            return string.Empty;

        return CurrentSystem.AvailableBaseAttributes
            .FirstOrDefault(a => a.AttributeDefinitionId == attributeDefinitionId)?.Name ?? string.Empty;
    }

    private void AddMetricRow()
    {
        CurrentSystem?.Metrics.Add(new EditableMetricDefinitionDto
        {
            Name = string.Empty,
            TemporaryKey = Guid.NewGuid().ToString("N"),
            BaseValue = 0,
            MinValue = 0,
            MaxValue = 100,
            RoundMode = ComputedValueRoundMode.Ceiling,
            DisplayOrder = CurrentSystem.Metrics.Count
        });
    }

    private void AddMetricFormulaStepRow(EditableMetricDefinitionDto metric)
    {
        var firstAttribute = CurrentSystem?.AvailableBaseAttributes.FirstOrDefault();

        metric.FormulaSteps.Add(new EditableMetricFormulaStepDto
        {
            Order = metric.FormulaSteps.Count,
            OperationType = MetricFormulaOperationType.Add,
            SourceType = firstAttribute is not null ? MetricFormulaSourceType.BaseAttribute : MetricFormulaSourceType.Constant,
            SourceId = firstAttribute?.AttributeDefinitionId,
            ConstantValue = 0m
        });
    }

    private IReadOnlyList<MetricFormulaSourceOption> GetMetricFormulaSourceOptions(
        EditableMetricDefinitionDto metric,
        MetricFormulaSourceType sourceType)
    {
        if (CurrentSystem is null)
            return Array.Empty<MetricFormulaSourceOption>();

        return sourceType switch
        {
            MetricFormulaSourceType.BaseAttribute => CurrentSystem.AvailableBaseAttributes
                .Select(x => new MetricFormulaSourceOption(x.AttributeDefinitionId, x.Name))
                .ToList(),
            MetricFormulaSourceType.Gauge => CurrentSystem.Gauges
                .Where(x => !x.IsDeleted && x.GaugeDefinitionId.HasValue)
                .Select(x => new MetricFormulaSourceOption(x.GaugeDefinitionId!.Value, x.Name))
                .ToList(),
            MetricFormulaSourceType.DerivedStat => CurrentSystem.DerivedStats
                .Where(x => !x.IsDeleted && x.DerivedStatDefinitionId.HasValue)
                .Select(x => new MetricFormulaSourceOption(x.DerivedStatDefinitionId!.Value, x.Name))
                .ToList(),
            MetricFormulaSourceType.Metric => CurrentSystem.Metrics
                .Where(x => !x.IsDeleted && x.MetricDefinitionId.HasValue && x.MetricDefinitionId != metric.MetricDefinitionId)
                .Select(x => new MetricFormulaSourceOption(x.MetricDefinitionId!.Value, x.Name))
                .ToList(),
            _ => Array.Empty<MetricFormulaSourceOption>()
        };
    }

    private void OnMetricFormulaSourceTypeChanged(
        EditableMetricDefinitionDto metric,
        EditableMetricFormulaStepDto step,
        string? rawValue)
    {
        if (!Enum.TryParse<MetricFormulaSourceType>(rawValue, out var sourceType))
            return;

        step.SourceType = sourceType;

        if (sourceType == MetricFormulaSourceType.Constant)
        {
            step.SourceId = null;
            return;
        }

        var firstOption = GetMetricFormulaSourceOptions(metric, sourceType).FirstOrDefault();
        step.SourceId = firstOption?.Id;
    }

    private string GetMetricFormulaStepSummary(EditableMetricFormulaStepDto step)
    {
        var operation = step.OperationType switch
        {
            MetricFormulaOperationType.Add => L["EditGameSystem_MetricFormulaOperation_Add"].Value,
            MetricFormulaOperationType.Subtract => L["EditGameSystem_MetricFormulaOperation_Subtract"].Value,
            MetricFormulaOperationType.Multiply => L["EditGameSystem_MetricFormulaOperation_Multiply"].Value,
            MetricFormulaOperationType.Divide => L["EditGameSystem_MetricFormulaOperation_Divide"].Value,
            _ => string.Empty
        };

        var source = step.SourceType == MetricFormulaSourceType.Constant
            ? step.ConstantValue.ToString()
            : GetMetricFormulaSourceLabel(step);

        return $"{operation} {source}";
    }

    private string GetMetricFormulaSourceLabel(EditableMetricFormulaStepDto step)
    {
        if (CurrentSystem is null || !step.SourceId.HasValue)
            return step.SourceName;

        return step.SourceType switch
        {
            MetricFormulaSourceType.BaseAttribute => CurrentSystem.AvailableBaseAttributes.FirstOrDefault(x => x.AttributeDefinitionId == step.SourceId.Value)?.Name ?? step.SourceName,
            MetricFormulaSourceType.Gauge => CurrentSystem.Gauges.FirstOrDefault(x => x.GaugeDefinitionId == step.SourceId.Value)?.Name ?? step.SourceName,
            MetricFormulaSourceType.DerivedStat => CurrentSystem.DerivedStats.FirstOrDefault(x => x.DerivedStatDefinitionId == step.SourceId.Value)?.Name ?? step.SourceName,
            MetricFormulaSourceType.Metric => CurrentSystem.Metrics.FirstOrDefault(x => x.MetricDefinitionId == step.SourceId.Value)?.Name ?? step.SourceName,
            MetricFormulaSourceType.Constant => step.ConstantValue.ToString(),
            _ => step.SourceName
        };
    }

    private void PrepareMetricsForSave(List<EditableMetricDefinitionDto> metrics)
    {
        foreach (var metric in metrics.Where(x => !x.IsDeleted))
        {
            var activeSteps = metric.FormulaSteps
                .Where(x => !x.IsDeleted)
                .OrderBy(x => x.Order)
                .ThenBy(x => x.MetricFormulaStepId)
                .ToList();

            for (var index = 0; index < activeSteps.Count; index++)
            {
                activeSteps[index].Order = index;
            }

            if (activeSteps.Count > 0)
            {
                // Dès qu'une formule existe, on cesse de renvoyer les anciens composants pondérés.
                metric.Components.Clear();
            }
        }
    }

    private sealed record MetricFormulaSourceOption(Guid Id, string Name);

    private void AddTraitRow()
    {
        CurrentSystem?.Traits.Add(new EditableTraitDefinitionDto { Name = string.Empty });
    }

    private void AddTraitOptionRow(EditableTraitDefinitionDto trait)
    {
        trait.Options.Add(new EditableTraitOptionDto { Name = string.Empty });
    }

    private void AddTraitOptionModifierRow(EditableTraitOptionDto option)
    {
        var firstAttribute = CurrentSystem?.AvailableBaseAttributes.FirstOrDefault();

        option.Modifiers.Add(new EditableModifierDefinitionDto
        {
            OperationType = ModifierOperationType.AddValue,
            TargetType = ModifierTargetType.BaseAttribute,
            TargetId = firstAttribute?.AttributeDefinitionId ?? Guid.Empty,
            Value = 0,
            ValueMode = ModifierValueMode.Fixed,
            SourceMetricId = CurrentSystem?.AvailableMetrics.FirstOrDefault()?.MetricDefinitionId
        });
    }

    private void AddGaugeRow()
    {
        CurrentSystem?.Gauges.Add(new EditableGaugeDefinitionDto
        {
            Name = string.Empty,
            MinValue = 0,
            MaxValue = 10,
            DefaultValue = 10,
            IsHealthGauge = false
        });
    }

    private async Task ApplyChanges()
    {
        if (CurrentSystem is null)
            return;

        try
        {
            Message = string.Empty;

            if (!CurrentSystem.IsLockedToSessionCopy && CurrentSystem.ImpactedSessions.Count > 0)
            {
                ShowSharedConfirm = true;
                return;
            }

            await ApplyChangesInternal(false);
        }
        catch (Exception ex)
        {
            Message = $"{L["Common_Error"]} : {ex.Message}";
        }
    }

    private async Task ConfirmApplyChanges()
    {
        try
        {
            await ApplyChangesInternal(true);
        }
        catch (Exception ex)
        {
            Message = $"{L["Common_Error"]} : {ex.Message}";
        }
    }

    private Task CancelApplyChanges()
    {
        ShowSharedConfirm = false;
        return Task.CompletedTask;
    }

    private async Task ApplyChangesInternal(bool confirmShared)
    {

        if (CurrentSystem is null)
            return;

        ShowSharedConfirm = false;

        PrepareMetricsForSave(CurrentSystem.Metrics);

        var request = new GameSystemApplyChangesRequestDto
        {
            Name = CurrentSystem.Name,
            Description = CurrentSystem.Description,
            TestResolutionMode = CurrentSystem.TestResolutionMode,
            DefaultTestDiceCount = CurrentSystem.DefaultTestDiceCount,
            DefaultTestDiceSides = CurrentSystem.DefaultTestDiceSides,
            CriticalSuccessValue = CurrentSystem.CriticalSuccessValue,
            CriticalFailureValue = CurrentSystem.CriticalFailureValue,
            ConfirmSharedSystemChanges = confirmShared,
            Attributes = CurrentSystem.Attributes,
            DerivedStats = CurrentSystem.DerivedStats,
            Metrics = CurrentSystem.Metrics,
            Traits = CurrentSystem.Traits,
            Gauges = CurrentSystem.Gauges,
            Talents = CurrentSystem.Talents,
            Items = CurrentSystem.Items
        };

        await GameSystemService.ApplyGameSystemChangesAsync(GameSystemId, CurrentUserId, request);
        await LoadEditor();

        Message = L["EditGameSystem_ChangesApplied"];
    }

    private async Task UndoLastChange()
    {
        try
        {
            Message = string.Empty;

            await GameSystemService.UndoLastGameSystemChangeAsync(GameSystemId, CurrentUserId);
            await LoadEditor();

            Message = L["EditGameSystem_LastChangeUndone"];
        }
        catch (Exception ex)
        {
            Message = $"{L["Common_Error"]} : {ex.Message}";
        }
    }

    private void AddTalentRow()
    {
        CurrentSystem?.Talents.Add(new EditableTalentDefinitionDto
        {
            Name = string.Empty,
            DisplayOrder = (CurrentSystem?.Talents.Count ?? 0) + 1
        });
    }

    private void AddItemRow()
    {
        CurrentSystem?.Items.Add(new EditableItemDefinitionDto
        {
            Name = string.Empty,
            DisplayOrder = (CurrentSystem?.Items.Count ?? 0) + 1
        });
    }

    private void AddTalentModifierRow(EditableTalentDefinitionDto talent)
    {
        var firstAttribute = CurrentSystem?.AvailableBaseAttributes.FirstOrDefault();

        talent.Modifiers.Add(new EditableModifierDefinitionDto
        {
            TargetType = ModifierTargetType.BaseAttribute,
            TargetId = firstAttribute?.AttributeDefinitionId ?? Guid.Empty,
            Value = 0,
            ValueMode = ModifierValueMode.Fixed,
            SourceMetricId = CurrentSystem?.AvailableMetrics.FirstOrDefault()?.MetricDefinitionId
        });
    }

    private void AddItemModifierRow(EditableItemDefinitionDto item)
    {
        var firstAttribute = CurrentSystem?.AvailableBaseAttributes.FirstOrDefault();

        item.Modifiers.Add(new EditableModifierDefinitionDto
        {
            TargetType = ModifierTargetType.BaseAttribute,
            TargetId = firstAttribute?.AttributeDefinitionId ?? Guid.Empty,
            Value = 0,
            ValueMode = ModifierValueMode.Fixed,
            SourceMetricId = CurrentSystem?.AvailableMetrics.FirstOrDefault()?.MetricDefinitionId
        });
    }
}
