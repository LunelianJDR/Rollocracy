@page "/mj/gamesystems/{GameSystemId:guid}"
@rendermode InteractiveServer

@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Extensions.Localization
@using Rollocracy.Domain.Entities
@using Rollocracy.Domain.GameRules
@using Rollocracy.Localization

@inject Rollocracy.Domain.Interfaces.IGameSystemService GameSystemService
@inject Rollocracy.Domain.Interfaces.ISessionService SessionService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedTexts> L

<h3>@L["EditGameSystem_Title"]</h3>

@if (!IsLoaded)
{
    <p>@L["Common_Loading"]</p>
}
else if (RedirectToHome)
{
    <p>@L["Common_Loading"]</p>
}
else if (CurrentSystem is null)
{
    <p>@L["EditGameSystem_NotFound"]</p>
}
else
{
    <h4>@L["EditGameSystem_GeneralSection"]</h4>

    <div>
        <label>@L["EditGameSystem_Name"]</label><br />
        <input @bind="CurrentSystemName" />
    </div>

    <div>
        <label>@L["EditGameSystem_Description"]</label><br />
        <textarea @bind="CurrentSystemDescription"></textarea>
    </div>

    <div>
        <label>@L["EditGameSystem_ResolutionMode"]</label><br />
        <select @bind="CurrentResolutionMode">
            <option value="@TestResolutionMode.SuccessThreshold">@L["Resolution_SuccessThreshold"]</option>
            <option value="@TestResolutionMode.RollUnderAttribute">@L["Resolution_RollUnderAttribute"]</option>
        </select>
    </div>

    <button @onclick="SaveGeneralInfo">@L["Common_Save"]</button>

    <hr />

    <h4>@L["EditGameSystem_AttributesSection"]</h4>

    <div>
        <label>@L["Common_Name"]</label><br />
        <input @bind="NewAttributeName" />
    </div>

    <div>
        <label>@L["Common_Min"]</label><br />
        <input type="number" @bind="NewAttributeMin" />
    </div>

    <div>
        <label>@L["Common_Max"]</label><br />
        <input type="number" @bind="NewAttributeMax" />
    </div>

    <div>
        <label>@L["Common_DefaultValue"]</label><br />
        <input type="number" @bind="NewAttributeDefault" />
    </div>

    <button @onclick="AddAttribute">@L["EditGameSystem_AddAttribute"]</button>

    @if (AttributeDefinitions.Count == 0)
    {
        <p>@L["EditGameSystem_NoAttributes"]</p>
    }
    else
    {
        <ul>
            @foreach (var attributeDefinition in AttributeDefinitions)
            {
                <li>@attributeDefinition.Name (@L["Common_Min"] : @attributeDefinition.MinValue, @L["Common_Max"] : @attributeDefinition.MaxValue, @L["Common_DefaultValue"] : @attributeDefinition.DefaultValue)</li>
            }
        </ul>
    }

    <hr />

    <h4>@L["EditGameSystem_TraitsSection"]</h4>

    <div>
        <label>@L["EditGameSystem_TraitTypeName"]</label><br />
        <input @bind="NewTraitDefinitionName" />
    </div>

    <button @onclick="AddTraitDefinition">@L["EditGameSystem_AddTraitType"]</button>

    @if (TraitDefinitions.Count == 0)
    {
        <p>@L["EditGameSystem_NoTraitTypes"]</p>
    }
    else
    {
        @foreach (var traitDefinition in TraitDefinitions)
        {
            <div>
                <p><strong>@traitDefinition.Name</strong></p>

                <input @bind="NewTraitOptionNames[traitDefinition.Id]" />
                <button @onclick="() => AddTraitOption(traitDefinition.Id)">@L["EditGameSystem_AddOption"]</button>

                @if (TraitOptionsByDefinition.ContainsKey(traitDefinition.Id) && TraitOptionsByDefinition[traitDefinition.Id].Count > 0)
                {
                    <ul>
                        @foreach (var option in TraitOptionsByDefinition[traitDefinition.Id])
                        {
                            <li>@option.Name</li>
                        }
                    </ul>
                }
                else
                {
                    <p>@L["EditGameSystem_NoOptionsForTrait"]</p>
                }
            </div>
        }
    }

    <hr />

    <h4>@L["EditGameSystem_GaugesSection"]</h4>

    <div>
        <label>@L["Common_Name"]</label><br />
        <input @bind="NewGaugeName" />
    </div>

    <div>
        <label>@L["Common_Min"]</label><br />
        <input type="number" @bind="NewGaugeMin" />
    </div>

    <div>
        <label>@L["Common_Max"]</label><br />
        <input type="number" @bind="NewGaugeMax" />
    </div>

    <div>
        <label>@L["Common_DefaultValue"]</label><br />
        <input type="number" @bind="NewGaugeDefault" />
    </div>

    <div>
        <label>@L["EditGameSystem_IsHealthGauge"]</label>
        <input type="checkbox" @bind="NewGaugeIsHealthGauge" />
    </div>

    <button @onclick="AddGauge">@L["EditGameSystem_AddGauge"]</button>

    @if (GaugeDefinitions.Count == 0)
    {
        <p>@L["EditGameSystem_NoGauges"]</p>
    }
    else
    {
        <ul>
            @foreach (var gauge in GaugeDefinitions)
            {
                <li>@gauge.Name (@L["Common_Min"] : @gauge.MinValue, @L["Common_Max"] : @gauge.MaxValue, @L["Common_DefaultValue"] : @gauge.DefaultValue, @L["EditGameSystem_Lethal"] : @(gauge.IsHealthGauge? L["Common_Yes"] : L["Common_No"]))</li>
            }
        </ul>
    }

    @if (!string.IsNullOrWhiteSpace(Message))
    {
        <p>@Message</p>
    }
}

@code {
    [Parameter] public Guid GameSystemId { get; set; }

    private bool IsLoaded;
    private bool RedirectToHome;
    private Guid CurrentUserId;
    private string Message = string.Empty;

    private GameSystem? CurrentSystem;
    private string CurrentSystemName = string.Empty;
    private string CurrentSystemDescription = string.Empty;
    private TestResolutionMode CurrentResolutionMode;

    private string NewAttributeName = string.Empty;
    private int NewAttributeMin = 0;
    private int NewAttributeMax = 20;
    private int NewAttributeDefault = 10;

    private string NewTraitDefinitionName = string.Empty;

    private string NewGaugeName = string.Empty;
    private int NewGaugeMin = 0;
    private int NewGaugeMax = 10;
    private int NewGaugeDefault = 10;
    private bool NewGaugeIsHealthGauge = false;

    private List<AttributeDefinition> AttributeDefinitions = new();
    private List<TraitDefinition> TraitDefinitions = new();
    private List<GaugeDefinition> GaugeDefinitions = new();
    private Dictionary<Guid, List<TraitOption>> TraitOptionsByDefinition = new();
    private Dictionary<Guid, string> NewTraitOptionNames = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        var isAuthenticated = user.Identity?.IsAuthenticated == true;
        var userIdValue = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (!isAuthenticated || string.IsNullOrWhiteSpace(userIdValue))
        {
            RedirectToHome = true;
            IsLoaded = true;
            return;
        }

        CurrentUserId = Guid.Parse(userIdValue);

        var canCreateSessions = await SessionService.CanUserCreateSessionsAsync(CurrentUserId);

        if (!canCreateSessions)
        {
            RedirectToHome = true;
            IsLoaded = true;
            return;
        }

        await LoadGameSystem();
        IsLoaded = true;
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && RedirectToHome)
        {
            Navigation.NavigateTo("/", forceLoad: true);
        }

        return Task.CompletedTask;
    }

    private async Task LoadGameSystem()
    {
        Message = string.Empty;

        CurrentSystem = await GameSystemService.GetGameSystemByIdAsync(GameSystemId, CurrentUserId);

        if (CurrentSystem is null)
            return;

        CurrentSystemName = CurrentSystem.Name;
        CurrentSystemDescription = CurrentSystem.Description;
        CurrentResolutionMode = CurrentSystem.TestResolutionMode;

        AttributeDefinitions = await GameSystemService.GetAttributeDefinitionsAsync(GameSystemId, CurrentUserId);
        TraitDefinitions = await GameSystemService.GetTraitDefinitionsAsync(GameSystemId, CurrentUserId);
        GaugeDefinitions = await GameSystemService.GetGaugeDefinitionsAsync(GameSystemId, CurrentUserId);

        TraitOptionsByDefinition.Clear();
        NewTraitOptionNames.Clear();

        foreach (var traitDefinition in TraitDefinitions)
        {
            TraitOptionsByDefinition[traitDefinition.Id] =
                await GameSystemService.GetTraitOptionsAsync(traitDefinition.Id, CurrentUserId);

            NewTraitOptionNames[traitDefinition.Id] = string.Empty;
        }
    }

    private async Task SaveGeneralInfo()
    {
        try
        {
            await GameSystemService.UpdateGameSystemAsync(
                GameSystemId,
                CurrentUserId,
                CurrentSystemName,
                CurrentSystemDescription,
                CurrentResolutionMode);

            await LoadGameSystem();
            Message = L["EditGameSystem_GeneralSaved"];
        }
        catch (Exception ex)
        {
            Message = $"{L["Common_Error"]} : {ex.Message}";
        }
    }

    private async Task AddAttribute()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(NewAttributeName))
            {
                Message = L["EditGameSystem_AttributeNameRequired"];
                return;
            }

            await GameSystemService.AddAttributeDefinitionAsync(
                GameSystemId,
                CurrentUserId,
                NewAttributeName,
                NewAttributeMin,
                NewAttributeMax,
                NewAttributeDefault);

            NewAttributeName = string.Empty;
            NewAttributeMin = 0;
            NewAttributeMax = 20;
            NewAttributeDefault = 10;

            await LoadGameSystem();
            Message = L["EditGameSystem_AttributeAdded"];
        }
        catch (Exception ex)
        {
            Message = $"{L["Common_Error"]} : {ex.Message}";
        }
    }

    private async Task AddTraitDefinition()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(NewTraitDefinitionName))
            {
                Message = L["EditGameSystem_TraitTypeNameRequired"];
                return;
            }

            await GameSystemService.AddTraitDefinitionAsync(
                GameSystemId,
                CurrentUserId,
                NewTraitDefinitionName);

            NewTraitDefinitionName = string.Empty;

            await LoadGameSystem();
            Message = L["EditGameSystem_TraitTypeAdded"];
        }
        catch (Exception ex)
        {
            Message = $"{L["Common_Error"]} : {ex.Message}";
        }
    }

    private async Task AddTraitOption(Guid traitDefinitionId)
    {
        try
        {
            if (!NewTraitOptionNames.ContainsKey(traitDefinitionId))
                return;

            var optionName = NewTraitOptionNames[traitDefinitionId];

            if (string.IsNullOrWhiteSpace(optionName))
            {
                Message = L["EditGameSystem_OptionNameRequired"];
                return;
            }

            await GameSystemService.AddTraitOptionAsync(
                traitDefinitionId,
                CurrentUserId,
                optionName);

            NewTraitOptionNames[traitDefinitionId] = string.Empty;

            await LoadGameSystem();
            Message = L["EditGameSystem_OptionAdded"];
        }
        catch (Exception ex)
        {
            Message = $"{L["Common_Error"]} : {ex.Message}";
        }
    }

    private async Task AddGauge()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(NewGaugeName))
            {
                Message = L["EditGameSystem_GaugeNameRequired"];
                return;
            }

            await GameSystemService.AddGaugeDefinitionAsync(
                GameSystemId,
                CurrentUserId,
                NewGaugeName,
                NewGaugeMin,
                NewGaugeMax,
                NewGaugeDefault,
                NewGaugeIsHealthGauge);

            NewGaugeName = string.Empty;
            NewGaugeMin = 0;
            NewGaugeMax = 10;
            NewGaugeDefault = 10;
            NewGaugeIsHealthGauge = false;

            await LoadGameSystem();
            Message = L["EditGameSystem_GaugeAdded"];
        }
        catch (Exception ex)
        {
            Message = $"{L["Common_Error"]} : {ex.Message}";
        }
    }
}