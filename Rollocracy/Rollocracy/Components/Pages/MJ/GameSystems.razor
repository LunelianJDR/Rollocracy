@page "/mj/gamesystems"
@rendermode InteractiveServer

@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Extensions.Localization
@using Rollocracy.Domain.Entities
@using Rollocracy.Domain.GameRules
@using Rollocracy.Localization

@inject Rollocracy.Domain.Interfaces.IGameSystemService GameSystemService
@inject Rollocracy.Domain.Interfaces.ISessionService SessionService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedTexts> L

<h3>@L["GameSystems_Title"]</h3>

@if (!IsLoaded)
{
    <p>@L["Common_Loading"]</p>
}
else if (RedirectToHome)
{
    <p>@L["Common_Loading"]</p>
}
else
{
    <div>
        <label>@L["GameSystems_NewName"]</label><br />
        <input @bind="NewSystemName" />
    </div>

    <div>
        <label>@L["GameSystems_NewDescription"]</label><br />
        <textarea @bind="NewSystemDescription"></textarea>
    </div>

    <div>
        <label>@L["GameSystems_ResolutionMode"]</label><br />
        <select @bind="NewSystemResolutionMode">
            <option value="@TestResolutionMode.SuccessThreshold">@L["Resolution_SuccessThreshold"]</option>
            <option value="@TestResolutionMode.RollUnderAttribute">@L["Resolution_RollUnderAttribute"]</option>
        </select>
    </div>

    <button @onclick="CreateGameSystem">@L["GameSystems_Create"]</button>

    @if (!string.IsNullOrWhiteSpace(Message))
    {
        <p>@Message</p>
    }

    <hr />

    @if (OwnedGameSystems.Count == 0)
    {
        <p>@L["GameSystems_None"]</p>
    }
    else
    {
        @foreach (var system in OwnedGameSystems)
        {
            <div>
                <p><strong>@L["GameSystems_Name"] :</strong> @system.Name</p>
                <p><strong>@L["GameSystems_Description"] :</strong> @system.Description</p>
                <p><strong>@L["GameSystems_Mode"] :</strong> @GetResolutionLabel(system.TestResolutionMode)</p>
                <button @onclick="() => EditSystem(system.Id)">@L["GameSystems_Edit"]</button>
            </div>
            <hr />
        }
    }
}

@code {
    private bool IsLoaded;
    private bool RedirectToHome;
    private Guid CurrentUserId;
    private string Message = string.Empty;
    private string NewSystemName = string.Empty;
    private string NewSystemDescription = string.Empty;
    private TestResolutionMode NewSystemResolutionMode = TestResolutionMode.SuccessThreshold;
    private List<GameSystem> OwnedGameSystems = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        var isAuthenticated = user.Identity?.IsAuthenticated == true;
        var userIdValue = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (!isAuthenticated || string.IsNullOrWhiteSpace(userIdValue))
        {
            RedirectToHome = true;
            IsLoaded = true;
            return;
        }

        CurrentUserId = Guid.Parse(userIdValue);

        var canCreateSessions = await SessionService.CanUserCreateSessionsAsync(CurrentUserId);

        if (!canCreateSessions)
        {
            RedirectToHome = true;
            IsLoaded = true;
            return;
        }

        await LoadGameSystems();
        IsLoaded = true;
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && RedirectToHome)
        {
            Navigation.NavigateTo("/", forceLoad: true);
        }

        return Task.CompletedTask;
    }

    private async Task LoadGameSystems()
    {
        OwnedGameSystems = await GameSystemService.GetGameSystemsByOwnerAsync(CurrentUserId);
    }

    private async Task CreateGameSystem()
    {
        try
        {
            Message = string.Empty;

            if (string.IsNullOrWhiteSpace(NewSystemName))
            {
                Message = L["GameSystems_NameRequired"];
                return;
            }

            var system = await GameSystemService.CreateGameSystemAsync(
                CurrentUserId,
                NewSystemName,
                NewSystemDescription,
                NewSystemResolutionMode);

            NewSystemName = string.Empty;
            NewSystemDescription = string.Empty;
            NewSystemResolutionMode = TestResolutionMode.SuccessThreshold;

            await LoadGameSystems();
            Navigation.NavigateTo($"/mj/gamesystems/{system.Id}");
        }
        catch (Exception ex)
        {
            Message = $"{L["Common_Error"]} : {ex.Message}";
        }
    }

    private void EditSystem(Guid systemId)
    {
        Navigation.NavigateTo($"/mj/gamesystems/{systemId}");
    }

    private string GetResolutionLabel(TestResolutionMode mode)
    {
        return mode switch
        {
            TestResolutionMode.SuccessThreshold => L["Resolution_SuccessThreshold"],
            TestResolutionMode.RollUnderAttribute => L["Resolution_RollUnderAttribute"],
            _ => mode.ToString()
        };
    }
}