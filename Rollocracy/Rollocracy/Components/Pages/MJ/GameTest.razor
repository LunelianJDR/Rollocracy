    private int GetSuccessDifference(GameMasterGameTestResultLineDto resultLine)
    {
        if (!resultLine.HasRolled)
            return 0;

        if (ActiveTest is null)
            return 0;

        if (ActiveTest.ResolutionMode == TestResolutionMode.SuccessThreshold)
        {
            return resultLine.FinalValue - (ActiveTest.SuccessThreshold ?? 0);
        }

        return resultLine.FinalValue;
    }

