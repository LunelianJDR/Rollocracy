    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        var isAuthenticated = user.Identity?.IsAuthenticated == true;
        var userIdValue = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (!isAuthenticated || string.IsNullOrWhiteSpace(userIdValue))
        {
            RedirectToHome = true;
            IsLoaded = true;
            return;
        }

        CurrentUserId = Guid.Parse(userIdValue);

        await LoadPageData();

        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/sessionhub"))
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On("TestChanged", async () =>
        {
            await InvokeAsync(async () =>
            {
                await LoadActiveTest();
                StateHasChanged();
            });
        });

        await hubConnection.StartAsync();
        await hubConnection.SendAsync("JoinSessionGroup", SessionId.ToString());

        IsLoaded = true;
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && RedirectToHome)
        {
            Navigation.NavigateTo("/", forceLoad: true);
        }

        return Task.CompletedTask;
    }

    private async Task LoadPageData()
    {
        CurrentSession = await SessionService.GetSessionByIdAsync(SessionId);

        if (CurrentSession?.GameSystemId is not Guid gameSystemId)
        {
            await LoadCharacterSummariesAsync();
            await LoadActiveTest();
            return;
        }

        AssignedGameSystem = await GameSystemService.GetGameSystemByIdAsync(gameSystemId, CurrentUserId);

        if (AssignedGameSystem is null)
        {
            await LoadCharacterSummariesAsync();
            await LoadActiveTest();
            return;
        }

        AvailableAttributes = await GameSystemService.GetAttributeDefinitionsAsync(AssignedGameSystem.Id, CurrentUserId);
        AvailableTraitDefinitions = await GameSystemService.GetTraitDefinitionsAsync(AssignedGameSystem.Id, CurrentUserId);
        AvailableGaugeDefinitions = await GameSystemService.GetGaugeDefinitionsAsync(AssignedGameSystem.Id, CurrentUserId);
        AvailableMetrics = await GameSystemService.GetMetricDefinitionsAsync(AssignedGameSystem.Id, CurrentUserId);
        SessionGauges = await SessionService.GetSessionGaugesAsync(SessionId, CurrentUserId);

        var editor = await GameSystemService.GetGameSystemEditorAsync(AssignedGameSystem.Id, CurrentUserId);
        if (editor is not null)
        {
            AvailableDerivedStats = editor.DerivedStats;
            AvailableTalents = editor.Talents;
            AvailableItems = editor.Items;
        }

        foreach (var traitDefinition in AvailableTraitDefinitions)
        {
            TraitOptionsByDefinition[traitDefinition.Id] = await GameSystemService.GetTraitOptionsAsync(traitDefinition.Id, CurrentUserId);
        }

        NewDiceCount = AssignedGameSystem.DefaultTestDiceCount;
        NewDiceSides = AssignedGameSystem.DefaultTestDiceSides;
        UseSystemDefaultDice = true;

        RebuildDifficultyScale();
        EnsureSuccessThresholdDefault();
        OnTestTargetKindChanged();

        await LoadCharacterSummariesAsync();
        await LoadActiveTest();
    }

    private async Task LoadActiveTest()
    {
        ActiveTest = await GameTestService.GetActiveGameTestForSessionAsync(SessionId);
    }

    private async Task LoadCharacterSummariesAsync()
    {
        var characters = await CharacterService.GetSessionCharacterSummariesAsync(
            SessionId,
            includeOffline: true,
            includeDead: true,
            includeNpcs: true);

        CharacterSummariesById = characters.ToDictionary(x => x.CharacterId, x => x);
    }

    private void OnTestTargetKindChanged()
    {
        SelectedAttributeId = NewTargetKind switch
        {
            GameTestTargetKind.BaseAttribute => AvailableAttributes.FirstOrDefault()?.Id.ToString() ?? string.Empty,
            GameTestTargetKind.DerivedStat => AvailableDerivedStats.FirstOrDefault()?.DerivedStatDefinitionId?.ToString() ?? string.Empty,
            _ => string.Empty
        };
    }

    private Task OnDiceModeChanged()
    {
        EnsureSuccessThresholdDefault();
        return Task.CompletedTask;
    }

    private Task OnCustomDiceChanged()
    {
        if (!UseSystemDefaultDice)
        {
            EnsureSuccessThresholdDefault();
        }

        return Task.CompletedTask;
    }

    private void EnsureSuccessThresholdDefault()
    {
        if (AssignedGameSystem is null || AssignedGameSystem.TestResolutionMode != TestResolutionMode.SuccessThreshold)
            return;

        var diceCount = UseSystemDefaultDice ? AssignedGameSystem.DefaultTestDiceCount : NewDiceCount;
        var diceSides = UseSystemDefaultDice ? AssignedGameSystem.DefaultTestDiceSides : NewDiceSides;

        if (diceCount < 1 || diceSides < 2)
            return;

        var average = diceCount * (diceSides + 1) / 2.0;
        NewSuccessThreshold = (int)Math.Ceiling(average);
    }

    private void RebuildDifficultyScale()
    {
        if (AssignedGameSystem is null)
        {
            DifficultyScaleValues = new List<int> { 0 };
            SelectedDifficultyIndex = 0;
            return;
        }

        var maxSum = AssignedGameSystem.DefaultTestDiceCount * AssignedGameSystem.DefaultTestDiceSides;
        var halfTarget = (int)Math.Ceiling(maxSum / 2.0);

        var baseStep = maxSum < 20 ? 1 : maxSum < 50 ? 2 : 5;

        var sideCount = 0;
        var step = baseStep;

        for (var candidateSideCount = 7; candidateSideCount >= 5; candidateSideCount--)
        {
            var candidateStep = Math.Max(baseStep, (halfTarget / candidateSideCount / baseStep) * baseStep);
            if (candidateStep > 0 && candidateStep * candidateSideCount <= halfTarget)
            {
                sideCount = candidateSideCount;
                step = candidateStep;
                break;
            }
        }

        if (sideCount == 0)
        {
            for (var candidateSideCount = 4; candidateSideCount >= 1; candidateSideCount--)
            {
                var candidateStep = Math.Max(baseStep, (halfTarget / candidateSideCount / baseStep) * baseStep);
                if (candidateStep > 0)
                {
                    sideCount = candidateSideCount;
                    step = candidateStep;
                    break;
                }
            }
        }

        if (sideCount == 0)
        {
            DifficultyScaleValues = new List<int> { 0 };
            SelectedDifficultyIndex = 0;
            return;
        }

        DifficultyScaleValues = new List<int>();
        for (var i = sideCount; i >= 1; i--)
            DifficultyScaleValues.Add(i * step);

        DifficultyScaleValues.Add(0);

        for (var i = 1; i <= sideCount; i++)
            DifficultyScaleValues.Add(-i * step);

        SelectedDifficultyIndex = sideCount;
    }

    private string FormatDifficultyValue(int value)
    {
        if (value == 0)
            return "0";

        return value > 0 ? $"+{value}" : value.ToString();
    }

    private string GetDifficultyTickClass(int index)
    {
        if (index != SelectedDifficultyIndex)
            return string.Empty;

        var value = DifficultyScaleValues[index];

        if (value > 0)
            return "active active-positive";

        if (value < 0)
            return "active active-negative";

        return "active active-neutral";
    }

    private string GetAutoRollTickClass(int index)
    {
        return index == SelectedAutoRollDelayIndex ? "active active-neutral" : string.Empty;
    }

    private async Task CreateGameTest()
    {
        try
        {
            Message = string.Empty;

            if (AssignedGameSystem is null)
            {
                Message = L["GameTest_NoGameSystemForSession"];
                return;
            }

            if (string.IsNullOrWhiteSpace(SelectedAttributeId))
            {
                Message = L["GameTest_AttributeRequired"];
                return;
            }

            
            var difficultyRaw = SelectedDifficultyRawValue;
            var modifierMode = difficultyRaw >= 0 ? TestModifierMode.Bonus : TestModifierMode.Malus;
            var difficultyValue = Math.Abs(difficultyRaw);

            var request = new GameTestCreateRequestDto
            {
                TargetKind = NewTargetKind,
                TargetDefinitionId = Guid.Parse(SelectedAttributeId),
                UseSystemDefaultDice = UseSystemDefaultDice,
                DiceCount = UseSystemDefaultDice ? AssignedGameSystem.DefaultTestDiceCount : NewDiceCount,
                DiceSides = UseSystemDefaultDice ? AssignedGameSystem.DefaultTestDiceSides : NewDiceSides,
                CriticalSuccessValue = UseSystemDefaultDice ? AssignedGameSystem.CriticalSuccessValue : null,
                CriticalFailureValue = UseSystemDefaultDice ? AssignedGameSystem.CriticalFailureValue : null,
                SuccessThreshold = NewSuccessThreshold,
                ModifierMode = modifierMode,
                DifficultyValue = difficultyValue,
                TargetScope = NewTargetScope,
                TraitFilterMode = NewTraitFilterMode,
                AdvancedFilter = new CharacterTargetFilterDto
                {
                    OnlyAlive = true,
                    OnlyDead = false,
                    OnlyOnline = NewTargetScope == TestTargetScope.OnlineLivingCharacters,
                    IncludeNpcs = IncludeNpcsInTest,
                    MatchAllConditions = AdvancedFilter.MatchAllConditions,
                    TraitOptionIds = AdvancedFilter.TraitOptionIds.ToList(),
                    TalentIds = AdvancedFilter.TalentIds.ToList(),
                    ItemIds = AdvancedFilter.ItemIds.ToList(),
                    ValueFilters = AdvancedFilter.ValueFilters
                        .Select(x => new CharacterValueFilterDto
                        {
                            TargetType = x.TargetType,
                            TargetId = x.TargetId,
                            TargetName = x.TargetName,
                            ComparisonType = x.ComparisonType,
                            Value = x.Value
                        })
                        .ToList()
                },
            };

            ActiveTest = await GameTestService.CreateGameTestAsync(SessionId, CurrentUserId, request);
            Message = L["GameTest_Created"];
        }
        catch (Exception ex)
        {
            Message = $"{L["Common_Error"]} : {ex.Message}";
        }
    }

    private string GetResultCardClass(GameMasterGameTestResultLineDto line)
{
    if (!line.HasRolled)
        return string.Empty;

    return line.Outcome switch
    {
            GameTestOutcome.Success => "rc-character-result-card--success",
            GameTestOutcome.CriticalSuccess => "rc-character-result-card--criticalsuccess",
            GameTestOutcome.Failure => "rc-character-result-card--failure",
            GameTestOutcome.CriticalFailure => "rc-character-result-card--criticalfailure",
        _ => string.Empty
    };
}

    private void ToggleTraitFilter(Guid optionId, object? isCheckedValue)
    {
        var isChecked = false;

        if (isCheckedValue is bool boolValue)
            isChecked = boolValue;
        else if (isCheckedValue is string stringValue && bool.TryParse(stringValue, out var parsed))
            isChecked = parsed;

        if (isChecked)
            SelectedTraitOptionIds.Add(optionId);
        else
            SelectedTraitOptionIds.Remove(optionId);
    }

