    private void AddGenericConsequence()
    {
        var targetKind = AvailableGaugeDefinitions.Count > 0
            ? TestConsequenceTargetKind.Gauge
            : TestConsequenceTargetKind.Attribute;

        ConsequenceRows.Add(new ConsequenceRowModel
        {
            RowId = Guid.NewGuid(),
            ApplyOn = TestConsequenceApplyOn.OnSuccess,
            OperationType = TestConsequenceOperationType.AddValue,
            TargetKind = targetKind,
            TargetDefinitionId = GetFirstConsequenceTargetId(targetKind),
            ModifierMode = TestModifierMode.Malus,
            Value = 1,
            ValueMode = ModifierValueMode.Fixed,
            SourceMetricId = AvailableMetrics.FirstOrDefault()?.Id
        });
    }

    private void RemoveConsequenceRow(Guid rowId)
    {
        var row = ConsequenceRows.FirstOrDefault(x => x.RowId == rowId);
        if (row is not null)
            ConsequenceRows.Remove(row);
    }

    private void ChangeConsequenceOperation(ConsequenceRowModel row, string? rawValue)
    {
        if (!int.TryParse(rawValue, out var parsed))
            return;

        row.OperationType = (TestConsequenceOperationType)parsed;

        switch (row.OperationType)
        {
            case TestConsequenceOperationType.AddValue:
                row.TargetKind = AvailableGaugeDefinitions.Count > 0
                    ? TestConsequenceTargetKind.Gauge
                    : TestConsequenceTargetKind.Attribute;
                row.TargetDefinitionId = GetFirstConsequenceTargetId(row.TargetKind);
                if (row.Value == 0)
                    row.Value = 1;
                break;

            case TestConsequenceOperationType.GrantTalent:
            case TestConsequenceOperationType.RevokeTalent:
                row.TargetKind = TestConsequenceTargetKind.Talent;
                row.TargetDefinitionId = GetFirstConsequenceTargetId(row.TargetKind);
                row.Value = 0;
                row.ValueMode = ModifierValueMode.Fixed;
                row.SourceMetricId = AvailableMetrics.FirstOrDefault()?.Id;
                break;

            case TestConsequenceOperationType.GrantItem:
            case TestConsequenceOperationType.RevokeItem:
                row.TargetKind = TestConsequenceTargetKind.Item;
                row.TargetDefinitionId = GetFirstConsequenceTargetId(row.TargetKind);
                row.Value = 0;
                row.ValueMode = ModifierValueMode.Fixed;
                row.SourceMetricId = AvailableMetrics.FirstOrDefault()?.Id;
                break;
        }
    }

    private void ChangeConsequenceTargetKind(ConsequenceRowModel row, string? rawValue)
    {
        if (!int.TryParse(rawValue, out var parsed))
            return;

        row.TargetKind = (TestConsequenceTargetKind)parsed;
        row.TargetDefinitionId = GetFirstConsequenceTargetId(row.TargetKind);
    }

    private Guid GetFirstConsequenceTargetId(TestConsequenceTargetKind targetKind)
    {
        return targetKind switch
        {
            TestConsequenceTargetKind.Gauge => AvailableGaugeDefinitions.FirstOrDefault()?.Id ?? Guid.Empty,
            TestConsequenceTargetKind.SessionGauge => SessionGauges.FirstOrDefault()?.SessionGaugeId ?? Guid.Empty,
            TestConsequenceTargetKind.Attribute => AvailableAttributes.FirstOrDefault()?.Id ?? Guid.Empty,
            TestConsequenceTargetKind.DerivedStat => AvailableDerivedStats.FirstOrDefault()?.DerivedStatDefinitionId ?? Guid.Empty,
            TestConsequenceTargetKind.Metric => AvailableMetrics.FirstOrDefault()?.Id ?? Guid.Empty,
            TestConsequenceTargetKind.Talent => AvailableTalents.FirstOrDefault()?.TalentDefinitionId ?? Guid.Empty,
            TestConsequenceTargetKind.Item => AvailableItems.FirstOrDefault()?.ItemDefinitionId ?? Guid.Empty,
            _ => Guid.Empty
        };
    }

