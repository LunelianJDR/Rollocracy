@page "/mj/session/{SessionId:guid}/mass-distribution"
@rendermode InteractiveServer

@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Extensions.Localization
@using Rollocracy.Domain.Characters
@using Rollocracy.Domain.Interfaces
@using Rollocracy.Localization
@using Rollocracy.Domain.GameRules
@using Rollocracy.Components.Pages.MJ.Shared

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IMassDistributionService MassDistributionService
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedTexts> L
@inject ISessionService SessionService
@inject ICharacterService CharacterService

<h3>@L["MassDistribution_Title"]</h3>

@if (!IsLoaded)
{
    <p>@L["Common_Loading"]</p>
}
else if (RedirectToHome)
{
    <p>@L["Common_Loading"]</p>
}
else if (Editor is null)
{
    <p>@L["MassDistribution_NotFound"]</p>
}
else
{
    <section class="rc-tool-section">
        <div class="rc-tool-layout">
            <div class="rc-tool-panel">
                <div class="rc-tool-panel__header rc-tool-panel__header--top-aligned">
                    <div class="rc-tool-panel__header-main">
                        <h5 class="rc-tool-panel__title">@L["MassDistribution_Title"]</h5>
                        <p class="rc-tool-panel__subtitle">@Editor.SessionName · @L["MassDistribution_FilterSection"] / @L["MassDistribution_EffectsSection"]</p>
                    </div>

                    <div class="rc-tool-inline-actions">
                        <button @onclick="PreviewTargets">@L["MassDistribution_PreviewTargets"]</button>
                        <button @onclick="ApplyDistribution">@L["MassDistribution_Apply"]</button>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(Message))
                {
                    <div class="rc-inline-error">@Message</div>
                }

                @if (LastBatch is not null)
                {
                    <div class="rc-inline-info">
                        <div>
                            <strong>@L["MassDistribution_LastBatch"] :</strong>
                            @LastBatch.Name
                            · @LastBatch.TargetCharacterCount
                        </div>
                        <button @onclick="UndoLastDistribution">@L["MassDistribution_UndoLast"]</button>
                    </div>
                }

                <div class="rc-tool-form-grid">
                    <div class="rc-form-field rc-form-field--full">
                        <label>@L["MassDistribution_Name"]</label>
                        <input @bind="Request.Name" />
                    </div>
                </div>

                <div class="rc-tool-subsection">
                    <div class="rc-tool-subsection__title">@L["MassDistribution_FilterSection"]</div>

                    <div class="rc-filter-groups">
                        <CharacterAudienceFilters Title="@L["GameTest_TargetScope"]"
                                                    OnlyOnline="Request.Filter.OnlyOnline"
                                                    OnlyAlive="Request.Filter.OnlyAlive"
                                                    IncludeNpcs="Request.Filter.IncludeNpcs"
                                                    OnlyOnlineChanged="@(value => { Request.Filter.OnlyOnline = value; if (value) Request.Filter.OnlyAlive = false; })"
                                                    OnlyAliveChanged="@(value => { Request.Filter.OnlyAlive = value; if (value) Request.Filter.OnlyOnline = false; })"
                                                    IncludeNpcsChanged="@(value => Request.Filter.IncludeNpcs = value)" />

                        <CharacterAdvancedFilters Filter="Request.Filter"
                                                  TraitOptionGroups="AdvancedTraitOptionGroups"
                                                  TalentOptions="AdvancedTalentOptions"
                                                  ItemOptions="AdvancedItemOptions"
                                                  AttributeTargets="AdvancedAttributeTargets"
                                                  GaugeTargets="AdvancedGaugeTargets"
                                                  DerivedStatTargets="AdvancedDerivedTargets"
                                                  MetricTargets="AdvancedMetricTargets" />
                    </div>
                </div>

                <div class="rc-tool-subsection">
                    <div class="rc-tool-subsection__header">
                        <div class="rc-tool-subsection__title">@L["MassDistribution_EffectsSection"]</div>
                        <div class="rc-tool-inline-actions">
                            <button @onclick="AddEffect">@L["MassDistribution_AddEffect"]</button>
                        </div>
                    </div>

                    @if (Request.Effects.Count == 0)
                    {
                        <p class="rc-tool-muted">@L["MassDistribution_NoEffects"]</p>
                    }
                    else
                    {
                        <div class="rc-consequence-list">
                            @foreach (var effect in Request.Effects)
                            {
                                <div class="rc-consequence-card">
                                    <div class="rc-consequence-card__grid">
                                        <div class="rc-form-field">
                                            <label>@L["Poll_ConsequenceOperation"]</label>
                                            <select @bind="effect.OperationType">
                                                <option value="@CharacterEffectOperationType.AddValue">@L["MassDistribution_Operation_AddValue"]</option>
                                                <option value="@CharacterEffectOperationType.GrantTalent">@L["MassDistribution_Operation_GrantTalent"]</option>
                                                <option value="@CharacterEffectOperationType.RevokeTalent">@L["MassDistribution_Operation_RevokeTalent"]</option>
                                                <option value="@CharacterEffectOperationType.GrantItem">@L["MassDistribution_Operation_GrantItem"]</option>
                                                <option value="@CharacterEffectOperationType.RevokeItem">@L["MassDistribution_Operation_RevokeItem"]</option>
                                            </select>
                                        </div>

                                        @if (effect.OperationType == CharacterEffectOperationType.AddValue)
                                        {
                                            <div class="rc-form-field">
                                                <label>@L["MassDistribution_FilterTarget"]</label>
                                                <select @bind="effect.TargetType">
                                                    <option value="@CharacterEffectTargetType.BaseAttribute">@L["EditGameSystem_ModifierTarget_Attribute"]</option>
                                                    <option value="@CharacterEffectTargetType.Gauge">@L["MassDistribution_Target_Gauge"]</option>
                                                    <option value="@CharacterEffectTargetType.SessionGauge">@L["SessionPage_TargetSessionGauge"]</option>
                                                    <option value="@CharacterEffectTargetType.DerivedStat">@L["EditGameSystem_ModifierTarget_DerivedStat"]</option>
                                                    <option value="@CharacterEffectTargetType.Metric">@L["EditGameSystem_ModifierTarget_Metric"]</option>
                                                </select>
                                            </div>

                                            <div class="rc-form-field">
                                                <label>@L["GameTest_TargetDefinition"]</label>

                                                @if (effect.TargetType == CharacterEffectTargetType.BaseAttribute)
                                                {
                                                    <select @bind="effect.TargetId">
                                                        @foreach (var item in Editor.BaseAttributes)
                                                        {
                                                            <option value="@item.Id">@item.Name</option>
                                                        }
                                                    </select>
                                                }
                                                else if (effect.TargetType == CharacterEffectTargetType.Gauge)
                                                {
                                                    <select @bind="effect.TargetId">
                                                        @foreach (var item in Editor.Gauges)
                                                        {
                                                            <option value="@item.Id">@item.Name</option>
                                                        }
                                                    </select>
                                                }
                                                else if (effect.TargetType == CharacterEffectTargetType.SessionGauge)
                                                {
                                                    <select @bind="effect.TargetId">
                                                        @foreach (var item in SessionGauges)
                                                        {
                                                            <option value="@item.SessionGaugeId">@item.Name</option>
                                                        }
                                                    </select>
                                                }
                                                else if (effect.TargetType == CharacterEffectTargetType.DerivedStat)
                                                {
                                                    <select @bind="effect.TargetId">
                                                        @foreach (var item in Editor.DerivedStats)
                                                        {
                                                            <option value="@item.Id">@item.Name</option>
                                                        }
                                                    </select>
                                                }
                                                else if (effect.TargetType == CharacterEffectTargetType.Metric)
                                                {
                                                    <select @bind="effect.TargetId">
                                                        @foreach (var item in Editor.Metrics)
                                                        {
                                                            <option value="@item.Id">@item.Name</option>
                                                        }
                                                    </select>
                                                }
                                            </div>

                                            <div class="rc-form-field">
                                                <label>@L["GameTest_ConsequenceValueMode"]</label>
                                                <select @bind="effect.ValueMode">
                                                    <option value="@ModifierValueMode.Fixed">@L["EditGameSystem_ModifierValueMode_Fixed"]</option>
                                                    <option value="@ModifierValueMode.Metric">@L["EditGameSystem_ModifierValueMode_Metric"]</option>
                                                </select>
                                            </div>

                                            @if (effect.ValueMode == ModifierValueMode.Metric)
                                            {
                                                <div class="rc-form-field">
                                                    <label>@L["Common_SourceMetric"]</label>
                                                    <select @bind="effect.SourceMetricId">
                                                        @foreach (var item in Editor.Metrics)
                                                        {
                                                            <option value="@item.Id">@item.Name</option>
                                                        }
                                                    </select>
                                                </div>

                                                <div class="rc-form-field">
                                                    <label>@L["GameTest_DifficultyMode"]</label>
                                                    <select @bind="effect.Value">
                                                        <option value="1">@L["GameTest_Bonus"]</option>
                                                        <option value="-1">@L["GameTest_Malus"]</option>
                                                    </select>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="rc-form-field">
                                                    <label>@L["GameTest_DifficultyValue"]</label>
                                                    <input type="number" @bind="effect.Value" />
                                                </div>
                                            }
                                        }
                                        else if (effect.OperationType == CharacterEffectOperationType.GrantTalent || effect.OperationType == CharacterEffectOperationType.RevokeTalent)
                                        {
                                            effect.TargetType = CharacterEffectTargetType.Talent;

                                            <div class="rc-form-field">
                                                <label>@L["GameTest_TargetDefinition"]</label>
                                                <select @bind="effect.TargetId">
                                                    @foreach (var item in Editor.Talents)
                                                    {
                                                        <option value="@item.Id">@item.Name</option>
                                                    }
                                                </select>
                                            </div>
                                        }
                                        else
                                        {
                                            effect.TargetType = CharacterEffectTargetType.Item;

                                            <div class="rc-form-field">
                                                <label>@L["GameTest_TargetDefinition"]</label>
                                                <select @bind="effect.TargetId">
                                                    @foreach (var item in Editor.Items)
                                                    {
                                                        <option value="@item.Id">@item.Name</option>
                                                    }
                                                </select>
                                            </div>
                                        }
                                    </div>

                                    <div class="rc-tool-inline-actions">
                                        <button @onclick="() => Request.Effects.Remove(effect)">@L["Common_Remove"]</button>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>

                <div class="rc-tool-actions rc-tool-actions--right">
                    <button @onclick="PreviewTargets">@L["MassDistribution_PreviewTargets"]</button>
                    <button @onclick="ApplyDistribution">@L["MassDistribution_Apply"]</button>
                </div>
            </div>

            <div class="rc-tool-panel">
                <div class="rc-tool-panel__header">
                    <div>
                        <h5 class="rc-tool-panel__title">@L["MassDistribution_PreviewResult"]</h5>
                        <p class="rc-tool-panel__subtitle">@L["MassDistribution_TargetCount"] : @PreviewCharacters.Count</p>
                    </div>
                </div>

                @if (PreviewCharacters.Count == 0)
                {
                    <div class="rc-empty-panel">
                        <p>@L["MassDistribution_NoPreview"]</p>
                    </div>
                }
                else
                {
                    <div class="rc-test-result-grid">
                        @foreach (var item in PreviewCharacters)
                        {
                            if (CharacterSummariesById.TryGetValue(item.CharacterId, out var summary))
                            {
                                <CharacterResultSummaryCard Character="summary" />
                            }
                        }
                    </div>
                }
            </div>
        </div>
    </section>
}

@code {
    [Parameter] public Guid SessionId { get; set; }

    private Guid CurrentUserId;
    private bool IsLoaded;
    private bool RedirectToHome;
    private string Message = string.Empty;

    private MassDistributionEditorDto? Editor;
    private List<SessionGaugeDto> SessionGauges = new();
    private MassDistributionRequestDto Request = new();
    private Dictionary<Guid, SessionCharacterSummaryDto> CharacterSummariesById = new();

    private List<MassDistributionPreviewCharacterDto> PreviewCharacters { get; set; } = new();

    private MassDistributionLastBatchDto? LastBatch;

    private List<CharacterFilterGroupItem> AdvancedTraitOptionGroups
    => Editor?.TraitOptions
        .GroupBy(x => new { x.GroupId, x.GroupName })
        .OrderBy(x => x.Key.GroupName)
        .Select(group => new CharacterFilterGroupItem
        {
            GroupName = group.Key.GroupName,
            Options = group
                .OrderBy(x => x.Name)
                .Select(x => new CharacterFilterReferenceItem
                {
                    Id = x.Id,
                    Name = x.Name
                })
                .ToList()
        })
        .ToList()
        ?? new List<CharacterFilterGroupItem>();

    private List<CharacterFilterReferenceItem> AdvancedTalentOptions
        => Editor?.Talents.Select(x => new CharacterFilterReferenceItem { Id = x.Id, Name = x.Name }).ToList() ?? new();

    private List<CharacterFilterReferenceItem> AdvancedItemOptions
        => Editor?.Items.Select(x => new CharacterFilterReferenceItem { Id = x.Id, Name = x.Name }).ToList() ?? new();

    private List<CharacterFilterReferenceItem> AdvancedAttributeTargets
        => Editor?.BaseAttributes.Select(x => new CharacterFilterReferenceItem { Id = x.Id, Name = x.Name }).ToList() ?? new();

    private List<CharacterFilterReferenceItem> AdvancedGaugeTargets
        => Editor?.Gauges.Select(x => new CharacterFilterReferenceItem { Id = x.Id, Name = x.Name }).ToList() ?? new();

    private List<CharacterFilterReferenceItem> AdvancedDerivedTargets
        => Editor?.DerivedStats.Select(x => new CharacterFilterReferenceItem { Id = x.Id, Name = x.Name }).ToList() ?? new();

    private List<CharacterFilterReferenceItem> AdvancedMetricTargets
        => Editor?.Metrics.Select(x => new CharacterFilterReferenceItem { Id = x.Id, Name = x.Name }).ToList() ?? new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var isAuthenticated = user.Identity?.IsAuthenticated == true;
        var userIdValue = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (!isAuthenticated || string.IsNullOrWhiteSpace(userIdValue))
        {
            RedirectToHome = true;
            IsLoaded = true;
            return;
        }

        CurrentUserId = Guid.Parse(userIdValue);
        Editor = await MassDistributionService.GetEditorAsync(SessionId, CurrentUserId);
        SessionGauges = await SessionService.GetSessionGaugesAsync(SessionId, CurrentUserId);
        LastBatch = await MassDistributionService.GetLastBatchAsync(SessionId, CurrentUserId);
        await LoadCharacterSummariesAsync();

        IsLoaded = true;
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && RedirectToHome)
            Navigation.NavigateTo("/", forceLoad: true);

        return Task.CompletedTask;
    }

    private void AddValueFilter()
    {
        var firstAttribute = Editor?.BaseAttributes.FirstOrDefault();

        Request.Filter.ValueFilters.Add(new CharacterValueFilterDto
        {
            TargetType = CharacterEffectTargetType.BaseAttribute,
            TargetId = firstAttribute?.Id ?? Guid.Empty,
            ComparisonType = CharacterValueComparisonType.GreaterThanOrEqual,
            Value = 0
        });
    }

    private void AddEffect()
    {
        var firstAttribute = Editor?.BaseAttributes.FirstOrDefault();

        Request.Effects.Add(new CharacterEffectDefinitionDto
        {
            OperationType = CharacterEffectOperationType.AddValue,
            TargetType = CharacterEffectTargetType.BaseAttribute,
            TargetId = firstAttribute?.Id ?? Guid.Empty,
            Value = 0,
            ValueMode = ModifierValueMode.Fixed,
            SourceMetricId = Editor?.Metrics.FirstOrDefault()?.Id
        });
    }

    private async Task PreviewTargets()
    {
        try
        {
            Message = string.Empty;
            PreviewCharacters = await MassDistributionService.PreviewTargetsAsync(SessionId, CurrentUserId, Request);
        }
        catch (Exception ex)
        {
            Message = $"{L["Common_Error"]} : {ex.Message}";
        }
    }

    private async Task ApplyDistribution()
    {
        try
        {
            Message = string.Empty;
            var count = await MassDistributionService.ApplyAsync(SessionId, CurrentUserId, Request);
            PreviewCharacters = await MassDistributionService.PreviewTargetsAsync(SessionId, CurrentUserId, Request);
            LastBatch = await MassDistributionService.GetLastBatchAsync(SessionId, CurrentUserId);
            Message = $"{L["MassDistribution_ApplySuccess"]} : {count}";
        }
        catch (Exception ex)
        {
            Message = $"{L["Common_Error"]} : {ex.Message}";
        }
    }

    private async Task UndoLastDistribution()
    {
        try
        {
            Message = string.Empty;
            var batchName = await MassDistributionService.UndoLastAsync(SessionId, CurrentUserId);
            LastBatch = await MassDistributionService.GetLastBatchAsync(SessionId, CurrentUserId);
            PreviewCharacters.Clear();
            Message = $"{L["MassDistribution_UndoSuccess"]} : {batchName}";
        }
        catch (Exception ex)
        {
            Message = $"{L["Common_Error"]} : {ex.Message}";
        }
    }

    private async Task LoadCharacterSummariesAsync()
    {
        var characters = await CharacterService.GetSessionCharacterSummariesAsync(
            SessionId,
            includeOffline: true,
            includeDead: true,
            includeNpcs: true);

        CharacterSummariesById = characters.ToDictionary(x => x.CharacterId, x => x);
    }
}