@page "/mj/session/{SessionId:guid}/random-draw"
@rendermode InteractiveServer

@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Extensions.Localization
@using Rollocracy.Domain.Characters
@using Rollocracy.Domain.Interfaces
@using Rollocracy.Domain.GameRules
@using Rollocracy.Localization
@using Rollocracy.Components.Pages.MJ.Shared

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ICharacterService CharacterService
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedTexts> L

<h3>@L["RandomDraw_Title"]</h3>

@if (!IsLoaded)
{
    <p>@L["Common_Loading"]</p>
}
else if (RedirectToHome)
{
    <p>@L["Common_Loading"]</p>
}
else if (Editor is null)
{
    <p>@L["RandomDraw_NotFound"]</p>
}
else
{
    <section class="rc-tool-section">
        <div class="rc-tool-layout">
            <div class="rc-tool-panel">
                <div class="rc-tool-panel__header rc-tool-panel__header--top-aligned">
                    <div class="rc-tool-panel__header-main">
                        <h5 class="rc-tool-panel__title">@L["RandomDraw_Title"]</h5>
                        <p class="rc-tool-panel__subtitle">@Editor.SessionName · @L["RandomDraw_FilterSection"]</p>
                    </div>

                    <div class="rc-tool-inline-actions">
                        <button @onclick="ExecuteDraw">@L["RandomDraw_Execute"]</button>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(Message))
                {
                    <div class="@(IsWarning ? "rc-inline-warning" : "rc-inline-error")">
                        @Message
                    </div>
                }

                <div class="rc-tool-form-grid">
                    <div class="rc-form-field">
                        <label>@L["RandomDraw_Name"]</label>
                        <input @bind="Request.Name" />
                    </div>

                    <div class="rc-form-field">
                        <label>@L["RandomDraw_Count"]</label>
                        <input type="number" min="1" @bind="Request.DrawCount" />
                    </div>
                </div>

                <div class="rc-tool-subsection">
                    <div class="rc-tool-subsection__title">@L["MassDistribution_FilterSection"]</div>

                    <div class="rc-filter-groups">
                        <CharacterAudienceFilters Title="@L["GameTest_TargetScope"]"
                                                    OnlyOnline="Request.Filter.OnlyOnline"
                                                    OnlyAlive="Request.Filter.OnlyAlive"
                                                    IncludeNpcs="Request.Filter.IncludeNpcs"
                                                    OnlyOnlineChanged="@(value => { Request.Filter.OnlyOnline = value; if (value) Request.Filter.OnlyAlive = false; })"
                                                    OnlyAliveChanged="@(value => { Request.Filter.OnlyAlive = value; if (value) Request.Filter.OnlyOnline = false; })"
                                                    IncludeNpcsChanged="@(value => Request.Filter.IncludeNpcs = value)" />
                        
                        <CharacterAdvancedFilters Filter="Request.Filter"
                                                  TraitOptionGroups="AdvancedTraitOptionGroups"
                                                  TalentOptions="AdvancedTalentOptions"
                                                  ItemOptions="AdvancedItemOptions"
                                                  AttributeTargets="AdvancedAttributeTargets"
                                                  GaugeTargets="AdvancedGaugeTargets"
                                                  DerivedStatTargets="AdvancedDerivedTargets"
                                                  MetricTargets="AdvancedMetricTargets" />
                    </div>

                </div>

                <div class="rc-tool-actions rc-tool-actions--right">
                    <button @onclick="ExecuteDraw">@L["RandomDraw_Execute"]</button>
                </div>
            </div>

            <div class="rc-tool-panel">
                <div class="rc-tool-panel__header">
                    <div>
                        <h5 class="rc-tool-panel__title">@L["RandomDraw_LastResult"]</h5>
                        <p class="rc-tool-panel__subtitle">
                            @(LastDraw is null ? L["RandomDraw_NoResultYet"] : LastDraw.Name)
                        </p>
                    </div>
                </div>

                @if (LastDraw is null || LastDraw.Results.Count == 0)
                {
                    <div class="rc-empty-panel">
                        <p>@L["RandomDraw_NoResultYet"]</p>
                    </div>
                }
                else
                {
                    <div class="rc-test-result-grid">
                        @foreach (var item in LastDraw.Results)
                        {
                            if (CharacterSummariesById.TryGetValue(item.CharacterId, out var summary))
                            {
                                <CharacterResultSummaryCard Character="summary" />
                            }
                        }
                    </div>
                }

                <div class="rc-tool-subsection">
                    <div class="rc-tool-subsection__title">@L["RandomDraw_History"]</div>

                    @if (Editor.RecentDraws.Count == 0)
                    {
                        <div class="rc-empty-panel rc-empty-panel--small">
                            <p>@L["RandomDraw_NoHistory"]</p>
                        </div>
                    }
                    else
                    {
                        <div class="rc-random-draw-history">
                            @foreach (var draw in Editor.RecentDraws)
                            {
                                <div class="rc-random-draw-history__item">
                                    <div class="rc-random-draw-history__title">@draw.Name</div>

                                    <div class="rc-random-draw-history__result">
                                        @string.Join(" | ", draw.Results.Select(x => x.CharacterName + (x.IsNpc ? $" ({L["Common_Npc"]})" : string.Empty)))
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </section>
}

@code {
    [Parameter] public Guid SessionId { get; set; }

    private Guid CurrentUserId;
    private bool IsLoaded;
    private bool RedirectToHome;
    private string Message = string.Empty;
    private bool IsWarning;

    private RandomDrawEditorDto? Editor;
    private RandomDrawRequestDto Request = new();
    private RandomDrawResultDto? LastDraw;
    private Dictionary<Guid, SessionCharacterSummaryDto> CharacterSummariesById = new();

    private List<CharacterFilterGroupItem> AdvancedTraitOptionGroups
    => Editor?.TraitOptions
        .GroupBy(x => new { x.GroupId, x.GroupName })
        .OrderBy(x => x.Key.GroupName)
        .Select(group => new CharacterFilterGroupItem
        {
            GroupName = group.Key.GroupName,
            Options = group
                .OrderBy(x => x.Name)
                .Select(x => new CharacterFilterReferenceItem
                {
                    Id = x.Id,
                    Name = x.Name
                })
                .ToList()
        })
        .ToList()
        ?? new List<CharacterFilterGroupItem>();

    private List<CharacterFilterReferenceItem> AdvancedTalentOptions
        => Editor?.Talents.Select(x => new CharacterFilterReferenceItem { Id = x.Id, Name = x.Name }).ToList() ?? new();

    private List<CharacterFilterReferenceItem> AdvancedItemOptions
        => Editor?.Items.Select(x => new CharacterFilterReferenceItem { Id = x.Id, Name = x.Name }).ToList() ?? new();

    private List<CharacterFilterReferenceItem> AdvancedAttributeTargets
        => Editor?.BaseAttributes.Select(x => new CharacterFilterReferenceItem { Id = x.Id, Name = x.Name }).ToList() ?? new();

    private List<CharacterFilterReferenceItem> AdvancedGaugeTargets
        => Editor?.Gauges.Select(x => new CharacterFilterReferenceItem { Id = x.Id, Name = x.Name }).ToList() ?? new();

    private List<CharacterFilterReferenceItem> AdvancedDerivedTargets
        => Editor?.DerivedStats.Select(x => new CharacterFilterReferenceItem { Id = x.Id, Name = x.Name }).ToList() ?? new();

    private List<CharacterFilterReferenceItem> AdvancedMetricTargets
        => Editor?.Metrics.Select(x => new CharacterFilterReferenceItem { Id = x.Id, Name = x.Name }).ToList() ?? new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var isAuthenticated = user.Identity?.IsAuthenticated == true;
        var userIdValue = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (!isAuthenticated || string.IsNullOrWhiteSpace(userIdValue))
        {
            RedirectToHome = true;
            IsLoaded = true;
            return;
        }

        CurrentUserId = Guid.Parse(userIdValue);
        await LoadEditorAsync();
        IsLoaded = true;
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && RedirectToHome)
            Navigation.NavigateTo("/", forceLoad: true);

        return Task.CompletedTask;
    }

    private async Task LoadEditorAsync()
    {
        Editor = await CharacterService.GetRandomDrawEditorAsync(SessionId, CurrentUserId);
        await LoadCharacterSummariesAsync();

        if (Editor is not null)
        {
            Request.Name = Editor.SuggestedName;

            if (Request.DrawCount <= 0)
                Request.DrawCount = 1;

            Request.Filter.IncludeNpcs = true;
        }
    }

    private void AddValueFilter()
    {
        var firstAttribute = Editor?.BaseAttributes.FirstOrDefault();

        Request.Filter.ValueFilters.Add(new CharacterValueFilterDto
        {
            TargetType = CharacterEffectTargetType.BaseAttribute,
            TargetId = firstAttribute?.Id ?? Guid.Empty,
            ComparisonType = CharacterValueComparisonType.GreaterThanOrEqual,
            Value = 0
        });
    }

    private async Task ExecuteDraw()
    {
        try
        {
            Message = string.Empty;
            IsWarning = false;

            var requestedCount = Request.DrawCount;

            LastDraw = await CharacterService.ExecuteRandomDrawAsync(SessionId, CurrentUserId, Request);

            if (LastDraw.Results.Count < requestedCount)
            {
                Message = L["RandomDraw_TooManyRequestedWarning"];
                IsWarning = true;
            }

            await LoadEditorAsync();

            if (Editor is not null)
            {
                Request.Name = Editor.SuggestedName;
            }
        }
        catch (Exception ex)
        {
            Message = $"{L["Common_Error"]} : {ex.Message}";
            IsWarning = false;
        }
    }

    private async Task LoadCharacterSummariesAsync()
    {
        var characters = await CharacterService.GetSessionCharacterSummariesAsync(
            SessionId,
            includeOffline: true,
            includeDead: true,
            includeNpcs: true);

        CharacterSummariesById = characters.ToDictionary(x => x.CharacterId, x => x);
    }
}