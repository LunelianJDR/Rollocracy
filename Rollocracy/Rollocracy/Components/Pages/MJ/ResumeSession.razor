@page "/mj/sessions"
@rendermode InteractiveServer

@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Extensions.Localization
@using Rollocracy.Localization
@using DomainSession = Rollocracy.Domain.Entities.Session

@inject Rollocracy.Domain.Interfaces.ISessionService SessionService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedTexts> L

<h3>@L["ResumeSession_Title"]</h3>

@if (!IsLoaded)
{
    <p>@L["Common_Loading"]</p>
}
else if (RedirectToHome)
{
    <p>@L["Common_Loading"]</p>
}
else if (SessionSummaries.Count == 0)
{
    <p>@L["ResumeSession_None"]</p>
}
else
{
    @foreach (var item in SessionSummaries)
    {
        <div>
            <p><strong>@L["ResumeSession_Name"] :</strong> @item.Session.SessionName</p>
            <p><strong>@L["ResumeSession_AliveCharacters"] :</strong> @item.AliveCharacterCount</p>
            <p><strong>@L["ResumeSession_IsActive"] :</strong> @(item.Session.IsActive? L["Common_Yes"] : L["Common_No"])</p>

            @if (item.Session.IsActive)
            {
                <p><strong>@L["ResumeSession_Url"] :</strong> <code>@($"{Navigation.BaseUri}{CurrentUsername}/{item.Session.SessionSlug}")</code></p>
            }
            else
            {
                <p><strong>@L["ResumeSession_Url"] :</strong> @L["ResumeSession_InactiveUrl"]</p>
            }

            <button @onclick="() => OpenSession(item.Session.Id)">@L["ResumeSession_Open"]</button>

            @if (item.Session.IsActive)
            {
                <button @onclick="() => ToggleSessionState(item.Session.Id, false)">@L["ResumeSession_Deactivate"]</button>
            }
            else
            {
                <button @onclick="() => ToggleSessionState(item.Session.Id, true)">@L["ResumeSession_Activate"]</button>
            }
        </div>
        <hr />
    }
}

@if (!string.IsNullOrWhiteSpace(Message))
{
    <p>@Message</p>
}

@code {
    private Guid CurrentUserId;
    private string CurrentUsername = string.Empty;
    private bool IsLoaded;
    private bool RedirectToHome;
    private string Message = string.Empty;
    private List<SessionSummary> SessionSummaries = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        var isAuthenticated = user.Identity?.IsAuthenticated == true;
        var userIdValue = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (!isAuthenticated || string.IsNullOrWhiteSpace(userIdValue))
        {
            RedirectToHome = true;
            IsLoaded = true;
            return;
        }

        CurrentUserId = Guid.Parse(userIdValue);
        CurrentUsername = user.Identity?.Name ?? string.Empty;

        var canCreateSessions = await SessionService.CanUserCreateSessionsAsync(CurrentUserId);

        if (!canCreateSessions)
        {
            RedirectToHome = true;
            IsLoaded = true;
            return;
        }

        await LoadSessions();
        IsLoaded = true;
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && RedirectToHome)
        {
            Navigation.NavigateTo("/", forceLoad: true);
        }

        return Task.CompletedTask;
    }

    private async Task LoadSessions()
    {
        Message = string.Empty;
        SessionSummaries.Clear();

        var sessions = await SessionService.GetSessionsByGameMasterAsync(CurrentUserId);

        foreach (var session in sessions)
        {
            var aliveCount = await SessionService.GetAliveCharacterCountAsync(session.Id);

            SessionSummaries.Add(new SessionSummary
            {
                Session = session,
                AliveCharacterCount = aliveCount
            });
        }
    }

    private void OpenSession(Guid sessionId)
    {
        Navigation.NavigateTo($"/mj/session/{sessionId}");
    }

    private async Task ToggleSessionState(Guid sessionId, bool isActive)
    {
        try
        {
            await SessionService.SetSessionActiveStateAsync(sessionId, CurrentUserId, isActive);
            await LoadSessions();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Message = $"{L["Common_Error"]} : {ex.Message}";
        }
    }

    private class SessionSummary
    {
        public DomainSession Session { get; set; } = new();
        public int AliveCharacterCount { get; set; }
    }
}