    private async Task CreateGameTest()
    {
        try
        {
            Message = string.Empty;

            if (string.IsNullOrWhiteSpace(SelectedAttributeId))
            {
                Message = L["GameTest_AttributeRequired"];
                return;
            }

            var filterGroups = new List<GameTestTraitFilterGroupDto>();

            foreach (var traitDefinition in AvailableTraitDefinitions)
            {
                if (!TraitOptionsByDefinition.TryGetValue(traitDefinition.Id, out var traitOptions))
                    continue;

                var selectedOptionIds = traitOptions
                    .Where(o => SelectedTraitOptionIds.Contains(o.Id))
                    .Select(o => o.Id)
                    .ToList();

                if (selectedOptionIds.Count > 0)
                {
                    filterGroups.Add(new GameTestTraitFilterGroupDto
                    {
                        TraitDefinitionId = traitDefinition.Id,
                        TraitDefinitionName = traitDefinition.Name,
                        SelectedOptionIds = selectedOptionIds
                    });
                }
            }

            var request = new GameTestCreateRequestDto
            {
                TargetKind = NewTargetKind,
                TargetDefinitionId = Guid.Parse(SelectedAttributeId),
                UseSystemDefaultDice = UseSystemDefaultDice,
                DiceCount = UseSystemDefaultDice ? AssignedGameSystem?.DefaultTestDiceCount ?? NewDiceCount : NewDiceCount,
                DiceSides = UseSystemDefaultDice ? AssignedGameSystem?.DefaultTestDiceSides ?? NewDiceSides : NewDiceSides,
                CriticalSuccessValue = UseSystemDefaultDice ? AssignedGameSystem?.CriticalSuccessValue : null,
                CriticalFailureValue = UseSystemDefaultDice ? AssignedGameSystem?.CriticalFailureValue : null,
                SuccessThreshold = NewSuccessThreshold,
                ModifierMode = NewModifierMode,
                DifficultyValue = NewDifficultyValue,
                TargetScope = NewTargetScope,
                TraitFilters = filterGroups,
                TraitFilterMode = NewTraitFilterMode,
                Consequences = ConsequenceRows.Select(c => new GameTestConsequenceDraftDto
                {
                    ApplyOn = c.ApplyOn,
                    OperationType = c.OperationType,
                    TargetKind = c.TargetKind,
                    TargetDefinitionId = c.TargetDefinitionId,
                    ModifierMode = c.ModifierMode,
                    Value = c.ValueMode == ModifierValueMode.Metric ? 0 : c.Value,
                    ValueMode = c.ValueMode,
                    SourceMetricId = c.ValueMode == ModifierValueMode.Metric ? c.SourceMetricId : null
                }).ToList()
            };

            ActiveTest = await GameTestService.CreateGameTestAsync(
                SessionId,
                CurrentUserId,
                request);

            Message = L["GameTest_Created"];
        }
        catch (Exception ex)
        {
            Message = $"{L["Common_Error"]} : {ex.Message}";
        }
    }

