@page "/mj/session/{SessionId:guid}"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Extensions.Localization
@using Rollocracy.Domain.Characters
@using Rollocracy.Domain.Entities
@using Rollocracy.Domain.GameRules
@using Rollocracy.Domain.GameTests
@using Rollocracy.Localization
@using Rollocracy.Domain.Polls
@using DomainSession = Rollocracy.Domain.Entities.Session
@inject NavigationManager Navigation
@inject Rollocracy.Domain.Interfaces.ISessionService SessionService
@inject Rollocracy.Domain.Interfaces.IGameSystemService GameSystemService
@inject Rollocracy.Domain.Interfaces.ICharacterService CharacterService
@inject Rollocracy.Domain.Interfaces.IGameTestService GameTestService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IStringLocalizer<SharedTexts> L
@inject Rollocracy.Domain.Interfaces.IPollService PollService

<h3>@L["SessionPage_Title"]</h3>

@if (!IsLoaded)
{
    <p>@L["Common_Loading"]</p>
}
else if (CurrentSession is null)
{
    <p>@L["SessionPage_NotFound"]</p>
}
else
{
    <p><strong>@L["SessionPage_Name"] :</strong> @CurrentSession.SessionName</p>
    <p><strong>@L["SessionPage_Slug"] :</strong> @CurrentSession.SessionSlug</p>

    <p><strong>@L["SessionPage_JoinUrl"] :</strong></p>
    <p><code>@JoinUrl</code></p>

    <p>
        <strong>@L["SessionPage_Password"] :</strong>
        @if (string.IsNullOrWhiteSpace(CurrentSession.SessionPassword))
        {
            <span>@L["Common_None"]</span>
        }
        else if (ShowSessionPassword)
        {
            <code>@CurrentSession.SessionPassword</code>
        }
        else
        {
            <code>****</code>
        }
    </p>

    @if (!string.IsNullOrWhiteSpace(CurrentSession.SessionPassword))
    {
        <button @onclick="ToggleSessionPasswordVisibility">
            @(ShowSessionPassword? L["SessionPage_HidePassword"] : L["SessionPage_ShowPassword"])
        </button>
    }

    <hr />

    <p><strong>@L["SessionPage_ConnectedPlayers"] :</strong> @SessionStats.ConnectedPlayersCount</p>
    <p><strong>@L["SessionPage_AliveCharactersCount"] :</strong> @SessionStats.AliveCharactersCount</p>
    <p><strong>@L["SessionPage_TotalCharactersCount"] :</strong> @SessionStats.TotalCharactersCount</p>

    <hr />

    <h4>@L["SessionPage_GameSystemSection"]</h4>

    @if (OwnedGameSystems.Count == 0)
    {
        <p>@L["SessionPage_NoGameSystems"]</p>
        <button @onclick="GoToCreateGameSystem">@L["SessionPage_CreateGameSystem"]</button>
    }
    else
    {
        <div>
            <label>@L["SessionPage_SelectGameSystem"]</label><br />
            <select @bind="SelectedGameSystemId">
                <option value="">@L["SessionPage_NoGameSystemSelected"]</option>
                @foreach (var gameSystem in OwnedGameSystems)
                {
                    <option value="@gameSystem.Id.ToString()">@gameSystem.Name</option>
                }
            </select>
        </div>

        <button @onclick="AssignSelectedGameSystem">@L["SessionPage_AssignGameSystem"]</button>
        <button @onclick="GoToCreateGameSystem">@L["SessionPage_CreateGameSystem"]</button>

        @if (AssignedGameSystem is not null)
        {
            <p><strong>@L["SessionPage_CurrentGameSystem"] :</strong> @AssignedGameSystem.Name</p>

            @if (AssignedGameSystem.LockedToSessionId == SessionId)
            {
                <button @onclick="EditAssignedGameSystem">@L["SessionPage_EditSessionGameSystem"]</button>
            }
            else
            {
                <button @onclick="CloneAndEditAssignedGameSystem">@L["SessionPage_CloneAndEditForSession"]</button>
            }
        }
    }

    <hr />

    <h4>@L["SessionPage_SpecialRolesSection"]</h4>

    <div>
        <button @onclick="AddSpecialRole">@L["SessionPage_AddSpecialRole"]</button>
    </div>

    @if (ShowSpecialRoleEditor)
    {
        <div style="margin-top:8px;">
            <select @bind="SelectedSpecialRolePlayerSessionId">
                <option value="">@L["SessionPage_SelectPlayer"]</option>
                @foreach (var player in SpecialRoleEligiblePlayers)
                {
                    <option value="@player.Id">@player.PlayerName</option>
                }
            </select>

            <select @bind="SelectedSpecialRole">
                <option value="@SessionSpecialRole.Observer">@L["SessionSpecialRole_Observer"]</option>
                <option value="@SessionSpecialRole.Assistant">@L["SessionSpecialRole_Assistant"]</option>
            </select>

            <button @onclick="ValidateSpecialRole">@L["Common_Save"]</button>
        </div>
    }

    @if (SpecialRoleAssignments.Count == 0)
    {
        <p>@L["SessionPage_NoSpecialRoles"]</p>
    }
    else
    {
        <ul>
            @foreach (var player in SpecialRoleAssignments)
            {
                <li>
                    @player.PlayerName - @(player.SpecialRole == SessionSpecialRole.Assistant ? L["SessionSpecialRole_Assistant"] : L["SessionSpecialRole_Observer"])
                    <button @onclick="() => RemoveSpecialRole(player.Id)">@L["EditGameSystem_Delete"]</button>
                </li>
            }
        </ul>
    }

    <hr />

    <h4>@L["GameTest_GameMasterSectionTitle"]</h4>

    @if (AssignedGameSystem is null)
    {
        <p>@L["GameTest_NoGameSystemForSession"]</p>
    }
    else if (AvailableAttributes.Count == 0 && AvailableDerivedStats.Count == 0)
    {
        <p>@L["GameTest_NoAttributeAvailable"]</p>
    }
    else
    {
        <div>
            <label>@L["GameTest_TargetKind"]</label><br />
            <select @bind="NewTargetKind" @bind:after="OnTestTargetKindChanged">
                <option value="@GameTestTargetKind.BaseAttribute">@L["GameTest_TargetAttribute"]</option>
                <option value="@GameTestTargetKind.DerivedStat">@L["TestConsequence_Target_DerivedStat"]</option>
            </select>
        </div>

        <div>
            <label>@L["GameTest_Attribute"]</label><br />
            <select @bind="SelectedAttributeId">
                <option value="">@L["GameTest_SelectAttribute"]</option>
                @if (NewTargetKind == GameTestTargetKind.BaseAttribute)
                {
                    @foreach (var attributeDefinition in AvailableAttributes)
                    {
                        <option value="@attributeDefinition.Id.ToString()">@attributeDefinition.Name</option>
                    }
                }
                else
                {
                    @foreach (var derivedDefinition in AvailableDerivedStats)
                    {
                        <option value="@derivedDefinition.DerivedStatDefinitionId?.ToString()">@derivedDefinition.Name</option>
                    }
                }
            </select>
        </div>

        <div>
            <label>@L["GameTest_DiceMode"]</label><br />
            <InputSelect @bind-Value="UseSystemDefaultDice">
                <option value="true">@L["GameTest_UseSystemDefaultDice"]</option>
                <option value="false">@L["GameTest_UseCustomDice"]</option>
            </InputSelect>
        </div>

        @if (UseSystemDefaultDice)
        {
            <div>
                <strong>@L["GameTest_Dice"] :</strong>
                @($"{AssignedGameSystem.DefaultTestDiceCount}d{AssignedGameSystem.DefaultTestDiceSides}")
            </div>

            @if (AssignedGameSystem.CriticalSuccessValue.HasValue)
            {
                <div>
                    <strong>@L["GameTest_CriticalSuccessValue"] :</strong>
                    @AssignedGameSystem.CriticalSuccessValue
                </div>
            }

            @if (AssignedGameSystem.CriticalFailureValue.HasValue)
            {
                <div>
                    <strong>@L["GameTest_CriticalFailureValue"] :</strong>
                    @AssignedGameSystem.CriticalFailureValue
                </div>
            }
        }
        else
        {
            <div>
                <label>@L["GameTest_DiceCount"]</label><br />
                <input type="number" @bind="NewDiceCount" />
            </div>

            <div>
                <label>@L["GameTest_DiceSides"]</label><br />
                <input type="number" @bind="NewDiceSides" />
            </div>
        }

        @if (AssignedGameSystem.TestResolutionMode == TestResolutionMode.SuccessThreshold)
        {
            <div>
                <label>@L["GameTest_SuccessThreshold"]</label><br />
                <input type="number" @bind="NewSuccessThreshold" />
            </div>
        }

        <div>
            <label>@L["GameTest_DifficultyMode"]</label><br />
            <select @bind="NewModifierMode">
                <option value="@TestModifierMode.Bonus">@L["GameTest_Bonus"]</option>
                <option value="@TestModifierMode.Malus">@L["GameTest_Malus"]</option>
            </select>
        </div>

        <div>
            <label>@L["GameTest_DifficultyValue"]</label><br />
            <input type="number" @bind="NewDifficultyValue" />
        </div>

        <div>
            <label>@L["GameTest_TargetScope"]</label><br />
            <select @bind="NewTargetScope">
                <option value="@TestTargetScope.OnlineLivingCharacters">@L["GameTest_TargetOnlineLiving"]</option>
                <option value="@TestTargetScope.AllLivingCharacters">@L["GameTest_TargetAllLiving"]</option>
            </select>
        </div>

        <div>
            <label>@L["GameTest_TraitFilterMode"]</label><br />
            <select @bind="NewTraitFilterMode">
                <option value="@TestTraitFilterMode.AndBetweenGroups">@L["GameTest_FilterModeAnd"]</option>
                <option value="@TestTraitFilterMode.OrBetweenGroups">@L["GameTest_FilterModeOr"]</option>
            </select>
        </div>

        <h5>@L["GameTest_TraitFilters"]</h5>

        @if (AvailableTraitDefinitions.Count == 0)
        {
            <p>@L["GameTest_NoTraitFilterAvailable"]</p>
        }
        else
        {
            @foreach (var traitDefinition in AvailableTraitDefinitions)
            {
                <div style="margin-bottom: 1rem;">
                    <strong>@traitDefinition.Name</strong>

                    @if (TraitOptionsByDefinition.TryGetValue(traitDefinition.Id, out var traitOptions))
                    {
                        @foreach (var option in traitOptions)
                        {
                            <div>
                                <label>
                                    <input type="checkbox"
                                           checked="@SelectedTraitOptionIds.Contains(option.Id)"
                                           @onchange="args => ToggleTraitFilter(option.Id, args.Value)" />
                                    @option.Name
                                </label>
                            </div>
                        }
                    }
                </div>
            }
        }

        <h5>@L["GameTest_Consequences"]</h5>

        <button @onclick="AddSuccessConsequence">@L["GameTest_AddSuccessConsequence"]</button>
        <button @onclick="AddFailureConsequence">@L["GameTest_AddFailureConsequence"]</button>

        @if (ConsequenceRows.Count == 0)
        {
            @L["GameTest_NoConsequence"]
        }
        else
        {
            @for (var i = 0; i < ConsequenceRows.Count; i++)
            {
                var row = ConsequenceRows[i];

                <div style="margin-top:8px; padding:8px; border:1px solid #ccc;">
                    <div>
                        @L["GameTest_When"]
                        <select @bind="row.ApplyOn">
                            <option value="@TestConsequenceApplyOn.OnSuccess">@L["GameTest_OnSuccess"]</option>
                            <option value="@TestConsequenceApplyOn.OnFailure">@L["GameTest_OnFailure"]</option>
                            <option value="@TestConsequenceApplyOn.OnCriticalSuccess">@L["GameTest_OnCriticalSuccess"]</option>
                            <option value="@TestConsequenceApplyOn.OnCriticalFailure">@L["GameTest_OnCriticalFailure"]</option>
                        </select>
                    </div>

                    <div>
                        @L["GameTest_ConsequenceOperation"]
                        <select value="@((int)row.OperationType)" @onchange="e => ChangeConsequenceOperation(row, e.Value?.ToString())">
                            <option value="@((int)TestConsequenceOperationType.AddValue)">@L["TestConsequence_Operation_AddValue"]</option>
                            <option value="@((int)TestConsequenceOperationType.GrantTalent)">@L["TestConsequence_Operation_GrantTalent"]</option>
                            <option value="@((int)TestConsequenceOperationType.RevokeTalent)">@L["TestConsequence_Operation_RevokeTalent"]</option>
                            <option value="@((int)TestConsequenceOperationType.GrantItem)">@L["TestConsequence_Operation_GrantItem"]</option>
                            <option value="@((int)TestConsequenceOperationType.RevokeItem)">@L["TestConsequence_Operation_RevokeItem"]</option>
                        </select>
                    </div>

                    @if (row.OperationType == TestConsequenceOperationType.AddValue)
                    {
                        <div>
                            @L["GameTest_ConsequenceTargetKind"]
                            <select value="@((int)row.TargetKind)" @onchange="e => ChangeConsequenceTargetKind(row, e.Value?.ToString())">
                                <option value="@((int)TestConsequenceTargetKind.Gauge)">@L["GameTest_TargetGauge"]</option>
                                <option value="@((int)TestConsequenceTargetKind.Attribute)">@L["GameTest_TargetAttribute"]</option>
                                <option value="@((int)TestConsequenceTargetKind.DerivedStat)">@L["TestConsequence_Target_DerivedStat"]</option>
                                <option value="@((int)TestConsequenceTargetKind.Metric)">@L["TestConsequence_Target_Metric"]</option>
                            </select>
                        </div>
                    }
                    else if (row.OperationType == TestConsequenceOperationType.GrantTalent || row.OperationType == TestConsequenceOperationType.RevokeTalent)
                    {
                        row.TargetKind = TestConsequenceTargetKind.Talent;
                        <div>
                            @L["GameTest_ConsequenceTargetKind"]
                            <span>@L["TestConsequence_Target_Talent"]</span>
                        </div>
                    }
                    else
                    {
                        row.TargetKind = TestConsequenceTargetKind.Item;
                        <div>
                            @L["GameTest_ConsequenceTargetKind"]
                            <span>@L["TestConsequence_Target_Item"]</span>
                        </div>
                    }

                    <div>
                        @L["GameTest_TargetDefinition"]

                        @if (row.TargetKind == TestConsequenceTargetKind.Gauge)
                        {
                            <select @bind="row.TargetDefinitionId">
                                @foreach (var gaugeDefinition in AvailableGaugeDefinitions)
                                {
                                    <option value="@gaugeDefinition.Id">@gaugeDefinition.Name</option>
                                }
                            </select>
                        }
                        else if (row.TargetKind == TestConsequenceTargetKind.Attribute)
                        {
                            <select @bind="row.TargetDefinitionId">
                                @foreach (var attributeDefinition in AvailableAttributes)
                                {
                                    <option value="@attributeDefinition.Id">@attributeDefinition.Name</option>
                                }
                            </select>
                        }
                        else if (row.TargetKind == TestConsequenceTargetKind.DerivedStat)
                        {
                            <select @bind="row.TargetDefinitionId">
                                @foreach (var derivedDefinition in AvailableDerivedStats)
                                {
                                    <option value="@derivedDefinition.DerivedStatDefinitionId">@derivedDefinition.Name</option>
                                }
                            </select>
                        }
                        else if (row.TargetKind == TestConsequenceTargetKind.Metric)
                        {
                            <select @bind="row.TargetDefinitionId">
                                @foreach (var metricDefinition in AvailableMetrics)
                                {
                                    <option value="@metricDefinition.Id">@metricDefinition.Name</option>
                                }
                            </select>
                        }
                        else if (row.TargetKind == TestConsequenceTargetKind.Talent)
                        {
                            <select @bind="row.TargetDefinitionId">
                                @foreach (var talentDefinition in AvailableTalents)
                                {
                                    <option value="@talentDefinition.TalentDefinitionId">@talentDefinition.Name</option>
                                }
                            </select>
                        }
                        else if (row.TargetKind == TestConsequenceTargetKind.Item)
                        {
                            <select @bind="row.TargetDefinitionId">
                                @foreach (var itemDefinition in AvailableItems)
                                {
                                    <option value="@itemDefinition.ItemDefinitionId">@itemDefinition.Name</option>
                                }
                            </select>
                        }
                    </div>

                    @if (row.OperationType == TestConsequenceOperationType.AddValue)
                    {
                        <div>
                            @L["GameTest_DifficultyMode"]
                            <select @bind="row.ModifierMode">
                                <option value="@TestModifierMode.Bonus">@L["GameTest_Bonus"]</option>
                                <option value="@TestModifierMode.Malus">@L["GameTest_Malus"]</option>
                            </select>
                        </div>

                        <div>
                            @L["GameTest_ConsequenceValueMode"]
                            <select @bind="row.ValueMode">
                                <option value="@ModifierValueMode.Fixed">@L["EditGameSystem_ModifierValueMode_Fixed"]</option>
                                <option value="@ModifierValueMode.Metric">@L["EditGameSystem_ModifierValueMode_Metric"]</option>
                            </select>
                        </div>

                        @if (row.ValueMode == ModifierValueMode.Metric)
                        {
                            <div>
                                @L["Common_SourceMetric"]
                                <select @bind="row.SourceMetricId">
                                    @foreach (var metricDefinition in AvailableMetrics)
                                    {
                                        <option value="@metricDefinition.Id">@metricDefinition.Name</option>
                                    }
                                </select>
                            </div>
                        }
                        else
                        {
                            <div>
                                @L["GameTest_DifficultyValue"]
                                <input type="number" @bind="row.Value" />
                            </div>
                        }
                    }

                    <div>
                        <button @onclick="() => RemoveConsequenceRow(row.RowId)">@L["Common_Remove"]</button>
                    </div>
                </div>
            }
        }

        @if (ActiveTest is null || ActiveTest.IsClosed)
        {
            <button @onclick="CreateGameTest">@L["GameTest_Create"]</button>
        }

        @if (ActiveTest is not null)
        {
            <hr />
            <p><strong>@L["GameTest_Target"] :</strong> @ActiveTest.AttributeName</p>
            <p><strong>@L["GameTest_Dice"] :</strong> @($"{ActiveTest.DiceCount}d{ActiveTest.DiceSides}")</p>
            <p><strong>@L["GameTest_DiceMode"] :</strong> @(ActiveTest.UseSystemDefaultDice? L["GameTest_UseSystemDefaultDice"] : L["GameTest_UseCustomDice"])</p>
            @if (ActiveTest.UseSystemDefaultDice && ActiveTest.CriticalSuccessValue.HasValue)
            {
                <p><strong>@L["GameTest_CriticalSuccessValue"] :</strong> @ActiveTest.CriticalSuccessValue</p>
            }
            @if (ActiveTest.UseSystemDefaultDice && ActiveTest.CriticalFailureValue.HasValue)
            {
                <p><strong>@L["GameTest_CriticalFailureValue"] :</strong> @ActiveTest.CriticalFailureValue</p>
            }

            @if (ActiveTest.ResolutionMode == TestResolutionMode.SuccessThreshold)
            {
                <p><strong>@L["GameTest_SuccessThreshold"] :</strong> @ActiveTest.SuccessThreshold</p>
            }

            <p>
                <strong>@L["GameTest_DifficultySummary"] :</strong>
                @(ActiveTest.ModifierMode == TestModifierMode.Bonus ? L["GameTest_Bonus"] : L["GameTest_Malus"])
                @(" ")
                @ActiveTest.DifficultyValue
            </p>

            <p>
                <strong>@L["GameTest_TargetScope"] :</strong>
                @(ActiveTest.TargetScope == TestTargetScope.OnlineLivingCharacters
                    ? L["GameTest_TargetOnlineLiving"]
                    : L["GameTest_TargetAllLiving"])
            </p>

            <p>
                <strong>@L["GameTest_TraitFilterMode"] :</strong>
                @(ActiveTest.TraitFilterMode == TestTraitFilterMode.AndBetweenGroups
                    ? L["GameTest_FilterModeAnd"]
                    : L["GameTest_FilterModeOr"])
            </p>

            @if (ActiveTest.IsClosed)
            {
                <p><em>@L["GameTest_LastTestPerformed"]</em></p>
            }

            <p><strong>@L["GameTest_TargetCount"] :</strong> @ActiveTest.TargetCount</p>
            <p><strong>@L["GameTest_RolledCount"] :</strong> @ActiveTest.RolledCount</p>
            <p><strong>@L["GameTest_SuccessCount"] :</strong> @ActiveTest.SuccessCount</p>
            <p><strong>@L["GameTest_FailureCount"] :</strong> @ActiveTest.FailureCount</p>
            <p><strong>@L["GameTest_CriticalSuccessCount"] :</strong> @ActiveTest.CriticalSuccessCount</p>
            <p><strong>@L["GameTest_CriticalFailureCount"] :</strong> @ActiveTest.CriticalFailureCount</p>
            <p><strong>@L["GameTest_SuccessRate"] :</strong> @($"{ActiveTest.SuccessRatePercent:F1}%")</p>
            <p><strong>@L["GameTest_BestRoll"] :</strong> @(ActiveTest.BestDiceTotal?.ToString() ?? "-")</p>
            <p><strong>@L["GameTest_WorstRoll"] :</strong> @(ActiveTest.WorstDiceTotal?.ToString() ?? "-")</p>
            <p><strong>@L["GameTest_AverageRoll"] :</strong> @(ActiveTest.AverageDiceTotal?.ToString("F2") ?? "-")</p>

            @if (ActiveTest is not null)
            {
                @if (!ConfirmRollbackVisible)
                {
                    <button @onclick="ShowRollbackConfirmation">@L["GameTest_RollbackLastTest"]</button>
                }
                else
                {
                    <p>@L["GameTest_RollbackConfirmQuestion"]</p>
                    <button @onclick="RollbackLatestTestConfirmed">@L["Common_Yes"]</button>
                    <button @onclick="CancelRollback">@L["Common_No"]</button>
                }
            }

            <h5>@L["GameTest_IndividualResults"]</h5>

            <ul>
                @foreach (var resultLine in ActiveTest?.Results ?? Enumerable.Empty<GameMasterGameTestResultLineDto>())
                {
                    <li style="margin-bottom: 1rem;">
                        <strong>@resultLine.CharacterName</strong> (@resultLine.PlayerName)
                        -
                        @if (!resultLine.HasRolled)
                        {
                            <span>@L["GameTest_Pending"]</span>
                        }
                        else
                        {
                            <span>@GetOutcomeLabel(resultLine.Outcome)</span>

                            <div>@L["GameTest_DiceResults"] : @string.Join(" - ", resultLine.DiceResults)</div>
                            <div>@L["GameTest_DiceTotal"] : @resultLine.DiceTotal</div>
                            <div>@L["GameTest_AttributeValue"] : @resultLine.AttributeValue</div>
                            <div>@L["GameTest_EffectiveAttributeValue"] : @resultLine.EffectiveAttributeValue</div>
                            <div>@L["GameTest_FinalValue"] : @resultLine.FinalValue</div>

                            @if (resultLine.IsAutoRolled)
                            {
                                <div>@L["GameTest_AutoRolled"]</div>
                            }
                        }
                    </li>
                }
            </ul>
        }
    }

    <hr />

    <h4>@L["Poll_GameMasterSectionTitle"]</h4>

    @if (LatestPoll is null || LatestPoll.IsClosed)
    {
        <div>
            <label>@L["Poll_Question"]</label><br />
            <input @bind="NewPollQuestion" />
        </div>

        <h5>@L["Poll_Options"]</h5>

        @for (var i = 0; i < NewPollOptions.Count; i++)
        {
            var optionIndex = i;
            var optionRow = NewPollOptions[optionIndex];

            <div style="margin-bottom: 1rem; border:1px solid #ccc; padding:0.5rem;">
                <input @bind="NewPollOptions[optionIndex].Label" placeholder="@L["Poll_OptionLabel"]" />

                @if (NewPollOptions.Count > 2)
                {
                    <button @onclick="() => RemovePollOption(optionIndex)">
                        @L["Common_Remove"]
                    </button>
                }

                <div style="margin-top: 0.5rem;">
                    <strong>@L["Poll_OptionConsequences"]</strong>
                </div>

                <button @onclick="() => AddPollOptionConsequence(optionIndex)">
                    @L["Poll_AddOptionConsequence"]
                </button>

                @foreach (var consequence in optionRow.Consequences)
                {
                    <div style="margin-top:8px; margin-left:20px; padding:8px; border:1px solid #ccc;">
                        <div>
                            @L["Poll_ConsequenceOperation"]
                            <select @bind="consequence.OperationType">
                                <option value="@TestConsequenceOperationType.AddValue">@L["TestConsequence_Operation_AddValue"]</option>
                                <option value="@TestConsequenceOperationType.GrantTalent">@L["TestConsequence_Operation_GrantTalent"]</option>
                                <option value="@TestConsequenceOperationType.RevokeTalent">@L["TestConsequence_Operation_RevokeTalent"]</option>
                                <option value="@TestConsequenceOperationType.GrantItem">@L["TestConsequence_Operation_GrantItem"]</option>
                                <option value="@TestConsequenceOperationType.RevokeItem">@L["TestConsequence_Operation_RevokeItem"]</option>
                            </select>
                        </div>

                        @if (consequence.OperationType == TestConsequenceOperationType.AddValue)
                        {
                            <div>
                                @L["GameTest_ConsequenceTargetKind"]
                                <select @bind="consequence.TargetKind">
                                    <option value="@TestConsequenceTargetKind.Gauge">@L["GameTest_TargetGauge"]</option>
                                    <option value="@TestConsequenceTargetKind.Attribute">@L["GameTest_TargetAttribute"]</option>
                                    <option value="@TestConsequenceTargetKind.DerivedStat">@L["TestConsequence_Target_DerivedStat"]</option>
                                    <option value="@TestConsequenceTargetKind.Metric">@L["TestConsequence_Target_Metric"]</option>
                                </select>
                            </div>
                        }
                        else if (consequence.OperationType == TestConsequenceOperationType.GrantTalent || consequence.OperationType == TestConsequenceOperationType.RevokeTalent)
                        {
                            consequence.TargetKind = TestConsequenceTargetKind.Talent;
                            <div>
                                @L["GameTest_ConsequenceTargetKind"]
                                <span>@L["TestConsequence_Target_Talent"]</span>
                            </div>
                        }
                        else
                        {
                            consequence.TargetKind = TestConsequenceTargetKind.Item;
                            <div>
                                @L["GameTest_ConsequenceTargetKind"]
                                <span>@L["TestConsequence_Target_Item"]</span>
                            </div>
                        }

                        <div>
                            @L["GameTest_TargetDefinition"]

                            @if (consequence.TargetKind == TestConsequenceTargetKind.Gauge)
                            {
                                <select @bind="consequence.TargetDefinitionId">
                                    @foreach (var gaugeDefinition in AvailableGaugeDefinitions)
                                    {
                                        <option value="@gaugeDefinition.Id">@gaugeDefinition.Name</option>
                                    }
                                </select>
                            }
                            else if (consequence.TargetKind == TestConsequenceTargetKind.Attribute)
                            {
                                <select @bind="consequence.TargetDefinitionId">
                                    @foreach (var attributeDefinition in AvailableAttributes)
                                    {
                                        <option value="@attributeDefinition.Id">@attributeDefinition.Name</option>
                                    }
                                </select>
                            }
                            else if (consequence.TargetKind == TestConsequenceTargetKind.DerivedStat)
                            {
                                <select @bind="consequence.TargetDefinitionId">
                                    @foreach (var derivedDefinition in AvailableDerivedStats)
                                    {
                                        <option value="@derivedDefinition.DerivedStatDefinitionId">@derivedDefinition.Name</option>
                                    }
                                </select>
                            }
                            else if (consequence.TargetKind == TestConsequenceTargetKind.Metric)
                            {
                                <select @bind="consequence.TargetDefinitionId">
                                    @foreach (var metricDefinition in AvailableMetrics)
                                    {
                                        <option value="@metricDefinition.Id">@metricDefinition.Name</option>
                                    }
                                </select>
                            }
                            else if (consequence.TargetKind == TestConsequenceTargetKind.Talent)
                            {
                                <select @bind="consequence.TargetDefinitionId">
                                    @foreach (var talentDefinition in AvailableTalents)
                                    {
                                        <option value="@talentDefinition.TalentDefinitionId">@talentDefinition.Name</option>
                                    }
                                </select>
                            }
                            else if (consequence.TargetKind == TestConsequenceTargetKind.Item)
                            {
                                <select @bind="consequence.TargetDefinitionId">
                                    @foreach (var itemDefinition in AvailableItems)
                                    {
                                        <option value="@itemDefinition.ItemDefinitionId">@itemDefinition.Name</option>
                                    }
                                </select>
                            }
                        </div>

                        @if (consequence.OperationType == TestConsequenceOperationType.AddValue)
                        {
                            <div>
                                @L["GameTest_DifficultyMode"]
                                <select @bind="consequence.ModifierMode">
                                    <option value="@TestModifierMode.Bonus">@L["GameTest_Bonus"]</option>
                                    <option value="@TestModifierMode.Malus">@L["GameTest_Malus"]</option>
                                </select>
                            </div>

                            <div>
                                @L["GameTest_ConsequenceValueMode"]
                                <select @bind="consequence.ValueMode">
                                    <option value="@ModifierValueMode.Fixed">@L["EditGameSystem_ModifierValueMode_Fixed"]</option>
                                    <option value="@ModifierValueMode.Metric">@L["EditGameSystem_ModifierValueMode_Metric"]</option>
                                </select>
                            </div>

                            @if (consequence.ValueMode == ModifierValueMode.Metric)
                            {
                                <div>
                                    @L["Common_SourceMetric"]
                                    <select @bind="consequence.SourceMetricId">
                                        @foreach (var metricDefinition in AvailableMetrics)
                                        {
                                            <option value="@metricDefinition.Id">@metricDefinition.Name</option>
                                        }
                                    </select>
                                </div>
                            }
                            else
                            {
                                <div>
                                    @L["GameTest_DifficultyValue"]
                                    <input type="number" @bind="consequence.Value" />
                                </div>
                            }
                        }

                        <div>
                            <button @onclick="() => optionRow.Consequences.Remove(consequence)">@L["Common_Remove"]</button>
                        </div>
                    </div>
                }
            </div>
        }

        <button @onclick="AddPollOption">@L["Poll_AddOption"]</button>

        <h5>@L["Poll_VoteWeightMode"]</h5>

        <div>
            <label>@L["Poll_VoteWeightMode"]</label><br />
            <select @bind="SelectedPollVoteWeightMode">
                <option value="@PollVoteWeightMode.FixedOne">@L["Poll_VoteWeightModeFixedOne"]</option>
                <option value="@PollVoteWeightMode.Metric">@L["Poll_VoteWeightModeMetric"]</option>
            </select>
        </div>

        @if (SelectedPollVoteWeightMode == PollVoteWeightMode.Metric)
        {
            <div style="margin-top:0.5rem;">
                <label>@L["Poll_VoteWeightMetric"]</label><br />
                <select @bind="SelectedPollMetricId">
                    <option value="">@L["Poll_SelectMetric"]</option>
                    @foreach (var metric in AvailableMetrics)
                    {
                        <option value="@metric.Id">@metric.Name</option>
                    }
                </select>
            </div>

            <p>@L["Poll_VoteWeightMetricHelp"]</p>
        }

        <button @onclick="CreatePoll">@L["Poll_Create"]</button>
    }

    @if (RecentPolls.Count > 0)
    {
        <div>
            <label>@L["Poll_History"]</label><br />
            <select @bind="SelectedPollHistoryId" @bind:after="LoadPollHistory">
                <option value="">@L["Poll_CurrentOrLatest"]</option>
                @foreach (var poll in RecentPolls)
                {
                    <option value="@poll.PollId">@poll.Question</option>
                }
            </select>
        </div>
    }

    @if (LatestPoll is not null)
    {
        <hr />

        <p><strong>@L["Poll_Question"] :</strong> @LatestPoll.Question</p>
        <p><strong>@L["Poll_TotalVotes"] :</strong> @LatestPoll.TotalVotes</p>
        <p><strong>@L["Poll_TotalWeightedVotes"] :</strong> @LatestPoll.TotalWeightedVotes.ToString("F2")</p>
        <p>
            <strong>@L["Poll_Participation"] :</strong>
            @LatestPoll.TotalVotes / @LatestPoll.OnlinePlayersCount
            (@($"{LatestPoll.ParticipationPercent:F1}%"))
        </p>

        @if (LatestPoll.IsClosed)
        {
            <p><em>@L["Poll_LastPoll"]</em></p>

            @if (CanUndoLatestPollConsequences)
            {
                @if (!ConfirmUndoPollConsequencesVisible)
                {
                    <button @onclick="ShowUndoPollConsequencesConfirmation">@L["Poll_UndoConsequences"]</button>
                }
                else
                {
                    <p>@L["Poll_UndoConsequencesConfirmQuestion"]</p>
                    <button @onclick="UndoLatestPollConsequencesConfirmed">@L["Common_Yes"]</button>
                    <button @onclick="CancelUndoPollConsequences">@L["Common_No"]</button>
                }
            }
        }
        else
        {
            <button @onclick="ClosePoll">@L["Poll_Close"]</button>
            <button @onclick="ToggleLivePollResults">
                @(ShowLivePollResults? L["Poll_HideLiveResults"] : L["Poll_ShowLiveResults"])
            </button>
        }

        @if (LatestPoll.IsClosed || ShowLivePollResults)
        {
            <ul>
                @foreach (var option in LatestPoll.Options)
                {
                    //            <li>
                    //               @option.Label : @option.VoteCount (@($"{option.VotePercent:F1}%"))
                    //           </li>
                    <li>
                        @option.Label :
                        @option.VoteCount (@($"{option.VotePercent:F1}%"))
                        -
                        @option.WeightedVoteTotal.ToString("F2") (@($"{option.WeightedVotePercent:F1}%"))
                    </li>
                }
            </ul>
        }

        @if (LatestPoll.Votes.Count > 0)
        {
            <button @onclick="TogglePollVoteDetails">
                @(ShowPollVoteDetails? L["Poll_HideVoteDetails"] : L["Poll_ShowVoteDetails"])
            </button>

            @if (ShowPollVoteDetails)
            {
                <h5>@L["Poll_VoteDetails"]</h5>
                <ul>
                    @foreach (var voteLine in LatestPoll.Votes)
                    {
                        //       <li>@voteLine.PlayerName - @voteLine.CharacterName : @voteLine.OptionLabel</li>
                        <li>@voteLine.PlayerName - @voteLine.CharacterName : @voteLine.OptionLabel (@voteLine.VoteWeight.ToString("F2"))</li>
                    }
                </ul>
            }
        }

        <p>
            <strong>@L["Poll_VoteWeightMode"] :</strong>
            @(LatestPoll.VoteWeightMode == PollVoteWeightMode.Metric
                ? $"{L["Poll_VoteWeightModeMetric"]} - {LatestPoll.MetricName}"
                : L["Poll_VoteWeightModeFixedOne"])
        </p>

        @if (LatestPoll.WeightRules.Count > 0)
        {
            <h5>@L["Poll_WeightRules"]</h5>
            <ul>
                @foreach (var rule in LatestPoll.WeightRules)
                {
                    <li>@rule.TraitDefinitionName : @rule.TraitOptionName => +@rule.WeightBonus.ToString("F2")</li>
                }
            </ul>
        }

        @if (LatestPoll.Consequences.Count > 0)
        {
            <h5>@L["Poll_OptionConsequences"]</h5>
            <ul>
                @foreach (var consequence in LatestPoll.Consequences)
                {
                    <li>
                        @consequence.OptionLabel :
                        @consequence.TargetName
                        @(" - ")
                        @if (consequence.OperationType == TestConsequenceOperationType.AddValue)
                        {
                            @if (consequence.ValueMode == ModifierValueMode.Metric)
                            {
                                <span>@(consequence.ModifierMode == TestModifierMode.Bonus ? L["GameTest_Bonus"] : L["GameTest_Malus"])</span>
                                @(" ")
                                <span>@L["Common_SourceMetric"] : @consequence.SourceMetricName</span>
                            }
                            else
                            {
                                <span>@(consequence.ModifierMode == TestModifierMode.Bonus ? L["GameTest_Bonus"] : L["GameTest_Malus"])</span>
                                @(" ")
                                <span>@consequence.Value</span>
                            }
                        }
                        else
                        {
                            <span>@consequence.OperationType</span>
                        }
                    </li>
                }
            </ul>
        }
    }

    <hr />

    <h4>@L["SessionPage_CharactersSection"]</h4>

    <div style="margin-bottom:12px;">
        <button @onclick="CreateNpc">@L["SessionPage_CreateNpc"]</button>
    </div>

    <div>
        <label>
            <input type="checkbox" @bind="ShowPlayerName" />
            @L["SessionPage_ShowPlayerName"]
        </label>
    </div>

    <div>
        <label>
            <input type="checkbox" @bind="ShowAttributes" />
            @L["SessionPage_ShowAttributes"]
        </label>
    </div>

    <div>
        <label>
            <input type="checkbox" @bind="ShowTraits" />
            @L["SessionPage_ShowTraits"]
        </label>
    </div>

    <div>
        <label>
            <input type="checkbox" @bind="ShowGauges" />
            @L["SessionPage_ShowGauges"]
        </label>
    </div>

    <div>
        <label>
            <input type="checkbox" @bind="IncludeOffline" @bind:after="RefreshCharacterSection" />
            @L["SessionPage_ShowOfflineCharacters"]
        </label>
    </div>

    <div>
        <label>
            <input type="checkbox" @bind="IncludeDead" @bind:after="RefreshCharacterSection" />
            @L["SessionPage_ShowDeadCharacters"]
        </label>
    </div>

    <div>
        <label>
            <input type="checkbox" @bind="IncludeNpcs" @bind:after="RefreshCharacterSection" />
            @L["SessionPage_ShowNpcs"]
        </label>
    </div>

    @if (Characters.Count == 0)
    {
        <p>@L["SessionPage_NoCharactersToDisplay"]</p>
    }
    else
    {
        <ul>
            @foreach (var character in Characters)
            {
                <li style="margin-bottom: 1rem;">
                    <button @onclick="() => LoadCharacterDetails(character.CharacterId)">
                        @character.CharacterName
                    </button>

                    <span>
                        - @(character.IsAlive? L["Common_Alive"] : L["Common_Dead"])
                        - @(character.IsOnline? L["Common_Online"] : L["Common_Offline"])
                        @if (character.IsNpc)
                        {
                            <text> - @L["Common_Npc"]</text>
                        }
                    </span>

                    @if (ShowPlayerName)
                    {
                        <div><strong>@L["SessionPage_PlayerName"] :</strong> @character.PlayerName</div>
                    }

                    @if (ShowAttributes && character.Attributes.Count > 0)
                    {
                        <div>
                            <strong>@L["PlayerRoom_Attributes"] :</strong>
                            @string.Join(" | ", character.Attributes.Select(a => $"{a.Name}: {a.Value}"))
                        </div>
                    }

                    @if (ShowTraits && character.Traits.Count > 0)
                    {
                        <div>
                            <strong>@L["PlayerRoom_Traits"] :</strong>
                            @string.Join(" | ", character.Traits.Select(t => $"{t.TraitName}: {t.OptionName}"))
                        </div>
                    }

                    @if (ShowGauges && character.Gauges.Count > 0)
                    {
                        <div>
                            <strong>@L["PlayerRoom_Gauges"] :</strong>
                            @string.Join(" | ", character.Gauges.Select(g => $"{g.Name}: {g.Value}/{g.MaxValue}"))
                        </div>
                    }
                </li>
            }
        </ul>
    }

    @if (SelectedCharacterSheet is not null)
    {
        <hr />
        <h4>@L["SessionPage_SelectedCharacterSheet"]</h4>
        <button @onclick="EditSelectedCharacter">@L["SessionPage_EditCharacter"]</button>
        <p><strong>@L["PlayerRoom_CharacterName"] :</strong> @SelectedCharacterSheet.Name</p>
        <p><strong>@L["PlayerRoom_CharacterStatus"] :</strong> @(SelectedCharacterSheet.IsAlive? L["Common_Alive"] : L["Common_Dead"])</p>

        @if (!string.IsNullOrWhiteSpace(SelectedCharacterSheet.Biography))
        {
            <p><strong>@L["PlayerRoom_CharacterBiography"] :</strong> @SelectedCharacterSheet.Biography</p>
        }

        <h5>@L["PlayerRoom_Attributes"]</h5>
        <ul>
            @foreach (var attributeLine in SelectedCharacterSheet.Attributes)
            {
                <li>@attributeLine.Name : @attributeLine.Value</li>
            }
        </ul>

        @if (SelectedCharacterSheet.DerivedStats != null && SelectedCharacterSheet.DerivedStats.Count > 0)
        {
            <h5>@L["PlayerRoom_DerivedStats"]</h5>
            <ul>
                @foreach (var derivedLine in SelectedCharacterSheet.DerivedStats)
                {
                    <li>@derivedLine.Name : @derivedLine.Value</li>
                }
            </ul>
        }

        <h5>@L["PlayerRoom_Traits"]</h5>
        <ul>
            @foreach (var traitLine in SelectedCharacterSheet.Traits)
            {
                <li>@traitLine.TraitName : @traitLine.OptionName</li>
            }
        </ul>

        @if (SelectedCharacterSheet.Talents != null && SelectedCharacterSheet.Talents.Count > 0)
        {
            <h5>@L["EditCharacter_Talents"]</h5>
            <ul>
                @foreach (var talentLine in SelectedCharacterSheet.Talents)
                {
                    <li>@talentLine.Name</li>
                }
            </ul>
        }

        @if (SelectedCharacterSheet.Items != null && SelectedCharacterSheet.Items.Count > 0)
        {
            <h5>@L["EditCharacter_Items"]</h5>
            <ul>
                @foreach (var itemLine in SelectedCharacterSheet.Items)
                {
                    <li>@itemLine.Name</li>
                }
            </ul>
        }

        <h5>@L["PlayerRoom_Gauges"]</h5>
        <ul>
            @foreach (var gaugeLine in SelectedCharacterSheet.Gauges)
            {
                <li>@gaugeLine.Name : @gaugeLine.Value / @gaugeLine.MaxValue</li>
            }
        </ul>
    }

    @if (!string.IsNullOrWhiteSpace(Message))
    {
        <p>@Message</p>
    }

    <hr />

    <p><strong>@L["SessionPage_SessionId"] :</strong> @SessionId</p>
}

@code {
    [Parameter] public Guid SessionId { get; set; }

    private HubConnection? hubConnection;

    private DomainSession? CurrentSession;
    private GameSystem? AssignedGameSystem;
    private List<GameSystem> OwnedGameSystems = new();
    private List<AttributeDefinition> AvailableAttributes = new();
    private List<SessionCharacterSummaryDto> Characters = new();
    private CharacterSheetDto? SelectedCharacterSheet;
    private SessionPublicStatsDto SessionStats = new();
    private GameMasterActiveGameTestDto? ActiveTest;

    private List<TraitDefinition> AvailableTraitDefinitions = new();
    private Dictionary<Guid, List<TraitOption>> TraitOptionsByDefinition = new();
    private List<GaugeDefinition> AvailableGaugeDefinitions = new();
    private List<MetricDefinition> AvailableMetrics = new();
    private List<EditableDerivedStatDefinitionDto> AvailableDerivedStats = new();
    private List<EditableTalentDefinitionDto> AvailableTalents = new();
    private List<EditableItemDefinitionDto> AvailableItems = new();
    private List<PlayerSession> SpecialRoleEligiblePlayers = new();
    private List<PlayerSession> SpecialRoleAssignments = new();
    private string SelectedSpecialRolePlayerSessionId = string.Empty;
    private SessionSpecialRole SelectedSpecialRole = SessionSpecialRole.Observer;
    private bool ShowSpecialRoleEditor;

    private TestModifierMode NewModifierMode = TestModifierMode.Bonus;
    private int NewDifficultyValue = 0;
    private TestTargetScope NewTargetScope = TestTargetScope.OnlineLivingCharacters;

    private HashSet<Guid> SelectedTraitOptionIds = new();
    private List<ConsequenceRowModel> ConsequenceRows = new();

    private bool IsLoaded;
    private bool ShowSessionPassword;

    private bool ShowPlayerName;
    private bool ShowAttributes;
    private bool ShowTraits;
    private bool ShowGauges;
    private bool IncludeOffline;
    private bool IncludeDead;
    private bool IncludeNpcs;

    private Guid CurrentUserId;
    private string CurrentUsername = string.Empty;
    private string JoinUrl = string.Empty;
    private string Message = string.Empty;
    private string SelectedGameSystemId = string.Empty;

    private string SelectedAttributeId = string.Empty;
    private GameTestTargetKind NewTargetKind = GameTestTargetKind.BaseAttribute;
    private bool UseSystemDefaultDice = true;
    private int NewDiceCount = 1;
    private int NewDiceSides = 100;
    private int? NewSuccessThreshold;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        var userIdValue = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        CurrentUsername = user.Identity?.Name ?? string.Empty;

        if (!string.IsNullOrWhiteSpace(userIdValue))
        {
            CurrentUserId = Guid.Parse(userIdValue);
        }

        await LoadSessionData();

        if (CurrentSession is not null && !string.IsNullOrWhiteSpace(CurrentUsername))
        {
            JoinUrl = $"{Navigation.BaseUri}{CurrentUsername}/{CurrentSession.SessionSlug}";
        }

        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/sessionhub"))
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On("PresenceChanged", async () =>
        {
            await InvokeAsync(async () =>
            {
                await RefreshSessionVisuals();
                StateHasChanged();
            });
        });

        hubConnection.On("CharacterStateChanged", async () =>
        {
            await InvokeAsync(async () =>
            {
                await RefreshSessionVisuals();
                StateHasChanged();
            });
        });

        hubConnection.On("TestChanged", async () =>
        {
            await InvokeAsync(async () =>
            {
                await LoadActiveTest();
                StateHasChanged();
            });
        });

        hubConnection.On("PollChanged", async () =>
        {
            await InvokeAsync(async () =>
            {
                await LoadLatestPoll();
                StateHasChanged();
            });
        });

        await hubConnection.StartAsync();
        await hubConnection.SendAsync("JoinSessionGroup", SessionId.ToString());
        await hubConnection.SendAsync("JoinPlayerPresence", SessionId.ToString(), Guid.NewGuid().ToString(), true);

        IsLoaded = true;
    }

    private async Task LoadSessionData()
    {
        CurrentSession = await SessionService.GetSessionByIdAsync(SessionId);
        OwnedGameSystems = await GameSystemService.GetGameSystemsByOwnerAsync(CurrentUserId);

        AssignedGameSystem = null;
        AvailableAttributes.Clear();
        AvailableTraitDefinitions.Clear();
        TraitOptionsByDefinition.Clear();
        AvailableGaugeDefinitions.Clear();
        AvailableMetrics.Clear();
        AvailableDerivedStats.Clear();
        AvailableTalents.Clear();
        AvailableItems.Clear();
        SelectedGameSystemId = string.Empty;

        SpecialRoleEligiblePlayers = await SessionService.GetEligibleSpecialRolePlayersAsync(SessionId, CurrentUserId);
        SpecialRoleAssignments = await SessionService.GetPlayersWithSpecialRolesAsync(SessionId, CurrentUserId);

        if (CurrentSession?.GameSystemId is Guid gameSystemId)
        {
            AssignedGameSystem = await GameSystemService.GetGameSystemByIdAsync(gameSystemId, CurrentUserId);

            if (AssignedGameSystem is not null)
            {
                AvailableAttributes = await GameSystemService.GetAttributeDefinitionsAsync(AssignedGameSystem.Id, CurrentUserId);
                AvailableTraitDefinitions = await GameSystemService.GetTraitDefinitionsAsync(AssignedGameSystem.Id, CurrentUserId);
                AvailableGaugeDefinitions = await GameSystemService.GetGaugeDefinitionsAsync(AssignedGameSystem.Id, CurrentUserId);
                AvailableMetrics = await GameSystemService.GetMetricDefinitionsAsync(AssignedGameSystem.Id, CurrentUserId);

                var editor = await GameSystemService.GetGameSystemEditorAsync(AssignedGameSystem.Id, CurrentUserId);
                if (editor is not null)
                {
                    AvailableDerivedStats = editor.DerivedStats;
                    AvailableTalents = editor.Talents;
                    AvailableItems = editor.Items;
                }

                NewDiceCount = AssignedGameSystem.DefaultTestDiceCount;
                NewDiceSides = AssignedGameSystem.DefaultTestDiceSides;
                UseSystemDefaultDice = true;
                SelectedAttributeId = AvailableAttributes.FirstOrDefault()?.Id.ToString() ?? AvailableDerivedStats.FirstOrDefault()?.DerivedStatDefinitionId?.ToString() ?? string.Empty;

                foreach (var traitDefinition in AvailableTraitDefinitions)
                {
                    var options = await GameSystemService.GetTraitOptionsAsync(traitDefinition.Id, CurrentUserId);
                    TraitOptionsByDefinition[traitDefinition.Id] = options;
                }

                if (AssignedGameSystem.LockedToSessionId == null)
                {
                    SelectedGameSystemId = AssignedGameSystem.Id.ToString();
                }
            }
        }

        await RefreshSessionVisuals();
        await LoadActiveTest();
        await LoadLatestPoll();
    }

    private async Task RefreshSessionVisuals()
    {
        SessionStats = await CharacterService.GetSessionPublicStatsAsync(SessionId);
        Characters = await CharacterService.GetSessionCharacterSummariesAsync(SessionId, IncludeOffline, IncludeDead, IncludeNpcs);

        if (SelectedCharacterSheet is not null)
        {
            SelectedCharacterSheet = await CharacterService.GetCharacterSheetForSessionAsync(SessionId, SelectedCharacterSheet.CharacterId);
        }
    }

    private async Task LoadActiveTest()
    {
        ActiveTest = await GameTestService.GetActiveGameTestForSessionAsync(SessionId);
    }

    private async Task RefreshCharacterSection()
    {
        await RefreshSessionVisuals();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadCharacterDetails(Guid characterId)
    {
        SelectedCharacterSheet = await CharacterService.GetCharacterSheetForSessionAsync(SessionId, characterId);
    }

    private void ToggleSessionPasswordVisibility()
    {
        ShowSessionPassword = !ShowSessionPassword;
    }

    private void GoToCreateGameSystem()
    {
        Navigation.NavigateTo("/mj/gamesystems");
    }

    private void AddSpecialRole()
    {
        ShowSpecialRoleEditor = true;

        if (string.IsNullOrWhiteSpace(SelectedSpecialRolePlayerSessionId) && SpecialRoleEligiblePlayers.Count > 0)
        {
            SelectedSpecialRolePlayerSessionId = SpecialRoleEligiblePlayers.First().Id.ToString();
        }
    }

    private async Task ValidateSpecialRole()
    {
        try
        {
            Message = string.Empty;

            if (string.IsNullOrWhiteSpace(SelectedSpecialRolePlayerSessionId))
            {
                Message = L["SessionPage_SelectPlayer"];
                return;
            }

            await SessionService.AssignSpecialRoleAsync(
                SessionId,
                CurrentUserId,
                Guid.Parse(SelectedSpecialRolePlayerSessionId),
                SelectedSpecialRole);

            ShowSpecialRoleEditor = false;
            await LoadSessionData();
        }
        catch (Exception ex)
        {
            Message = $"{L["Common_Error"]} : {ex.Message}";
        }
    }

    private async Task RemoveSpecialRole(Guid playerSessionId)
    {
        try
        {
            Message = string.Empty;
            await SessionService.RemoveSpecialRoleAsync(SessionId, CurrentUserId, playerSessionId);
            await LoadSessionData();
        }
        catch (Exception ex)
        {
            Message = $"{L["Common_Error"]} : {ex.Message}";
        }
    }

    private async Task AssignSelectedGameSystem()
    {
        try
        {
            Message = string.Empty;

            if (string.IsNullOrWhiteSpace(SelectedGameSystemId))
            {
                Message = L["SessionPage_SelectGameSystemRequired"];
                return;
            }

            var gameSystemId = Guid.Parse(SelectedGameSystemId);

            await SessionService.AssignGameSystemToSessionAsync(SessionId, CurrentUserId, gameSystemId);

            await LoadSessionData();
            Message = L["SessionPage_GameSystemAssigned"];
        }
        catch (Exception ex)
        {
            Message = $"{L["Common_Error"]} : {ex.Message}";
        }
    }

    private async Task CreateGameTest()
    {
        try
        {
            Message = string.Empty;

            if (string.IsNullOrWhiteSpace(SelectedAttributeId))
            {
                Message = L["GameTest_AttributeRequired"];
                return;
            }

            var filterGroups = new List<GameTestTraitFilterGroupDto>();

            foreach (var traitDefinition in AvailableTraitDefinitions)
            {
                if (!TraitOptionsByDefinition.TryGetValue(traitDefinition.Id, out var traitOptions))
                    continue;

                var selectedOptionIds = traitOptions
                    .Where(o => SelectedTraitOptionIds.Contains(o.Id))
                    .Select(o => o.Id)
                    .ToList();

                if (selectedOptionIds.Count > 0)
                {
                    filterGroups.Add(new GameTestTraitFilterGroupDto
                    {
                        TraitDefinitionId = traitDefinition.Id,
                        TraitDefinitionName = traitDefinition.Name,
                        SelectedOptionIds = selectedOptionIds
                    });
                }
            }

            var request = new GameTestCreateRequestDto
            {
                TargetKind = NewTargetKind,
                TargetDefinitionId = Guid.Parse(SelectedAttributeId),
                UseSystemDefaultDice = UseSystemDefaultDice,
                DiceCount = UseSystemDefaultDice ? AssignedGameSystem?.DefaultTestDiceCount ?? NewDiceCount : NewDiceCount,
                DiceSides = UseSystemDefaultDice ? AssignedGameSystem?.DefaultTestDiceSides ?? NewDiceSides : NewDiceSides,
                CriticalSuccessValue = UseSystemDefaultDice ? AssignedGameSystem?.CriticalSuccessValue : null,
                CriticalFailureValue = UseSystemDefaultDice ? AssignedGameSystem?.CriticalFailureValue : null,
                SuccessThreshold = NewSuccessThreshold,
                ModifierMode = NewModifierMode,
                DifficultyValue = NewDifficultyValue,
                TargetScope = NewTargetScope,
                TraitFilters = filterGroups,
                TraitFilterMode = NewTraitFilterMode,
                Consequences = ConsequenceRows.Select(c => new GameTestConsequenceDraftDto
                {
                    ApplyOn = c.ApplyOn,
                    OperationType = c.OperationType,
                    TargetKind = c.TargetKind,
                    TargetDefinitionId = c.TargetDefinitionId,
                    ModifierMode = c.ModifierMode,
                    Value = c.ValueMode == ModifierValueMode.Metric ? 0 : c.Value,
                    ValueMode = c.ValueMode,
                    SourceMetricId = c.ValueMode == ModifierValueMode.Metric ? c.SourceMetricId : null
                }).ToList()
            };

            ActiveTest = await GameTestService.CreateGameTestAsync(
                SessionId,
                CurrentUserId,
                request);

            Message = L["GameTest_Created"];
        }
        catch (Exception ex)
        {
            Message = $"{L["Common_Error"]} : {ex.Message}";
        }
    }

