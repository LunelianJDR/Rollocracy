@page "/mj/session/{SessionId:guid}"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Extensions.Localization
@using Rollocracy.Domain.Characters
@using Rollocracy.Domain.Entities
@using Rollocracy.Domain.GameRules
@using Rollocracy.Domain.GameTests
@using Rollocracy.Localization
@using Rollocracy.Domain.Polls
@using DomainSession = Rollocracy.Domain.Entities.Session
@inject NavigationManager Navigation
@inject Rollocracy.Domain.Interfaces.ISessionService SessionService
@inject Rollocracy.Domain.Interfaces.IGameSystemService GameSystemService
@inject Rollocracy.Domain.Interfaces.ICharacterService CharacterService
@inject Rollocracy.Domain.Interfaces.IGameTestService GameTestService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IStringLocalizer<SharedTexts> L
@inject Rollocracy.Domain.Interfaces.IPollService PollService

<h3>@L["SessionPage_Title"]</h3>

@if (!IsLoaded)
{
    <p>@L["Common_Loading"]</p>
}
else if (CurrentSession is null)
{
    <p>@L["SessionPage_NotFound"]</p>
}
else
{
    <p><strong>@L["SessionPage_Name"] :</strong> @CurrentSession.SessionName</p>
    <p><strong>@L["SessionPage_Slug"] :</strong> @CurrentSession.SessionSlug</p>

    <p><strong>@L["SessionPage_JoinUrl"] :</strong></p>
    <p><code>@JoinUrl</code></p>

    <p>
        <strong>@L["SessionPage_Password"] :</strong>
        @if (string.IsNullOrWhiteSpace(CurrentSession.SessionPassword))
        {
            <span>@L["Common_None"]</span>
        }
        else if (ShowSessionPassword)
        {
            <code>@CurrentSession.SessionPassword</code>
        }
        else
        {
            <code>****</code>
        }
    </p>

    @if (!string.IsNullOrWhiteSpace(CurrentSession.SessionPassword))
    {
        <button @onclick="ToggleSessionPasswordVisibility">
            @(ShowSessionPassword? L["SessionPage_HidePassword"] : L["SessionPage_ShowPassword"])
        </button>
    }

    <hr />

    <p><strong>@L["SessionPage_ConnectedPlayers"] :</strong> @SessionStats.ConnectedPlayersCount</p>
    <p><strong>@L["SessionPage_AliveCharactersCount"] :</strong> @SessionStats.AliveCharactersCount</p>
    <p><strong>@L["SessionPage_TotalCharactersCount"] :</strong> @SessionStats.TotalCharactersCount</p>

    <hr />

    <h4>@L["SessionPage_GameSystemSection"]</h4>

    @if (OwnedGameSystems.Count == 0)
    {
        <p>@L["SessionPage_NoGameSystems"]</p>
        <button @onclick="GoToCreateGameSystem">@L["SessionPage_CreateGameSystem"]</button>
    }
    else
    {
        <div>
            <label>@L["SessionPage_SelectGameSystem"]</label><br />
            <select @bind="SelectedGameSystemId">
                <option value="">@L["SessionPage_NoGameSystemSelected"]</option>
                @foreach (var gameSystem in OwnedGameSystems)
                {
                    <option value="@gameSystem.Id.ToString()">@gameSystem.Name</option>
                }
            </select>
        </div>

        <button @onclick="AssignSelectedGameSystem">@L["SessionPage_AssignGameSystem"]</button>
        <button @onclick="GoToCreateGameSystem">@L["SessionPage_CreateGameSystem"]</button>

        @if (AssignedGameSystem is not null)
        {
            <p><strong>@L["SessionPage_CurrentGameSystem"] :</strong> @AssignedGameSystem.Name</p>

            @if (AssignedGameSystem.LockedToSessionId == SessionId)
            {
                <button @onclick="EditAssignedGameSystem">@L["SessionPage_EditSessionGameSystem"]</button>
            }
            else
            {
                <button @onclick="CloneAndEditAssignedGameSystem">@L["SessionPage_CloneAndEditForSession"]</button>
            }
        }
    }

    <hr />

    <h4>@L["SessionPage_SpecialRolesSection"]</h4>

    <div>
        <button @onclick="AddSpecialRole">@L["SessionPage_AddSpecialRole"]</button>
    </div>

    @if (ShowSpecialRoleEditor)
    {
        <div style="margin-top:8px;">
            <select @bind="SelectedSpecialRolePlayerSessionId">
                <option value="">@L["SessionPage_SelectPlayer"]</option>
                @foreach (var player in SpecialRoleEligiblePlayers)
                {
                    <option value="@player.Id">@player.PlayerName</option>
                }
            </select>

            <select @bind="SelectedSpecialRole">
                <option value="@SessionSpecialRole.Observer">@L["SessionSpecialRole_Observer"]</option>
                <option value="@SessionSpecialRole.Assistant">@L["SessionSpecialRole_Assistant"]</option>
            </select>

            <button @onclick="ValidateSpecialRole">@L["Common_Save"]</button>
        </div>
    }

    @if (SpecialRoleAssignments.Count == 0)
    {
        <p>@L["SessionPage_NoSpecialRoles"]</p>
    }
    else
    {
        <ul>
            @foreach (var player in SpecialRoleAssignments)
            {
                <li>
                    @player.PlayerName - @(player.SpecialRole == SessionSpecialRole.Assistant ? L["SessionSpecialRole_Assistant"] : L["SessionSpecialRole_Observer"])
                    <button @onclick="() => RemoveSpecialRole(player.Id)">@L["EditGameSystem_Delete"]</button>
                </li>
            }
        </ul>
    }

    <hr />

    <h4>@L["SessionPage_SessionGaugesSection"]</h4>

    @if (SessionGauges.Count == 0)
    {
        <p>@L["SessionPage_NoSessionGauges"]</p>
    }
    else
    {
        <ul>
            @foreach (var gauge in SessionGauges)
            {
                <li>
                    <strong>@gauge.Name</strong> : @gauge.CurrentValue / @gauge.MaxValue
                    (min @gauge.MinValue)
                    <button @onclick="() => AskDeleteSessionGauge(gauge.SessionGaugeId)">
                        @L["EditGameSystem_Delete"]
                    </button>
                </li>
            }
        </ul>
    }

    <div style="margin-top:12px; padding:8px; border:1px solid #ccc;">
        <div>
            <label>@L["SessionPage_SessionGaugeName"]</label><br />
            <input @bind="NewSessionGaugeName" />
        </div>

        <div>
            <label>@L["SessionPage_SessionGaugeMinValue"]</label><br />
            <input type="number" @bind="NewSessionGaugeMinValue" />
        </div>

        <div>
            <label>@L["SessionPage_SessionGaugeMaxValue"]</label><br />
            <input type="number" @bind="NewSessionGaugeMaxValue" />
        </div>

        <div>
            <label>@L["SessionPage_SessionGaugeCurrentValue"]</label><br />
            <input type="number" @bind="NewSessionGaugeCurrentValue" />
        </div>

        <button @onclick="CreateSessionGauge">@L["SessionPage_AddSessionGauge"]</button>
    </div>

    @if (PendingSessionGaugeDeleteId.HasValue)
    {
        <div style="margin-top:12px; padding:8px; border:1px solid #ccc;">
            <p>@L["SessionPage_ConfirmDeleteSessionGauge"]</p>
            <button @onclick="ConfirmDeleteSessionGauge">@L["Common_Confirm"]</button>
            <button @onclick="CancelDeleteSessionGauge">@L["Common_Cancel"]</button>
        </div>
    }

    <hr />

    <hr />

<section class="rc-character-view">
    <div class="rc-character-view__top">
        <div class="rc-character-view__heading">
            <h4>@L["SessionPage_CharactersSection"]</h4>
            <p class="rc-character-view__subtitle">@L["SessionPage_NoCharactersToDisplay"]</p>
        </div>

        <div class="rc-character-view__actions">
            <button @onclick="CreateNpc">@L["SessionPage_CreateNpc"]</button>
        </div>
    </div>

    <div class="rc-character-view__filters">
        <label class="rc-filter-toggle">
            <input type="checkbox" @bind="ShowAttributes" />
            <span>@L["SessionPage_ShowAttributes"]</span>
        </label>

        <label class="rc-filter-toggle">
            <input type="checkbox" @bind="ShowTraits" />
            <span>@L["SessionPage_ShowTraits"]</span>
        </label>

        <label class="rc-filter-toggle">
            <input type="checkbox" @bind="ShowGauges" />
            <span>@L["SessionPage_ShowGauges"]</span>
        </label>

        <label class="rc-filter-toggle">
            <input type="checkbox" @bind="IncludeOffline" @bind:after="RefreshCharacterSection" />
            <span>@L["SessionPage_ShowOfflineCharacters"]</span>
        </label>

        <label class="rc-filter-toggle">
            <input type="checkbox" @bind="IncludeDead" @bind:after="RefreshCharacterSection" />
            <span>@L["SessionPage_ShowDeadCharacters"]</span>
        </label>

        <label class="rc-filter-toggle">
            <input type="checkbox" @bind="IncludeNpcs" @bind:after="RefreshCharacterSection" />
            <span>@L["SessionPage_ShowNpcs"]</span>
        </label>
    </div>

        <div class="rc-character-view__layout @(SelectedCharacterSheet is not null ? "has-selection" : string.Empty)">
            <div class="rc-character-view__grid">
                @if (Characters.Count == 0)
                {
                    <div class="rc-empty-panel">
                        <p>@L["SessionPage_NoCharactersToDisplay"]</p>
                    </div>
                }
                else
                {
                    @foreach (var character in Characters)
                    {
                        var healthGauges = character.Gauges.Where(g => g.IsHealthGauge).ToList();
                        var regularGauges = character.Gauges.Where(g => !g.IsHealthGauge).ToList();
                        var isSelected = SelectedCharacterSheet?.CharacterId == character.CharacterId;

                        <button type="button"
                                class="rc-character-card @(isSelected ? "selected" : string.Empty)"
                                @onclick="() => ToggleCharacterDetails(character.CharacterId)">

                            <div class="rc-character-card__header">
                                <div class="rc-character-card__title-wrap">
                                    <div class="rc-character-card__title">@character.CharacterName</div>

                                    <div class="rc-character-card__player">
                                        <span class="rc-character-card__player-name">@character.PlayerName</span>
                                    </div>

                                    <div class="rc-character-card__meta-row">
                                        <span class="rc-character-chip @(character.IsAlive ? "alive" : "dead")">
                                            @(character.IsAlive? L["Common_Alive"] : L["Common_Dead"])
                                        </span>

                                        <span class="rc-character-chip @(character.IsOnline ? "online" : "offline")">
                                            @(character.IsOnline? L["Common_Online"] : L["Common_Offline"])
                                        </span>

                                        @if (character.IsNpc)
                                        {
                                            <span class="rc-character-chip npc">@L["Common_Npc"]</span>
                                        }
                                    </div>
                                </div>
                            </div>

                            @if (ShowAttributes && character.Attributes.Count > 0)
                            {
                                <div class="rc-character-card__section">
                                    <div class="rc-character-card__section-title">@L["PlayerRoom_Attributes"]</div>
                                    <div class="rc-character-inline-list">
                                        @foreach (var attributeItem in character.Attributes)
                                        {
                                            <span class="rc-inline-pill">@attributeItem.Name: @attributeItem.Value</span>
                                        }
                                    </div>
                                </div>
                            }

                            @if (ShowTraits && character.DerivedStats.Count > 0)
                            {
                                <div class="rc-character-card__section">
                                    <div class="rc-character-card__section-title">@L["PlayerRoom_DerivedStats"]</div>
                                    <div class="rc-character-inline-list">
                                        @foreach (var derived in character.DerivedStats)
                                        {
                                            <span class="rc-inline-pill">@derived.Name: @derived.Value</span>
                                        }
                                    </div>
                                </div>
                            }

                            @if (ShowTraits && character.Traits.Count > 0)
                            {
                                <div class="rc-character-card__section">
                                    <div class="rc-character-card__section-title">@L["PlayerRoom_Traits"]</div>
                                    <div class="rc-character-inline-list">
                                        @foreach (var trait in character.Traits)
                                        {
                                            <span class="rc-inline-pill">@trait.TraitName: @trait.OptionName</span>
                                        }
                                    </div>
                                </div>
                            }

                            @if (ShowGauges && regularGauges.Count > 0)
                            {
                                <div class="rc-character-card__section">
                                    <div class="rc-character-card__section-title">@L["PlayerRoom_Gauges"]</div>
                                    <div class="rc-character-gauges">
                                        @foreach (var gauge in regularGauges)
                                        {
                                            <div class="rc-character-gauge-line">
                                                <span class="rc-character-gauge-line__name">@gauge.Name</span>
                                                <span class="rc-character-gauge-line__value">@gauge.Value / @gauge.MaxValue</span>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }

                            @if (healthGauges.Count > 0)
                            {
                                <div class="rc-character-card__footer">
                                    @foreach (var gauge in healthGauges)
                                    {
                                        var percent = gauge.MaxValue <= 0
                                            ? 0
                                            : Math.Clamp((int)Math.Round((double)gauge.Value * 100 / gauge.MaxValue), 0, 100);

                                        <div class="rc-health-gauge">
                                            <div class="rc-health-gauge__header">
                                                <span>@gauge.Name</span>
                                                <span>@gauge.Value / @gauge.MaxValue</span>
                                            </div>
                                            <div class="rc-health-gauge__track">
                                                <div class="rc-health-gauge__fill" style="@($"width:{percent}%")"></div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </button>
                    }
                }
            </div>

            @if (SelectedCharacterSheet is not null)
            {
                <aside class="rc-character-detail-panel">
                    <div class="rc-character-detail-panel__header">
                        <div>
                            <h5 class="rc-character-detail-panel__title">@SelectedCharacterSheet.Name</h5>
                            <div class="rc-character-detail-panel__meta">
                                <span class="rc-character-chip @(SelectedCharacterSheet.IsAlive ? "alive" : "dead")">
                                    @(SelectedCharacterSheet.IsAlive? L["Common_Alive"] : L["Common_Dead"])
                                </span>
                                @if (SelectedCharacterSummary?.IsNpc == true)
                                {
                                    <span class="rc-character-chip npc">@L["Common_Npc"]</span>
                                }
                            </div>
                        </div>

                        <div class="rc-character-detail-panel__actions">
                            @if (!ShowCharacterBioPanel)
                            {
                                <button @onclick="EditSelectedCharacter">@L["SessionPage_EditCharacter"]</button>
                                <button @onclick="ShowCharacterBio">@L["PlayerRoom_CharacterBiography"]</button>
                            }
                            else
                            {
                                <button @onclick="EditSelectedCharacter">@L["SessionPage_EditCharacter"]</button>
                                <button @onclick="HideCharacterBio">@L["Common_Cancel"]</button>
                            }
                        </div>
                    </div>

                    @if (ShowCharacterBioPanel)
                    {
                        <div class="rc-character-detail-panel__body">
                            @if (string.IsNullOrWhiteSpace(SelectedCharacterSheet.Biography))
                            {
                                <p>@L["EditCharacter_NotFound"]</p>
                            }
                            else
                            {
                                <p class="rc-character-bio">@SelectedCharacterSheet.Biography</p>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="rc-character-detail-panel__body">
                            <div class="rc-detail-block">
                                <div class="rc-detail-block__title">@L["SessionPage_PlayerName"]</div>
                                <div>@(SelectedCharacterSummary?.PlayerName ?? "-")</div>
                            </div>

                            <div class="rc-detail-block">
                                <div class="rc-detail-block__title">@L["PlayerRoom_Attributes"]</div>
                                <ul class="rc-detail-list">
                                    @foreach (var attributeLine in SelectedCharacterSheet.Attributes)
                                    {
                                        <li>@attributeLine.Name : @attributeLine.Value</li>
                                    }
                                </ul>
                            </div>

                            @if (SelectedCharacterSheet.DerivedStats.Count > 0)
                            {
                                <div class="rc-detail-block">
                                    <div class="rc-detail-block__title">@L["PlayerRoom_DerivedStats"]</div>
                                    <ul class="rc-detail-list">
                                        @foreach (var derivedLine in SelectedCharacterSheet.DerivedStats)
                                        {
                                            <li>@derivedLine.Name : @derivedLine.Value</li>
                                        }
                                    </ul>
                                </div>
                            }

                            <div class="rc-detail-block">
                                <div class="rc-detail-block__title">@L["PlayerRoom_Traits"]</div>
                                <ul class="rc-detail-list">
                                    @foreach (var traitLine in SelectedCharacterSheet.Traits)
                                    {
                                        <li>@traitLine.TraitName : @traitLine.OptionName</li>
                                    }
                                </ul>
                            </div>

                            @if (SelectedCharacterSheet.Talents?.Count > 0)
                            {
                                <div class="rc-detail-block">
                                    <div class="rc-detail-block__title">@L["EditCharacter_Talents"]</div>
                                    <ul class="rc-detail-list">
                                        @foreach (var talentLine in SelectedCharacterSheet.Talents)
                                        {
                                            <li>@talentLine.Name</li>
                                        }
                                    </ul>
                                </div>
                            }

                            @if (SelectedCharacterSheet.Items?.Count > 0)
                            {
                                <div class="rc-detail-block">
                                    <div class="rc-detail-block__title">@L["EditCharacter_Items"]</div>
                                    <ul class="rc-detail-list">
                                        @foreach (var itemLine in SelectedCharacterSheet.Items)
                                        {
                                            <li>@itemLine.Name</li>
                                        }
                                    </ul>
                                </div>
                            }

                            <div class="rc-detail-block">
                                <div class="rc-detail-block__title">@L["PlayerRoom_Gauges"]</div>
                                <ul class="rc-detail-list">
                                    @foreach (var gaugeLine in SelectedCharacterSheet.Gauges)
                                    {
                                        <li>@gaugeLine.Name : @gaugeLine.Value / @gaugeLine.MaxValue</li>
                                    }
                                </ul>
                            </div>
                        </div>
                    }
                </aside>
            }
        </div>
    </section>

    <hr />

    <p><strong>@L["SessionPage_SessionId"] :</strong> @SessionId</p>
}

@code {
    [Parameter] public Guid SessionId { get; set; }

    private HubConnection? hubConnection;

    private DomainSession? CurrentSession;
    private GameSystem? AssignedGameSystem;
    private List<GameSystem> OwnedGameSystems = new();
    private List<AttributeDefinition> AvailableAttributes = new();
    private List<SessionCharacterSummaryDto> Characters = new();
    private List<SessionGaugeDto> SessionGauges = new();
    private string NewSessionGaugeName = string.Empty;
    private int NewSessionGaugeMinValue = 0;
    private int NewSessionGaugeMaxValue = 10;
    private int NewSessionGaugeCurrentValue = 10;
    private Guid? PendingSessionGaugeDeleteId;
    private CharacterSheetDto? SelectedCharacterSheet;
    private SessionPublicStatsDto SessionStats = new();
    private GameMasterActiveGameTestDto? ActiveTest;

    private List<TraitDefinition> AvailableTraitDefinitions = new();
    private Dictionary<Guid, List<TraitOption>> TraitOptionsByDefinition = new();
    private List<GaugeDefinition> AvailableGaugeDefinitions = new();
    private List<MetricDefinition> AvailableMetrics = new();
    private List<EditableDerivedStatDefinitionDto> AvailableDerivedStats = new();
    private List<EditableTalentDefinitionDto> AvailableTalents = new();
    private List<EditableItemDefinitionDto> AvailableItems = new();
    private List<PlayerSession> SpecialRoleEligiblePlayers = new();
    private List<PlayerSession> SpecialRoleAssignments = new();
    private string SelectedSpecialRolePlayerSessionId = string.Empty;
    private SessionSpecialRole SelectedSpecialRole = SessionSpecialRole.Observer;
    private bool ShowSpecialRoleEditor;

    private TestModifierMode NewModifierMode = TestModifierMode.Bonus;
    private int NewDifficultyValue = 0;
    private TestTargetScope NewTargetScope = TestTargetScope.OnlineLivingCharacters;

    private HashSet<Guid> SelectedTraitOptionIds = new();
    private List<ConsequenceRowModel> ConsequenceRows = new();

    private bool IsLoaded;
    private bool ShowSessionPassword;

    private bool ShowAttributes;
    private bool ShowTraits;
    private bool ShowGauges;
    private bool IncludeOffline;
    private bool IncludeDead;
    private bool IncludeNpcs;
    private bool ShowCharacterBioPanel;

    private SessionCharacterSummaryDto? SelectedCharacterSummary
    => SelectedCharacterSheet is null
        ? null
        : Characters.FirstOrDefault(x => x.CharacterId == SelectedCharacterSheet.CharacterId);

    private Guid CurrentUserId;
    private string CurrentUsername = string.Empty;
    private string JoinUrl = string.Empty;
    private string Message = string.Empty;
    private string SelectedGameSystemId = string.Empty;

    private string SelectedAttributeId = string.Empty;
    private GameTestTargetKind NewTargetKind = GameTestTargetKind.BaseAttribute;
    private bool UseSystemDefaultDice = true;
    private int NewDiceCount = 1;
    private int NewDiceSides = 100;
    private int? NewSuccessThreshold;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        var userIdValue = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        CurrentUsername = user.Identity?.Name ?? string.Empty;

        if (!string.IsNullOrWhiteSpace(userIdValue))
        {
            CurrentUserId = Guid.Parse(userIdValue);
        }

        await LoadSessionData();

        if (CurrentSession is not null && !string.IsNullOrWhiteSpace(CurrentUsername))
        {
            JoinUrl = $"{Navigation.BaseUri}{CurrentUsername}/{CurrentSession.SessionSlug}";
        }

        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/sessionhub"))
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On("PresenceChanged", async () =>
        {
            await InvokeAsync(async () =>
            {
                await RefreshSessionVisuals();
                StateHasChanged();
            });
        });

        hubConnection.On("CharacterStateChanged", async () =>
        {
            await InvokeAsync(async () =>
            {
                await RefreshSessionVisuals();
                StateHasChanged();
            });
        });

        hubConnection.On("TestChanged", async () =>
        {
            await InvokeAsync(async () =>
            {
                await LoadActiveTest();
                StateHasChanged();
            });
        });

        hubConnection.On("PollChanged", async () =>
        {
            await InvokeAsync(async () =>
            {
                await LoadLatestPoll();
                StateHasChanged();
            });
        });

        await hubConnection.StartAsync();
        await hubConnection.SendAsync("JoinSessionGroup", SessionId.ToString());
        await hubConnection.SendAsync("JoinPlayerPresence", SessionId.ToString(), Guid.NewGuid().ToString(), true);

        IsLoaded = true;
    }

    private async Task LoadSessionData()
    {
        CurrentSession = await SessionService.GetSessionByIdAsync(SessionId);
        OwnedGameSystems = await GameSystemService.GetGameSystemsByOwnerAsync(CurrentUserId);

        AssignedGameSystem = null;
        AvailableAttributes.Clear();
        AvailableTraitDefinitions.Clear();
        TraitOptionsByDefinition.Clear();
        AvailableGaugeDefinitions.Clear();
        AvailableMetrics.Clear();
        AvailableDerivedStats.Clear();
        AvailableTalents.Clear();
        AvailableItems.Clear();
        SelectedGameSystemId = string.Empty;

        SpecialRoleEligiblePlayers = await SessionService.GetEligibleSpecialRolePlayersAsync(SessionId, CurrentUserId);
        SpecialRoleAssignments = await SessionService.GetPlayersWithSpecialRolesAsync(SessionId, CurrentUserId);
        SessionGauges = await SessionService.GetSessionGaugesAsync(SessionId, CurrentUserId);

        if (CurrentSession?.GameSystemId is Guid gameSystemId)
        {
            AssignedGameSystem = await GameSystemService.GetGameSystemByIdAsync(gameSystemId, CurrentUserId);

            if (AssignedGameSystem is not null)
            {
                AvailableAttributes = await GameSystemService.GetAttributeDefinitionsAsync(AssignedGameSystem.Id, CurrentUserId);
                AvailableTraitDefinitions = await GameSystemService.GetTraitDefinitionsAsync(AssignedGameSystem.Id, CurrentUserId);
                AvailableGaugeDefinitions = await GameSystemService.GetGaugeDefinitionsAsync(AssignedGameSystem.Id, CurrentUserId);
                AvailableMetrics = await GameSystemService.GetMetricDefinitionsAsync(AssignedGameSystem.Id, CurrentUserId);

                var editor = await GameSystemService.GetGameSystemEditorAsync(AssignedGameSystem.Id, CurrentUserId);
                if (editor is not null)
                {
                    AvailableDerivedStats = editor.DerivedStats;
                    AvailableTalents = editor.Talents;
                    AvailableItems = editor.Items;
                }

                NewDiceCount = AssignedGameSystem.DefaultTestDiceCount;
                NewDiceSides = AssignedGameSystem.DefaultTestDiceSides;
                UseSystemDefaultDice = true;
                SelectedAttributeId = AvailableAttributes.FirstOrDefault()?.Id.ToString() ?? AvailableDerivedStats.FirstOrDefault()?.DerivedStatDefinitionId?.ToString() ?? string.Empty;

                foreach (var traitDefinition in AvailableTraitDefinitions)
                {
                    var options = await GameSystemService.GetTraitOptionsAsync(traitDefinition.Id, CurrentUserId);
                    TraitOptionsByDefinition[traitDefinition.Id] = options;
                }

                if (AssignedGameSystem.LockedToSessionId == null)
                {
                    SelectedGameSystemId = AssignedGameSystem.Id.ToString();
                }
            }
        }

        await RefreshSessionVisuals();
        await LoadActiveTest();
        await LoadLatestPoll();
    }

        private async Task CreateSessionGauge()
    {
        try
        {
            Message = string.Empty;

            await SessionService.CreateSessionGaugeAsync(
                SessionId,
                CurrentUserId,
                NewSessionGaugeName,
                NewSessionGaugeMinValue,
                NewSessionGaugeMaxValue,
                NewSessionGaugeCurrentValue);

            NewSessionGaugeName = string.Empty;
            NewSessionGaugeMinValue = 0;
            NewSessionGaugeMaxValue = 10;
            NewSessionGaugeCurrentValue = 10;

            await LoadSessionData();
        }
        catch (Exception ex)
        {
            Message = $"{L["Common_Error"]} : {ex.Message}";
        }
    }

    private void AskDeleteSessionGauge(Guid sessionGaugeId)
    {
        PendingSessionGaugeDeleteId = sessionGaugeId;
