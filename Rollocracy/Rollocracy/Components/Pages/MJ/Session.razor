    private Task AddPollOptionConsequence(int optionIndex)
    {
        if (optionIndex < 0 || optionIndex >= NewPollOptions.Count)
            return Task.CompletedTask;

        var targetKind = AvailableGaugeDefinitions.Count > 0
            ? TestConsequenceTargetKind.Gauge
            : TestConsequenceTargetKind.Attribute;

        var targetDefinitionId = Guid.Empty;

        if (targetKind == TestConsequenceTargetKind.Gauge && AvailableGaugeDefinitions.Count > 0)
        {
            targetDefinitionId = AvailableGaugeDefinitions[0].Id;
        }
        else if (AvailableAttributes.Count > 0)
        {
            targetDefinitionId = AvailableAttributes[0].Id;
        }

        NewPollOptions[optionIndex].Consequences.Add(new PollOptionConsequenceRowModel
        {
            RowId = Guid.NewGuid(),
            TargetKind = targetKind,
            TargetDefinitionId = targetDefinitionId,
            ModifierMode = TestModifierMode.Malus,
            OperationType = TestConsequenceOperationType.AddValue,
            Value = 1,
            ValueMode = ModifierValueMode.Fixed,
            SourceMetricId = AvailableMetrics.FirstOrDefault()?.Id
        });

        return Task.CompletedTask;
    }

    private Task RemovePollOptionConsequence(int optionIndex, Guid rowId)
    {
        if (optionIndex < 0 || optionIndex >= NewPollOptions.Count)
            return Task.CompletedTask;

        var row = NewPollOptions[optionIndex].Consequences.FirstOrDefault(x => x.RowId == rowId);

        if (row is not null)
        {
            NewPollOptions[optionIndex].Consequences.Remove(row);
        }

        return Task.CompletedTask;
    }

