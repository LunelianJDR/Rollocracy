@page "/register"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using Microsoft.Extensions.Localization
@using Rollocracy.Localization
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedTexts> L

<h3>@L["Register_Title"]</h3>

<div>
    <label>@L["Register_Username"]</label><br />
    <input @bind="Username" />
</div>

<div>
    <label>@L["Register_Password"]</label><br />
    <input @bind="Password" type="password" />
</div>

<div>
    <label>
        <input type="checkbox" @bind="IsGameMaster" />
        @L["Register_IsGameMaster"]
    </label>
</div>

<div>
    <label>@L["Register_Language"]</label><br />
    <select @bind="SelectedLanguage">
        <option value="fr">@L["Language_French"]</option>
        <option value="en">@L["Language_English"]</option>
    </select>
</div>

<button @onclick="HandleRegister">@L["Register_Submit"]</button>

@if (!string.IsNullOrWhiteSpace(Message))
{
    <p>@Message</p>
}

@code {
    private string Username = string.Empty;
    private string Password = string.Empty;
    private bool IsGameMaster;
    private string SelectedLanguage = "fr";
    private string Message = string.Empty;

    private async Task HandleRegister()
    {
        try
        {
            var request = new
            {
                Username,
                Password,
                IsGameMaster,
                Language = SelectedLanguage
            };

            var response = await Http.PostAsJsonAsync("api/auth/register", request);

            if (response.IsSuccessStatusCode)
            {
                Message = L["Register_Success"];
                Navigation.NavigateTo("/login");
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Message = $"{L["Common_Error"]} : {error}";
            }
        }
        catch (Exception ex)
        {
            Message = $"{L["Common_Error"]} : {ex.Message}";
        }
    }
}